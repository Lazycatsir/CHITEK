---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { getHreflang, type Locale } from '../i18n/index';

export interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'pt' | 'es' | 'ar' | 'zh';
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: 'website' | 'article';
}

const { title, description, lang = 'en', ogTitle, ogDescription, ogImage, ogUrl, ogType = 'website' } = Astro.props;
const defaultOgImage = 'https://chitek-inno.com/assets/images/logo.webp';

const currentPath = Astro.url.pathname;
const canonicalUrl = ogUrl || getHreflang(lang as Locale, currentPath);
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Alternate language links -->
  <link rel="alternate" hreflang="zh" href={getHreflang('zh', currentPath)} />
  <link rel="alternate" hreflang="en" href={getHreflang('en', currentPath)} />
  <link rel="alternate" hreflang="pt" href={getHreflang('pt', currentPath)} />
  <link rel="alternate" hreflang="es" href={getHreflang('es', currentPath)} />
  <link rel="alternate" hreflang="ar" href={getHreflang('ar', currentPath)} />
  <link rel="alternate" hreflang="x-default" href={getHreflang('zh', currentPath)} />

  <!-- Open Graph -->
  <meta property="og:locale" content={lang === 'pt' ? 'pt_PT' : lang === 'es' ? 'es_ES' : lang === 'ar' ? 'ar_SA' : lang === 'zh' ? 'zh_CN' : 'en_US'} />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={ogDescription || description} />
  <meta property="og:image" content={ogImage || defaultOgImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="CHITEK INNOPOWER" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle || title} />
  <meta name="twitter:description" content={ogDescription || description} />

  <!-- Structured Data -->
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CHITEK INNOPOWER",
  "url": "https://chitek-inno.com",
  "logo": "https://chitek-inno.com/assets/images/logo.webp",
  "description": "Leading manufacturer of low-voltage power quality solutions — Active Harmonic Filter (AHF), Static Var Generator (SVG), and Automatic Voltage Regulator (AVR).",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+86-18818994346",
    "contactType": "sales",
    "availableLanguage": ["English", "Portuguese", "Spanish", "Arabic", "Chinese"]
  },
  "sameAs": []
}
  </script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CHITEK INNOPOWER",
  "url": "https://chitek-inno.com",
  "description": "B2B industrial power quality solutions manufacturer — AHF, SVG, AVR for global industrial and commercial applications.",
    "inLanguage": ["en", "pt", "es", "ar", "zh"]
}
  </script>
  <slot name="head" />
</head>
<body class="font-barlow text-text-dark bg-white overflow-x-hidden min-h-screen flex flex-col">
  <Nav lang={lang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />
  <Sidebar lang={lang} />

  <!-- Shared scroll animation -->
  <script>
    (function() {
      'use strict';
      function initScrollAnimation() {
        var observer = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(e) {
              if (e.isIntersecting) e.target.classList.add('visible');
            });
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.fade-up').forEach(function(el) {
          observer.observe(el);
        });
        setTimeout(function() {
          document.querySelectorAll('.hero .fade-up').forEach(function(el) {
            el.classList.add('visible');
          });
        }, 100);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollAnimation);
      } else {
        initScrollAnimation();
      }
    })();
  </script>
</body>
</html>
