---
export interface Props {
  lang?: 'en' | 'pt' | 'es' | 'ar' | 'zh';
}
const { lang = 'en' } = Astro.props;

const t: Record<string, { en: string; pt: string; es: string; ar: string; zh: string }> = {
  subscribeText: { en: 'Subscribe to us to enjoy event prices, along with dedicated technical support.', pt: 'Inscreva-se para aproveitar preços especiais, juntamente com suporte técnico dedicado.', es: 'Suscríbase para disfrutar de precios especiales y soporte técnico dedicado.', ar: 'اشترك معنا للاستمتاع بأسعار الفعاليات مع دعم فني مخصص.', zh: '订阅我们，享受活动优惠价格及专属技术支持。' },
  emailPlaceholder: { en: 'name@email.com', pt: 'nome@email.com', es: 'nombre@email.com', ar: 'name@email.com', zh: 'name@email.com' },
  subscribeBtn: { en: 'Subscribe', pt: 'Inscrever-se', es: 'Suscribirse', ar: 'اشترك', zh: '订阅' },
  products: { en: 'Products', pt: 'Produtos', es: 'Productos', ar: 'المنتجات', zh: '产品中心' },
  activeHarmonicFilter: { en: 'Active Harmonic Filter', pt: 'Filtro Harmônico Ativo', es: 'Filtro Armónico Activo', ar: 'فلتر التوافق النشط', zh: '有源滤波器' },
  advancedSvg: { en: 'Advanced Static Var Generator', pt: 'Gerador Estático de Var Avançado', es: 'Generador Estático de Var Avanzado', ar: 'مولد الفولت أمبير الساكن المتقدم', zh: '静止无功发生器' },
  sicHighEfficiency: { en: 'SiC-AHF/SVG (High Efficiency)', pt: 'SiC-AHF/SVG (Alta Eficiência)', es: 'SiC-AHF/SVG (Alta Eficiencia)', ar: 'SiC-AHF/SVG (كفاءة عالية)', zh: 'SiC-AHF/SVG（高效型）' },
  highProtection: { en: 'High-Protection AHF/SVG', pt: 'AHF/SVG de Alta Proteção', es: 'AHF/SVG de Alta Protección', ar: 'AHF/SVG حماية عالية', zh: '高防护 AHF/SVG' },
  solutions: { en: 'Solutions', pt: 'Soluções', es: 'Soluciones', ar: 'الحلول', zh: '解决方案' },
  industrialManufacturing: { en: 'Industrial Manufacturing', pt: 'Manufatura Industrial', es: 'Fabricación Industrial', ar: 'التصنيع الصناعي', zh: '工业制造' },
  commercialMedical: { en: 'Commercial & Medical Buildings', pt: 'Edifícios Comerciais e Médicos', es: 'Edificios Comerciales y Médicos', ar: 'المباني التجارية والطبية', zh: '商业及医疗建筑' },
  dataCentersTelecom: { en: 'Data Centers & Telecom', pt: 'Data Centers e Telecom', es: 'Centros de Datos y Telecomunicaciones', ar: 'مراكز البيانات والاتصالات', zh: '数据中心与通信' },
  renewableEnergy: { en: 'Renewable Energy (PV/Wind)', pt: 'Energia Renovável (FV/Eólica)', es: 'Energía Renovable (FV/Eólica)', ar: 'الطاقة المتجددة (الطاقة الشمسية/الرياح)', zh: '新能源（光伏/风电）' },
  transportation: { en: 'Transportation (Rail/Charging)', pt: 'Transporte (Ferroviário/Carregamento)', es: 'Transporte (Ferroviario/Carga)', ar: 'النقل (السكك الحديدية/الشحن)', zh: '轨道交通与充电' },
  powerGridUtility: { en: 'Power Grid & Utility', pt: 'Rede Elétrica e Utilidades', es: 'Red Eléctrica y Servicios Públicos', ar: 'شبكة الكهرباء والمرافق', zh: '电网与公用事业' },
  resourcesPartnership: { en: 'Resources & Partnership', pt: 'Recursos e Parcerias', es: 'Recursos y Asociaciones', ar: 'الموارد والشراكات', zh: '资源与合作' },
  news: { en: 'News & Insights', pt: 'Notícias e Insights', es: 'Noticias y Perspectivas', ar: 'الأخبار والرؤى', zh: '新闻资讯' },
  technicalLibrary: { en: 'Technical Library', pt: 'Biblioteca Técnica', es: 'Biblioteca Técnica', ar: 'المكتبة التقنية', zh: '技术资料库' },
  globalReferences: { en: 'Global References', pt: 'Referências Globales', es: 'Referencias Globales', ar: 'المراجع العالمية', zh: '全球项目案例' },
  oemOdmServices: { en: 'OEM & ODM Services', pt: 'Serviços OEM e ODM', es: 'Servicios OEM y ODM', ar: 'خدمات OEM و ODM', zh: 'OEM与ODM服务' },
  becomeDistributor: { en: 'Become a Distributor', pt: 'Torne-se um Distribuidor', es: 'Conviértase en Distribuidor', ar: 'كن موزعاً', zh: '成为经销商' },
  copyright: { en: '© 2026 Shenzhen CHITEK New Energy Technology Co., Ltd. All Rights Reserved.', pt: '© 2026 Shenzhen CHITEK New Energy Technology Co., Ltd. Todos os Direitos Reservados.', es: '© 2026 Shenzhen CHITEK New Energy Technology Co., Ltd. Todos los Derechos Reservados.', ar: '© 2026 شركة شنجن تشيتكتك لتكنولوجيا الطاقة الجديدة المحدودة. جميع الحقوق محفوظة.', zh: '© 2026 深圳市启点新能源科技有限公司 版权所有' },
  ipv6Served: { en: 'IPV6 Served', pt: 'IPV6 Atendido', es: 'IPV6 Atendido', ar: 'IPV6 مدعوم', zh: 'IPV6 支持' },
};
function _(key: string): string {
  return t[key]?.[lang] || t[key]?.en || key;
}
// 本地（localhost）全语言用路径前缀；线上维持原 prefix 逻辑
const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const prefix = isLocal
  ? (lang === 'en' ? '/en' : lang === 'es' ? '/es' : lang === 'ar' ? '/ar' : lang === 'pt' ? '/pt' : '')
  : (lang === 'pt' ? '/pt' : lang === 'es' ? '/es' : lang === 'ar' ? '/ar' : lang === 'zh' ? '/zh' : '');
const productsHref = prefix + '/products';
const solutionsHref = prefix + '/solutions';
const servicesHref = prefix + '/services';
const newsHref = prefix + '/news';
---
<footer class="bg-footer-bg text-white" id="footer">
  <div class="px-[clamp(24px,8vw,160px)]">
    <div class="pt-[clamp(32px,6vw,80px)] pb-[clamp(24px,4vw,56px)] border-b border-white/10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr] gap-[clamp(16px,3vw,48px)]">
    <div class="flex flex-col">
      <img src="/assets/images/logo.webp" alt="CHITEK Logo" width="140" height="48" loading="lazy" class="w-[clamp(100px,10vw,160px)] h-auto object-contain mb-[clamp(8px,1.5vw,20px)]" />
      <p class="text-[clamp(11px,0.9vw,14px)] text-white/70 leading-[1.8] max-w-[260px] mb-[clamp(12px,2vw,32px)]">{_('subscribeText')}</p>
      <div class="flex">
        <input type="email" placeholder={_('emailPlaceholder')} class="flex-1 bg-white/10 border border-white/20 border-r-0 text-white text-[clamp(11px,0.9vw,14px)] px-3.5 py-[11px] rounded-l-sm outline-none placeholder:text-white/50" />
        <button class="bg-brand-orange text-white border-none cursor-pointer text-[clamp(10px,0.8vw,13px)] font-semibold tracking-[0.08em] uppercase px-[18px] py-[11px] rounded-r-sm hover:bg-brand-orange-dark transition-colors duration-200">{_('subscribeBtn')}</button>
      </div>
      <div class="flex gap-[clamp(6px,1vw,12px)] mt-6">
        <div class="w-9 h-9 rounded-sm border border-white/20 flex items-center justify-center cursor-pointer hover:border-brand-orange hover:bg-brand-orange/10 transition-all duration-200">
          <svg viewBox="0 0 24 24" class="w-[15px] h-[15px] fill-white/70"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </div>
        <div class="w-9 h-9 rounded-sm border border-white/20 flex items-center justify-center cursor-pointer hover:border-brand-orange hover:bg-brand-orange/10 transition-all duration-200">
          <svg viewBox="0 0 24 24" class="w-[15px] h-[15px] fill-white/70"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
        </div>
        <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-sm border border-white/20 flex items-center justify-center cursor-pointer hover:border-brand-orange hover:bg-brand-orange/10 transition-all duration-200">
          <svg viewBox="0 0 24 24" class="w-[15px] h-[15px] fill-white/70"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>
    <div class="footer-col">
      <h4 class="text-[clamp(12px,1vw,16px)] font-bold tracking-[0.08em] uppercase text-white mb-[clamp(12px,2vw,32px)]">{_('products')}</h4>
      <ul class="list-none flex flex-col gap-[clamp(6px,1vw,14px)]">
        <li><a href={productsHref + '#ahf'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('activeHarmonicFilter')}</a></li>
        <li><a href={productsHref + '#svg'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('advancedSvg')}</a></li>
        <li><a href={productsHref + '#sic'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('sicHighEfficiency')}</a></li>
        <li><a href={productsHref + '#high-protection'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('highProtection')}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4 class="text-[clamp(12px,1vw,16px)] font-bold tracking-[0.08em] uppercase text-white mb-[clamp(12px,2vw,32px)]">{_('solutions')}</h4>
      <ul class="list-none flex flex-col gap-[clamp(6px,1vw,14px)]">
        <li><a href={solutionsHref + '#industry'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('industrialManufacturing')}</a></li>
        <li><a href={solutionsHref + '#commercial'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('commercialMedical')}</a></li>
        <li><a href={solutionsHref + '#datacenter'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('dataCentersTelecom')}</a></li>
        <li><a href={solutionsHref + '#renewable'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('renewableEnergy')}</a></li>
        <li><a href={solutionsHref + '#rail'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('transportation')}</a></li>
        <li><a href={solutionsHref + '#grid'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('powerGridUtility')}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4 class="text-[clamp(12px,1vw,16px)] font-bold tracking-[0.08em] uppercase text-white mb-[clamp(12px,2vw,32px)]">{_('resourcesPartnership')}</h4>
      <ul class="list-none flex flex-col gap-[clamp(6px,1vw,14px)]">
        <li><a href={servicesHref + '#tech-support'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('technicalLibrary')}</a></li>
        <li><a href={servicesHref + '#tech-support'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('globalReferences')}</a></li>
        <li><a href={servicesHref + '#oem'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('oemOdmServices')}</a></li>
        <li><a href={servicesHref + '#distributor'} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('becomeDistributor')}</a></li>
        {(lang === 'zh' || lang === 'en' || lang === 'es' || lang === 'ar') && <li><a href={newsHref} class="text-[clamp(11px,0.9vw,14px)] text-white/70 no-underline hover:text-brand-orange transition-colors duration-200">{_('news')}</a></li>}
      </ul>
    </div>
  </div>
  <div class="py-[clamp(12px,2vw,32px)] flex flex-col md:flex-row items-center justify-between gap-[clamp(8px,2vw,28px)]">
    <p class="text-[clamp(10px,0.8vw,13px)] text-white/60 tracking-[0.04em]">{_('copyright')}</p>
    <div class="flex gap-6">
      <a href="#" class="text-[12px] text-white/60 no-underline hover:text-white transition-colors duration-200">{_('ipv6Served')}</a>
    </div>
  </div>
</div>
</footer>
