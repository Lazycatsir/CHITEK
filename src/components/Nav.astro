      <a href={ptHref} class="lang-item flex items-center justify-between px-5 py-2.5 cursor-pointer transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:border-l-brand-orange hover:pl-6 no-underline {lang === 'pt' ? 'bg-[rgba(255,107,26,0.08)] border-l-brand-orange' : ''}">
        <span class="text-[13px] text-text-mid font-medium">Portugu&ecirc;s</span>
        <img src="/assets/images/flags/pt.png" alt="Portugal" class="w-6 h-4 object-cover rounded-sm ml-3 shadow-sm" />
      </a>
      <a href={esHref} class="lang-item flex items-center justify-between px-5 py-2.5 cursor-pointer transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:border-l-brand-orange hover:pl-6 no-underline {lang === 'es' ? 'bg-[rgba(255,107,26,0.08)] border-l-brand-orange' : ''}">
        <span class="text-[13px] text-text-mid font-medium">Espa&ntilde;ol</span>
        <img src="/assets/images/flags/es.png" alt="Spain" class="w-6 h-4 object-cover rounded-sm ml-3 shadow-sm" />
      </a>
      <a href={arHref} class="lang-item flex items-center justify-between px-5 py-2.5 cursor-pointer transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:border-l-brand-orange hover:pl-6 no-underline {lang === 'ar' ? 'bg-[rgba(255,107,26,0.08)] border-l-brand-orange' : ''}">
        <span class="text-[13px] text-text-mid font-medium">العربية</span>
        <img src="/assets/images/flags/sa.png" alt="Saudi Arabia" class="w-6 h-4 object-cover rounded-sm ml-3 shadow-sm" />
      </a>
      <a href={zhHref} class="lang-item flex items-center justify-between px-5 py-2.5 cursor-pointer transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:border-l-brand-orange hover:pl-6 no-underline {lang === 'zh' ? 'bg-[rgba(255,107,26,0.08)] border-l-brand-orange' : ''}">
        <span class="text-[13px] text-text-mid font-medium">中文</span>
        <img src="/assets/images/flags/cn.png" alt="China" class="w-6 h-4 object-cover rounded-sm ml-3 shadow-sm" />
      </a>
    </div>
  </div>
</div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu hidden fixed top-[72px] left-0 right-0 bottom-0 bg-white z-[999] flex-col px-5 py-4 pb-8 overflow-y-auto border-t border-border-light" id="mobileMenu">
  <div class="border-b border-border-light">
    <div class="mobile-menu-parent flex items-center justify-between py-4 text-[15px] font-semibold text-text-dark cursor-pointer no-underline tracking-[0.02em]" data-submenu="mobile-products">
      {_('products')}
      <span class="text-[10px] text-text-muted transition-transform duration-200">▾</span>
    </div>
    <div class="mobile-submenu hidden flex-col gap-1 pl-4 pb-4" id="mobile-products">
