---
export interface Props {
  lang?: 'en' | 'pt' | 'es' | 'ar' | 'zh';
}
const { lang = 'en' } = Astro.props;
const isRtl = lang === 'ar';

const t: Record<string, { en: string; pt: string; es: string; ar: string; zh: string }> = {
  products: { en: 'Products', pt: 'Produtos', es: 'Productos', ar: 'المنتجات', zh: '产品中心' },
  solutions: { en: 'Solutions', pt: 'Soluções', es: 'Soluciones', ar: 'الحلول', zh: '解决方案' },
  services: { en: 'Services', pt: 'Serviços', es: 'Servicios', ar: 'الخدمات', zh: '服务支持' },
  news: { en: 'News', pt: 'Notícias', es: 'Noticias', ar: 'الأخبار', zh: '新闻资讯' },
  about: { en: 'About', pt: 'Sobre', es: 'Sobre Nosotros', ar: 'عن الشركة', zh: '关于我们' },
  contact: { en: 'Contact', pt: 'Contato', es: 'Contacto', ar: 'اتصل بنا', zh: '联系我们' },
  search: { en: 'Search...', pt: 'Pesquisar...', es: 'Buscar...', ar: 'بحث...', zh: '搜索...' },
  activeHarmonicFilter: { en: 'Active Harmonic Filter', pt: 'Filtro Harmônico Ativo', es: 'Filtro Armónico Activo', ar: 'فلتر التوافق النشط', zh: '有源滤波器AHF' },
  staticVarGenerator: { en: 'Static Var Generator', pt: 'Gerador Estático de Var', es: 'Generador Estático de Var', ar: 'مولد الفولت أمبير الساكن', zh: '无功静止发生器SVG' },
  sicAhfSvg: { en: 'SiC AHF/SVG', pt: 'SiC AHF/SVG', es: 'SiC AHF/SVG', ar: 'SiC AHF/SVG', zh: '碳化硅系列 Sic AHF/SVG' },
  industrialManufacturing: { en: 'Industrial Manufacturing', pt: 'Manufatura Industrial', es: 'Fabricación Industrial', ar: 'التصنيع الصناعي', zh: '工业制造' },
  commercialMedical: { en: 'Commercial & Medical Buildings', pt: 'Edifícios Comerciais e Médicos', es: 'Edificios Comerciales y Médicos', ar: 'المباني التجارية والطبية', zh: '商业及医疗建筑' },
  dataCentersTelecom: { en: 'Data Centers & Telecom', pt: 'Data Centers e Telecom', es: 'Centros de Datos y Telecomunicaciones', ar: 'مراكز البيانات والاتصالات', zh: '数据中心与通信' },
  renewableEnergy: { en: 'Renewable Energy (PV/Wind)', pt: 'Energia Renovável (FV/Eólica)', es: 'Energía Renovable (FV/Eólica)', ar: 'الطاقة المتجددة (الطاقة الشمسية/الرياح)', zh: '新能源（光伏/风电）' },
  transportation: { en: 'Transportation (Rail/Charging)', pt: 'Transporte (Ferroviário/Carregamento)', es: 'Transporte (Ferroviario/Carga)', ar: 'النقل (السكك الحديدية/الشحن)', zh: '轨道交通与充电' },
  powerGridUtility: { en: 'Power Grid & Utility', pt: 'Rede Elétrica e Utilidades', es: 'Red Eléctrica y Servicios Públicos', ar: 'شبكة الكهرباء والمرافق', zh: '电网与公用事业' },
  oemOdm: { en: 'OEM/ODM', pt: 'OEM/ODM', es: 'OEM/ODM', ar: 'OEM/ODM', zh: 'OEM/ODM' },
  technicalSupport: { en: 'Technical Support', pt: 'Suporte Técnico', es: 'Soporte Técnico', ar: 'الدعم الفني', zh: '技术支持' },
  distributorProgram: { en: 'Distributor Program', pt: 'Programa de Distribuidores', es: 'Programa de Distribuidores', ar: 'برنامج الموزعين', zh: '经销商计划' },
  companyProfile: { en: 'Company Profile', pt: 'Perfil da Empresa', es: 'Perfil de la Empresa', ar: 'ملف الشركة', zh: '公司简介' },
  caseStudies: { en: 'Case Studies', pt: 'Estudos de Caso', es: 'Casos de Estudio', ar: 'دراسات الحالة', zh: '案例研究' },
  certifications: { en: 'Certifications', pt: 'Certificações', es: 'Certificaciones', ar: 'الشهادات', zh: '资质认证' },
};

function _(key: string): string {
  return t[key]?.[lang] || t[key]?.en || key;
}
const langLabel: Record<string, string> = { en: 'English', pt: 'Português', es: 'Español', ar: 'العربية', zh: '中文' };
const langFlagCode: Record<string, string> = { en: 'gb', pt: 'pt', es: 'es', ar: 'sa', zh: 'cn' };

/** Build href for a target language from current pathname */
function langHref(targetLang: string): string {
  const { pathname } = Astro.url;
  // Strip existing language prefix
  let base = pathname;
  for (const prefix of ['/en', '/es', '/ar', '/pt']) {
    if (base.startsWith(prefix)) {
      base = base.slice(prefix.length) || '/';
      break;
    }
  }
  // en → en.chitek-inno.com (子域名，不需要前缀)
  if (targetLang === 'en') return 'https://en.chitek-inno.com' + base;
  // zh → chitek-inno.com
  if (targetLang === 'zh') return 'https://chitek-inno.com' + base;
  // es/ar/pt → chitek-inno.com/{lang} (主域名，需要前缀)
  const prefix = '/' + targetLang;
  return 'https://chitek-inno.com' + prefix + (base === '/' ? '' : base);
}
const activeLangLabel = langLabel[lang] || 'English';
const activeLangFlag = langFlagCode[lang] || 'gb';
const enHref = langHref('en');
const ptHref = langHref('pt');
const esHref = langHref('es');
const arHref = langHref('ar');
const zhHref = langHref('zh');
// zh/en 在各自域名下用根路径，es/ar/pt 在主域名下需要前缀
const prefix = lang === 'es' ? '/es' : lang === 'ar' ? '/ar' : lang === 'pt' ? '/pt' : '';
const productsHref = prefix + '/products';
const solutionsHref = prefix + '/solutions';
const servicesHref = prefix + '/services';
const newsHref = prefix + '/news';
const aboutHref = prefix + '/about';
const contactHref = prefix + '/contact';
const homeHref = prefix || '/';
---
<!-- NAV: 桌面导航 + 移动菜单 (共用组件) -->
<style>
  #hamburgerBtn.open > span:nth-child(1) {
    translate: 0 4px;
    rotate: 45deg;
  }
  #hamburgerBtn.open > span:nth-child(2) {
    opacity: 0;
    scale: 0;
  }
  #hamburgerBtn.open > span:nth-child(3) {
    translate: 0 -4px;
    rotate: -45deg;
  }
  .mobile-submenu.open {
    display: flex;
  }
  [dir="rtl"] .lang-item {
    border-left: none;
    border-right-width: 3px;
    border-right-color: transparent;
  }
  [dir="rtl"] .lang-item:hover,
  [dir="rtl"] .lang-item.border-l-brand-orange {
    border-right-color: #ff6b1a;
  }
  [dir="rtl"] .lang-item.border-l-brand-orange {
    border-right-color: #ff6b1a;
  }
</style>
<nav class="fixed top-0 left-0 right-0 z-[1000] h-[72px] bg-white/[0.97] backdrop-blur-md border-b border-border-light shadow-sm">
  <div class="w-full h-full flex items-center px-5 md:px-12 gap-6 lg:gap-10">
	  <a href={homeHref} class:list={["flex items-center no-underline", isRtl ? "ml-auto" : "mr-auto"]}>
    <img src="/assets/images/logo.webp" alt="CHITEK Logo" class="w-[140px] h-auto object-contain" />
  </a>

  <button class="flex lg:hidden flex-col justify-center items-center w-10 h-10 cursor-pointer bg-transparent border-none p-0 gap-1.5 shrink-0" id="hamburgerBtn" aria-label={lang === 'pt' ? 'Alternar menu' : 'Toggle menu'}>
    <span class="block w-[22px] h-0.5 bg-text-dark rounded transition-all duration-300 origin-center"></span>
    <span class="block w-[22px] h-0.5 bg-text-dark rounded transition-all duration-300 origin-center"></span>
    <span class="block w-[22px] h-0.5 bg-text-dark rounded transition-all duration-300 origin-center"></span>
  </button>

  <div class="hidden lg:flex gap-1 items-center">
    <!-- Products Dropdown -->
    <div class="group relative flex items-center">
      <a href={productsHref} class="nav-link-base relative text-[14px] font-semibold tracking-[0.08em] no-underline text-text-mid px-5 py-2 rounded-sm inline-flex items-center whitespace-nowrap hover:text-brand-orange">
        {_('products')}
        <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-brand-orange scale-x-0 origin-left transition-transform duration-200 group-hover:scale-x-100"></span>
      </a>
      <div class="absolute top-full left-0 bg-white min-w-[340px] shadow-lg border border-border-light rounded py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible -translate-y-2.5 group-hover:translate-y-0 transition-all duration-300 z-[1001] mt-2 before:content-[''] before:absolute before:top-[-6px] before:left-6 before:w-3 before:h-3 before:bg-white before:border-t before:border-l before:border-border-light before:rotate-45">
        <a href={productsHref + '#ahf'} class="block px-6 py-3 text-text-mid whitespace-nowrap no-underline text-[13px] font-medium tracking-[0.02em] transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:text-brand-orange hover:border-l-brand-orange hover:pl-7">{_('activeHarmonicFilter')}</a>
        <a href={productsHref + '#svg'} class="block px-6 py-3 text-text-mid whitespace-nowrap no-underline text-[13px] font-medium tracking-[0.02em] transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:text-brand-orange hover:border-l-brand-orange hover:pl-7">{_('staticVarGenerator')}</a>
        <a href={productsHref + '#sic'} class="block px-6 py-3 text-text-mid whitespace-nowrap no-underline text-[13px] font-medium tracking-[0.02em] transition-all duration-200 border-l-3 border-transparent hover:bg-[rgba(255,107,26,0.05)] hover:text-brand-orange hover:border-l-brand-orange hover:pl-7">{_('sicAhfSvg')}</a>
      </div>
    </div>

    <!-- Solutions Dropdown -->
    <div class="group relative flex items-center">
      <a href={solutionsHref} class="nav-link-base relative text-[14px] font-semibold tracking-[0.08em] no-underline text-text-mid px-5 py-2 rounded-sm inline-flex items-center whitespace-nowrap hover:text-brand-orange">
        {_('solutions')}
