---
import BaseLayout from '../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK — 低压AHF、SVG制造商 | 电能质量解决方案',
  description: 'CHITEK提供有源电力滤波器(AHF)、静止无功发生器(SVG)、SiC AHF/SVG，用于低压电能质量矫正。',
};
---

<BaseLayout lang="zh" title={meta.title} description={meta.description}>
  <!-- Sticky Tab Bar (visible after scrolling past hero) -->
  <div id="sticky-tab-bar" class="sticky top-[72px] z-40 transition-all duration-[400ms] bg-white border-b-2 border-border-light shadow-[0_2px_16px_rgba(0,0,0,0.08)] opacity-0 -translate-y-2 pointer-events-none h-0 overflow-hidden">
    <div class="px-[clamp(24px,8vw,160px)]">
      <div class="flex items-center justify-center gap-0 md:gap-[clamp(8px,1.5vw,20px)] overflow-x-auto">
        <button class="sticky-hero-tab text-[clamp(12px,0.9vw,15px)] font-semibold whitespace-nowrap px-5 py-3 rounded-lg transition-all duration-200 relative text-white bg-brand-orange shadow-sm" data-tab="0"><span class="font-barlow-condensed">有源电力滤波器</span></button>
        <button class="sticky-hero-tab text-[clamp(12px,0.9vw,15px)] font-semibold whitespace-nowrap px-5 py-3 rounded-lg transition-all duration-200 relative text-[#374151] hover:text-brand-orange hover:bg-orange-50" data-tab="1"><span class="font-barlow-condensed">静止无功发生器</span></button>
              </div>
    </div>
  </div>

  <!-- Hero Section -->
  <section id="hero" class="relative w-full overflow-hidden min-h-[70vh] mt-[72px] flex items-center justify-center" style="background:url('/assets/images/products-hero-bg.webp') center/cover no-repeat">
    <canvas id="hero-canvas" class="absolute inset-0 z-[1] pointer-events-none"></canvas>
