      },
      {
        title: '100MW/200MWh电网侧储能电站', highlight: 'PCS THD < 4%，并网点闪烁Pst < 0.5，并网协议合规', image: '/assets/images/solutions-renewable-case-storage.jpg', industry: '储能', colorClass: 'text-brand-navy', bgClass: 'bg-slate-100', link: '#',
        overview: '100MW/200MWh电网侧储能电站，40×2.5MW PCS单元。多PCS谐波交错导致35kV PCC点THD > 6%。充放电模式切换闪烁Pst超过0.8，并网合规测试未通过。',
        trend: '闪烁Pst趋势：0.85 → 0.65 → 0.50 → 0.35',
        solution: [{ product: 'SVG+AHF组合', qty: 8, use: 'PCS交流母线电能质量调节' }, { product: 'PQ-Gateway', qty: 1, use: '并网合规监测平台' }],
        results: ['PCS THD < 4%（符合IEEE 519标准）', '并网点闪烁Pst < 0.5', '并网协议完全合规'],
      },
    ];

    // ===================== DATA MAP =====================
    const dataMap = {
      commercial: { painPoints: painPointScenes, topology: topologyScenes, cases: cases },
      grid:       { painPoints: gridPainPoints, topology: gridTopology, cases: gridCases },
      datacenter: { painPoints: dcPainPoints, topology: dcTopology, cases: dcCases },
      industry:   { painPoints: indPainPoints, topology: indTopology, cases: indCases },
      rail:       { painPoints: railPainPoints, topology: railTopology, cases: railCases },
      renewable:  { painPoints: rePainPoints, topology: reTopology, cases: reCases },
    };

    // ===================== STATE =====================
    let sceneIndex = 0;
    let sceneTimer;

    // ===================== UTILITIES =====================
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function animatingSwap(element, callback) {
      const prevHeight = element.getBoundingClientRect().height;
      element.style.height = prevHeight + 'px';
      element.classList.add('animating');
      setTimeout(() => {
        callback();
        const newHeight = element.scrollHeight;
        element.style.height = newHeight + 'px';
        element.classList.remove('animating');
        lucide.createIcons();
        setTimeout(() => {
          element.style.height = '';
        }, 350);
      }, 300);
    }

    // ===================== INDUSTRY TABS =====================
    function renderIndustryTabs(containerId) {
      const container = document.getElementById(containerId);
      container.innerHTML = industries.map(ind => {
        const isActive = activeIndustry === ind.id;
        return `<button onclick="setIndustry('${ind.id}')" class="flex items-center gap-2.5 text-[clamp(11px,0.9vw,14px)] font-semibold whitespace-nowrap px-5 py-3 rounded-lg transition-all duration-200 relative ${
          isActive
            ? 'text-white bg-electric-orange shadow-sm'
            : 'text-[#374151] hover:text-electric-orange hover:bg-orange-50'
        }">
          <i data-lucide="${ind.icon}" class="w-4 h-4"></i>
          <span>${escapeHtml(ind.label)}</span>
        </button>`;
      }).join('');
    }

    const industryTitles = {
      commercial: '商业与医疗建筑案例研究',
      grid: '电网案例研究',
      datacenter: '数据中心案例研究',
      industry: '工业制造案例研究',
      renewable: '新能源案例研究',
      rail: '轨道交通案例研究',
    };
    const heroImages = {
      commercial: '/assets/images/solutions-commercial-medical-hero-bg.jpg',
      grid: '/assets/images/solutions-grid-hero-bg.jpg',
      datacenter: '/assets/images/solutions-datacenter-hero-bg.jpg',
      industry: '/assets/images/solutions-industrial-hero-bg.jpg',
      renewable: '/assets/images/solutions-renewable-hero-bg.jpg',
      rail: '/assets/images/solutions-rail-hero-bg.jpg',
    };

    window.setIndustry = function(id) {
      if (!dataMap[id]) return;
      activeIndustry = id;
      sceneIndex = 0;
      expandedCaseIndex = null;
      document.getElementById('hero-image').src = heroImages[id] || heroImages['commercial'];
      document.getElementById('cases-title').textContent = industryTitles[id] || '案例研究';
      renderIndustryTabs('sticky-industry-tabs');
      renderScene();
      renderCases();
      resetSceneTimer();
      lucide.createIcons();
    }

    // ===================== UNIFIED SCENE RENDER =====================
    function renderTopologySVGHorizontal(scene) {
      const branches = scene.branches;
      const svgW = 860, svgH = 200, centerY = 65;

      const gridW = 80, trafoW = 100, devW = 170;
      const gridX = 20, trafoX = 145, devX = 290;

      const arrowColor = '#a8a6a1';
      const accentColor = '#f4a261';

      const branchStartX = 510;
      const branchGap = 42;
      const branchW = 210;

      return `<svg viewBox="0 0 ${svgW} ${svgH}" class="w-full max-w-[860px] h-auto mx-auto" style="overflow:visible">
        <defs>
          <marker id="ah-t" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><polygon points="0 0,8 3,0 6" fill="${arrowColor}"/></marker>
          <marker id="ah-o-t" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><polygon points="0 0,8 3,0 6" fill="${accentColor}"/></marker>
        </defs>

        <!-- Utility Grid -->
        <rect x="${gridX}" y="${centerY - 22}" width="${gridW}" height="44" rx="8" fill="#F5F6F8" stroke="#D0D5DD" stroke-width="1.5"/>
        <text x="${gridX + gridW/2}" y="${centerY + 5}" text-anchor="middle" fill="#4B5058" font-size="14" font-weight="600">电网</text>

        <!-- Grid → Transformer -->
        <line x1="${gridX + gridW}" y1="${centerY}" x2="${trafoX}" y2="${centerY}" stroke="${arrowColor}" stroke-width="2" marker-end="url(#ah-t)"/>

        <!-- Transformer -->
        <rect x="${trafoX}" y="${centerY - 22}" width="${trafoW}" height="44" rx="8" fill="#F5F6F8" stroke="#D0D5DD" stroke-width="1.5"/>
        <text x="${trafoX + trafoW/2}" y="${centerY + 5}" text-anchor="middle" fill="#4B5058" font-size="13" font-weight="600">变压器</text>

        <!-- Transformer → Device -->
        <line x1="${trafoX + trafoW}" y1="${centerY}" x2="${devX}" y2="${centerY}" stroke="${arrowColor}" stroke-width="2" marker-end="url(#ah-t)"/>

        <!-- Device (highlighted) -->
        <rect x="${devX}" y="${centerY - 28}" width="${devW}" height="56" rx="10" fill="rgba(244,162,97,0.06)" stroke="${accentColor}" stroke-width="2"/>
        <text x="${devX + devW/2}" y="${centerY - 6}" text-anchor="middle" fill="${accentColor}" font-size="15" font-weight="700">${escapeHtml(scene.deviceLabel)}</text>
        <text x="${devX + devW/2}" y="${centerY + 14}" text-anchor="middle" fill="${accentColor}" font-size="12" font-weight="500">${escapeHtml(scene.deviceType)}</text>

        <!-- Device → Branches (horizontal distribution) -->
        ${branches.map((b, i) => {
          const by = 30 + i * branchGap;
          const bx = branchStartX;
          return `
            <line x1="${devX + devW}" y1="${centerY}" x2="${bx}" y2="${by + 20}" stroke="${accentColor}" stroke-width="1.5" marker-end="url(#ah-o-t)"/>
            <rect x="${bx}" y="${by}" width="${branchW}" height="40" rx="8" fill="#F5F6F8" stroke="#D0D5DD" stroke-width="1"/>
            <text x="${bx + 14}" y="${by + 24}" text-anchor="start" fill="#4B5058" font-size="13" font-weight="500">${escapeHtml(b.label)}</text>
            <text x="${bx + branchW - 14}" y="${by + 24}" text-anchor="end" fill="#8B919A" font-size="11">${escapeHtml(b.sub)}</text>
          `;
        }).join('')}

        <!-- LV Busbar label -->
        <text x="${devX + devW/2}" y="${svgH - 8}" text-anchor="middle" fill="#8B919A" font-size="11">低压母线</text>
      </svg>`;
    }

    function renderScene() {
      const pts = dataMap[activeIndustry].painPoints;
      const tps = dataMap[activeIndustry].topology;
      const ppScene = pts[sceneIndex];
      const tpScene = tps[sceneIndex];

      document.getElementById('sc-counter').textContent = `${sceneIndex + 1} / ${pts.length}`;

      // Dots
      document.getElementById('sc-dots').innerHTML = pts.map((_, i) =>
        `<button onclick="sceneGo(${i})" class="w-2.5 h-2.5 rounded-full transition-colors duration-300 ${i === sceneIndex ? 'bg-brand-orange' : 'bg-gray-300'}"></button>`
      ).join('');

      // Scene label
      document.getElementById('sc-scene-label').innerHTML =
        `<i data-lucide="building-2" class="w-5 h-5 text-brand-orange"></i>` +
        `<span class="text-[clamp(13px,1.1vw,17px)] font-semibold text-brand-navy">${escapeHtml(ppScene.sceneName)} — ${escapeHtml(ppScene.sceneSubtitle)}</span>`;

      // Pain Points
      document.getElementById('sc-painpoints').innerHTML = ppScene.cards.map(card => `
        <div class="bg-bg-card border border-border-card rounded-xl p-[clamp(8px,1.5vw,32px)] transition-all duration-300 ease-out hover:-translate-y-1 hover:border-electric-orange hover:shadow-[0_8px_30px_rgba(230,111,81,0.15)]">
          <div class="flex items-center gap-2.5 mb-4">
            <i data-lucide="${card.icon}" class="w-6 h-6 text-electric-orange"></i>
            <h3 class="text-[clamp(18px,1.6vw,28px)] font-bold text-brand-navy font-barlow-condensed">${escapeHtml(card.title)}</h3>
          </div>
          <p class="text-[clamp(11px,0.9vw,14px)] text-brand-gray mb-5 leading-relaxed">${escapeHtml(card.desc)}</p>
          <div class="border-t border-border-card pt-4 mb-4 flex items-baseline gap-2">
            <span class="text-[40px] font-bold text-brand-orange leading-none">${escapeHtml(card.metric)}</span>
            <span class="text-[22px] font-bold text-brand-orange">${escapeHtml(card.metricLabel)}</span>
          </div>
          <div class="border-t border-border-card pt-4 space-y-3">
            ${card.consequences.map(c => `
              <div>
                <p class="text-[clamp(11px,0.9vw,14px)] font-semibold text-brand-navy">${escapeHtml(c.title)}</p>
                <p class="text-[clamp(11px,0.9vw,14px)] text-brand-gray leading-relaxed mt-0.5">${escapeHtml(c.sub)}</p>
              </div>
            `).join('')}
          </div>
        </div>
      `).join('');

      // Topology
      document.getElementById('sc-topology').innerHTML =
        renderTopologySVGHorizontal(tpScene) +
        `<p class="text-[clamp(11px,0.9vw,14px)] text-brand-orange text-center font-semibold bg-orange-50 px-4 py-2 rounded-lg mx-auto mt-6 inline-block">${escapeHtml(tpScene.deviceDesc)}</p>
        <div class="flex items-center justify-center gap-4 mt-6">
          <button class="flex items-center gap-2 px-6 py-3 border border-border-card rounded-lg text-[clamp(11px,0.9vw,14px)] font-medium text-text-secondary hover:border-brand-orange hover:text-brand-orange transition-all duration-200">
            <i data-lucide="download" class="w-4 h-4"></i>下载PDF
          </button>
          <button class="flex items-center gap-2 px-6 py-3 bg-brand-orange text-white rounded-lg text-[clamp(11px,0.9vw,14px)] font-semibold hover:brightness-110 transition-all duration-200">
            <i data-lucide="message-circle" class="w-4 h-4"></i>技术咨询
          </button>
        </div>`;

      // Bottom indicators
      document.getElementById('sc-indicators').innerHTML = pts.map((s, i) =>
        `<button onclick="sceneGo(${i})" class="flex items-center gap-2 text-[clamp(11px,0.9vw,14px)] font-medium transition-colors duration-200 ${i === sceneIndex ? 'text-brand-orange' : 'text-text-muted hover:text-text-secondary'}">
          <span class="w-2.5 h-2.5 rounded-full ${i === sceneIndex ? 'bg-brand-orange' : 'bg-gray-300'}"></span>
          <span>${escapeHtml(s.label)}</span>
        </button>`
      ).join('');

      lucide.createIcons();
    }

    window.sceneGo = function(index) {
      if (index === sceneIndex) return;
      const els = [
        document.getElementById('sc-painpoints'),
        document.getElementById('sc-topology')
      ];
      els.forEach(el => {
        el.style.height = el.getBoundingClientRect().height + 'px';
        el.classList.add('animating');
      });
      setTimeout(() => {
        sceneIndex = index;
        renderScene();
        els.forEach(el => {
          const nh = el.scrollHeight;
          el.style.height = nh + 'px';
          el.classList.remove('animating');
        });
        lucide.createIcons();
        setTimeout(() => {
          els.forEach(el => { el.style.height = ''; });
        }, 350);
      }, 300);
      resetSceneTimer();
    }
    window.sceneNext = function() { const len = dataMap[activeIndustry].painPoints.length; window.sceneGo((sceneIndex + 1) % len); }
    window.scenePrev = function() { const len = dataMap[activeIndustry].painPoints.length; window.sceneGo((sceneIndex - 1 + len) % len); }
    function resetSceneTimer() { clearInterval(sceneTimer); sceneTimer = setInterval(window.sceneNext, 8000); }

    // ===================== CASES (ACCORDION) =====================
    let expandedCaseIndex = null;

    window.toggleCase = function(index) {
      if (expandedCaseIndex === index) {
        expandedCaseIndex = null;
      } else {
        expandedCaseIndex = index;
      }
      renderCases();
    }

    function renderCases() {
      const cs = dataMap[activeIndustry].cases;
      document.getElementById('cases-list').innerHTML = cs.map((c, i) => {
        const isExpanded = expandedCaseIndex === i;
        return `
        <div class="bg-bg-card border border-border-card rounded-xl overflow-hidden transition-all duration-300 ease-out hover:bg-[#F9FAFB] hover:border-[#D0D5DD] hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)]">
          <!-- Header (always visible) -->
          <div onclick="toggleCase(${i})" class="flex flex-col ${i === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-[clamp(12px,3vw,48px)] p-[clamp(8px,1.5vw,32px)] lg:p-[clamp(16px,3vw,40px)] cursor-pointer">
            <div class="w-full md:w-[45%] md:max-w-[400px] aspect-[4/3] rounded-lg overflow-hidden flex-shrink-0">
              <img src="${escapeHtml(c.image)}" alt="${escapeHtml(c.title)}" class="w-full h-full object-cover transition-transform duration-300 ease-out hover:scale-105" loading="lazy">
            </div>
            <div class="flex-1 flex flex-col justify-center">
              <span class="inline-flex self-start px-3 py-1 rounded text-[clamp(11px,0.9vw,14px)] font-semibold ${c.colorClass} ${c.bgClass} mb-4">${escapeHtml(c.industry)}</span>
              <h3 class="text-[clamp(18px,1.6vw,28px)] font-semibold text-text-primary mb-3 font-barlow-condensed">${escapeHtml(c.title)}</h3>
              <p class="text-[clamp(11px,0.9vw,14px)] text-text-secondary mb-4 leading-relaxed">${escapeHtml(c.highlight)}</p>
              ${c.solution && c.solution.length > 0 ? `
              <div class="mb-4 flex flex-wrap gap-x-5 gap-y-1.5 text-[clamp(11px,0.9vw,14px)] text-text-muted">
                ${c.solution.map(s => `<span class="font-medium text-text-secondary">${escapeHtml(s.product)} <span class="text-electric-orange">×</span> ${s.qty} 台</span>`).join('')}
              </div>` : ''}
              <span class="inline-flex items-center gap-1.5 text-electric-orange font-medium text-[clamp(11px,0.9vw,14px)]">
                ${isExpanded ? '收起' : '查看详情'}
                <i data-lucide="${isExpanded ? 'chevron-up' : 'chevron-down'}" class="w-4 h-4"></i>
              </span>
            </div>
          </div>

          <!-- Expanded Content -->
          <div class="transition-all duration-300" style="${isExpanded ? '' : 'height:0;overflow:hidden;'}">
            <div class="px-6 lg:px-8 pb-8 border-t border-border-card">
              <!-- Project Overview -->
              <div class="pt-6 pb-4">
                <h4 class="text-[clamp(13px,1.1vw,17px)] font-bold text-brand-navy mb-3 font-barlow-condensed">项目概述</h4>
                <p class="text-[clamp(11px,0.9vw,14px)] text-text-secondary leading-relaxed">${escapeHtml(c.overview)}</p>
              </div>

              <!-- Trend -->
              <div class="bg-bg-alt-1 rounded-xl p-[clamp(8px,1.5vw,32px)] mb-6">
                <h4 class="text-[clamp(11px,0.9vw,14px)] font-semibold text-brand-navy mb-3">改造前后</h4>
                <p class="text-[28px] font-bold text-brand-orange leading-tight mb-1">${escapeHtml(c.trend)}</p>
                <div class="flex items-center gap-3 mt-3">
                  <span class="h-2 flex-1 rounded-full bg-electric-orange/20"></span>
                  <span class="h-2 flex-1 rounded-full bg-brand-orange/30"></span>
                  <span class="h-2 flex-1 rounded-full bg-brand-orange/50"></span>
                  <span class="h-2 w-16 rounded-full bg-brand-orange"></span>
                </div>
              </div>

              <!-- Solution Deployed -->
              <div class="mb-6">
                <h4 class="text-[clamp(13px,1.1vw,17px)] font-bold text-brand-navy mb-3 font-barlow-condensed">实施方案</h4>
                <div class="space-y-3">
                  ${c.solution.map(s => `
                    <div class="flex items-center gap-4 bg-bg-alt-1 rounded-lg px-5 py-3">
                      <span class="text-[clamp(11px,0.9vw,14px)] font-bold text-electric-orange w-[90px]">${escapeHtml(s.product)}</span>
                      <span class="text-[clamp(11px,0.9vw,14px)] text-text-secondary">× ${s.qty} 台</span>
                      <span class="text-xs text-text-muted">${escapeHtml(s.use)}</span>
                    </div>
                  `).join('')}
                </div>
              </div>

              <!-- Key Results -->
              <div class="mb-6">
                <h4 class="text-[clamp(13px,1.1vw,17px)] font-bold text-brand-navy mb-3 font-barlow-condensed">核心成果</h4>
                <div class="space-y-2">
                  ${c.results.map(r => `
                    <div class="flex items-start gap-2.5">
                      <i data-lucide="check-circle" class="w-5 h-5 text-commercial-green flex-shrink-0 mt-0.5"></i>
                      <span class="text-[clamp(11px,0.9vw,14px)] text-text-secondary">${escapeHtml(r)}</span>
                    </div>
                  `).join('')}
                </div>
              </div>

            </div>
          </div>
        </div>`;
      }).join('');
      lucide.createIcons();
    }

    // ===================== SCROLL EFFECTS =====================
    function handleScroll() {
      // Sticky tabs: hidden on hero, revealed after scrolling past
      const stickyTabs = document.getElementById('sticky-tabs');
      if (stickyTabs) {
        const heroBottom = window.innerHeight * 0.55;
        if (window.scrollY > heroBottom) {
          stickyTabs.style.opacity = '1';
          stickyTabs.style.transform = 'translateY(0)';
          stickyTabs.style.pointerEvents = 'auto';
          stickyTabs.style.height = 'auto';
          stickyTabs.style.overflow = 'visible';
        } else {
          stickyTabs.style.opacity = '0';
          stickyTabs.style.transform = 'translateY(-8px)';
          stickyTabs.style.pointerEvents = 'none';
          stickyTabs.style.height = '0';
          stickyTabs.style.overflow = 'hidden';
        }
      }

      // Scroll reveal
      document.querySelectorAll('.scroll-reveal').forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.85) {
          el.classList.add('revealed');
        }
      });
    }

    // ===================== HASH-BASED NAVIGATION =====================
    const industryHashMap = {
      'industry': 'industry',
      'commercial': 'commercial',
      'datacenter': 'datacenter',
      'renewable': 'renewable',
      'rail': 'rail',
      'grid': 'grid',
    };

    function navigateToIndustryFromHash() {
      const hash = window.location.hash.replace('#', '');
      if (hash && industryHashMap[hash]) {
        window.setIndustry(hash);
        setTimeout(() => {
          document.getElementById('solutions')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    }

    window.addEventListener('hashchange', navigateToIndustryFromHash);

    // ===================== INIT =====================
    document.addEventListener('DOMContentLoaded', function() {
      renderIndustryTabs('sticky-industry-tabs');
      renderScene();
      renderCases();
      lucide.createIcons();

      // Check initial hash
      navigateToIndustryFromHash();

      // Start timer
      sceneTimer = setInterval(window.sceneNext, 8000);

      // Scroll listener
      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll(); // Initial check
    });
</script>
