    /* Product Series 中间功能网格：6 张卡片自上而下错峰浮现，进出视口可反复触发 */
    .ps-card { opacity: 0; transform: translateY(36px); transition: opacity .55s ease, transform .55s ease, background-color 200ms ease, color 200ms ease; }
