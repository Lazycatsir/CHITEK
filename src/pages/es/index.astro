    .insight-title { transition-delay: 80ms; }
    .insight-card { opacity: 0; transform: translateY(64px); }
    .insight-card.visible { opacity: 1; transform: translateY(0); }

    @media (prefers-reduced-motion: reduce) {
      .conv-left, .conv-right,
      .insight-title, .insight-card,
      .ps-card { transform: none !important; transition: none !important; opacity: 1 !important; }
    }
  </style>

