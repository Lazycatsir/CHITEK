---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Soluciones de Calidad de Energía – Aplicaciones Industriales y de Utilidad | CHITEK',
  description: 'CHITEK ofrece soluciones de calidad de energía para aplicaciones de Fabricación Industrial, Edificios Comerciales, Centros de Datos, Energía Renovable, Transporte y Red Eléctrica en todo el mundo.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="es">
  <!-- ============ HERO ============ -->
  <section class="relative min-h-[70vh] flex flex-col justify-end overflow-hidden mt-[72px]">
    <div class="absolute inset-0 animate-fade-in">
      <img id="hero-image" src="/assets/images/solutions-commercial-medical-hero-bg.jpg" alt="" class="object-cover w-full h-full" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    </div>
    <div class="relative z-10 w-full px-[clamp(24px,8vw,160px)] pb-8">
      <div class="mb-12">
        <h1 class="text-[clamp(28px,3.5vw,64px)] font-bold leading-tight text-brand-orange drop-shadow-[0_2px_20px_rgba(0,0,0,0.5)] font-barlow-condensed animate-slide-up-300">Comercial y Médico</h1>
        <h2 class="text-[clamp(28px,3.5vw,64px)] font-bold leading-tight text-brand-orange drop-shadow-[0_2px_20px_rgba(0,0,0,0.5)] font-barlow-condensed animate-slide-up-450">Soluciones de Calidad de Energía</h2>
        <p class="mt-6 text-[clamp(14px,1.2vw,20px)] text-white/80 max-w-xl leading-relaxed animate-slide-up-[clamp(12px,2vw,32px)]00">Desde quirófanos de precisión hasta oficinas de categoría A — garantía de calidad de energía en todo escenario</p>
      </div>
    </div>
  </section>

  <!-- ============ STICKY INDUSTRY TABS ============ -->
  <div id="sticky-tabs" class="sticky top-[72px] z-40 transition-all duration-[400ms] bg-white border-b-2 border-border-subtle shadow-[0_2px_16px_rgba(38,70,83,0.08)] opacity-0 -translate-y-2 pointer-events-none h-0 overflow-hidden">
    <div class="px-[clamp(24px,8vw,160px)]">
      <div class="flex items-center justify-center gap-0 md:gap-4 flex-wrap" id="sticky-industry-tabs"></div>
    </div>
  </div>

  <!-- ============ SOLUTIONS CAROUSEL ============ -->
  <section id="solutions" class="scroll-reveal opacity-0 translate-y-10 transition-all duration-700 ease-out px-[clamp(24px,8vw,160px)] py-12 lg:py-16 relative overflow-hidden bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/images/solutions-scenario.webp')">
    <div>
      <div class="mb-6">
        <div>
          <h2 class="text-[clamp(24px,3vw,52px)] font-bold text-brand-navy leading-tight font-barlow-condensed">Solución de Calidad de Energía Basada en Escenarios</h2>
        </div>
        <div class="flex items-center justify-center gap-4 mt-4">
          <span class="text-[clamp(11px,0.9vw,14px)] text-text-secondary font-medium" id="sc-counter">1 / 3</span>
          <div class="flex gap-2" id="sc-dots"></div>
        </div>
      </div>
      <div class="mb-[clamp(20px,3vw,48px)]">
        <div class="flex items-center gap-2" id="sc-scene-label"></div>
      </div>
      <div class="mb-12">
        <h3 class="text-[clamp(18px,1.6vw,28px)] font-bold text-brand-navy mb-6 pb-3 border-b-2 border-border-subtle">Puntos Críticos</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-[clamp(12px,3vw,48px)] transition-[opacity,transform,height] duration-300 ease-out carousel-content" id="sc-painpoints"></div>
      </div>
      <div class="mb-12">
        <h3 class="text-[clamp(18px,1.6vw,28px)] font-bold text-brand-navy mb-6 pb-3 border-b-2 border-border-subtle">Topología del Sistema</h3>
        <div class="bg-bg-card border border-border-card rounded-xl p-[clamp(8px,1.5vw,32px)] lg:p-10 transition-[opacity,transform,height] duration-300 ease-out carousel-content" id="sc-topology"></div>
      </div>
      <div class="flex items-center justify-center gap-[clamp(12px,3vw,48px)] mt-12" id="sc-indicators"></div>
    </div>
  </section>

  <!-- ============ CASES ============ -->
  <section id="cases" class="scroll-reveal opacity-0 translate-y-10 transition-all duration-700 ease-out bg-[linear-gradient(135deg,#fff5f0,#fef0e5,#fde4d0)] px-[clamp(24px,8vw,160px)] pt-10 lg:pt-16 pb-8 lg:pb-12">
    <div>
      <h2 class="text-[clamp(24px,3vw,52px)] font-bold text-text-primary leading-tight font-barlow-condensed" id="cases-title">Comercial y Médico Building Casos de Estudio</h2>
      <div class="mt-3 mb-[clamp(16px,2.5vw,40px)] w-36 h-[3px] rounded-full bg-gradient-to-r from-brand-orange/60 via-brand-orange to-brand-orange/60 shadow-[0_0_8px_rgba(255,107,26,0.3)]"></div>
      <div class="max-w-[75%] mx-auto space-y-6 [&>:last-child]:mb-0" id="cases-list"></div>
    </div>
  </section>

</BaseLayout>

<style>
  .scroll-reveal {
    opacity: 0;
    translate: 0 10px;
  }
  .scroll-reveal.revealed {
    opacity: 1;
    translate: 0 0;
  }
</style>

<!-- Lucide icons library -->
<script is:inline src="/assets/js/lucide.min.js">
</script>

