            <i data-lucide="message-circle" class="w-4 h-4"></i>Consulta Técnica
          </button>
        </div>`;

      // Bottom indicators
      document.getElementById('sc-indicators').innerHTML = pts.map((s, i) =>
        `<button onclick="sceneGo(${i})" class="flex items-center gap-2 text-[clamp(11px,0.9vw,14px)] font-medium transition-colors duration-200 ${i === sceneIndex ? 'text-brand-orange' : 'text-text-muted hover:text-text-secondary'}">
          <span class="w-2.5 h-2.5 rounded-full ${i === sceneIndex ? 'bg-brand-orange' : 'bg-gray-300'}"></span>
          <span>${escapeHtml(s.label)}</span>
        </button>`
      ).join('');

      lucide.createIcons();
    }

    window.sceneGo = function(index) {
      if (index === sceneIndex) return;
      const els = [
        document.getElementById('sc-painpoints'),
        document.getElementById('sc-topology')
      ];
      els.forEach(el => {
        el.style.height = el.getBoundingClientRect().height + 'px';
        el.classList.add('animating');
      });
      setTimeout(() => {
        sceneIndex = index;
        renderScene();
        els.forEach(el => {
          const nh = el.scrollHeight;
          el.style.height = nh + 'px';
          el.classList.remove('animating');
        });
        lucide.createIcons();
        setTimeout(() => {
          els.forEach(el => { el.style.height = ''; });
        }, 350);
      }, 300);
      resetSceneTimer();
    }
    window.sceneNext = function() { const len = dataMap[activeIndustria].painPoints.length; window.sceneGo((sceneIndex + 1) % len); }
    window.scenePrev = function() { const len = dataMap[activeIndustria].painPoints.length; window.sceneGo((sceneIndex - 1 + len) % len); }
    function resetSceneTimer() { clearInterval(sceneTimer); sceneTimer = setInterval(window.sceneNext, 8000); }

    // ===================== CASES (ACCORDION) =====================
