---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
---
<BaseLayout title="Noticias y Perspectivas | CHITEK INNOPOWER" description="Manténgase actualizado con las últimas noticias, artículos técnicos y perspectivas de la industria de CHITEK INNOPOWER en soluciones de calidad de energía." lang="es">
  <Sidebar lang="es" />

  <!-- Hero Section -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-20 md:py-28">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight mb-6">
        Noticias y <span class="text-brand-orange">Perspectivas</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
        Manténgase informado sobre los últimos desarrollos en tecnología de calidad de energía, tendencias de la industria y soluciones CHITEK.
      </p>
    </div>
  </section>

