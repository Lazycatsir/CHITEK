                </a>
              ))}
            </div>
          </div>
          <!-- Related Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              Casos de Clientes
            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href="/es/news/solar-farm-dubai" class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
                  <div class="text-xs text-text-muted mt-1">{caseItem.industry}</div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
