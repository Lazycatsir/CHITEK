  category: "Tecnología",
  date: "2026-07-09",
  dateDisplay: "Jul 9, 2026",
  author: "Equipo Técnico de CHITEK",
  readTime: "8 min de lectura",
  description: "Explore las ventajas competitivas de los Filtros Activos de Armónicos de CHITEK: 9 patentes, certificaciones internacionales, matriz de 8 modelos, colaboración académica y presencia global en más de 10 países.",
  keywords: ["filtro activo de armónicos", "AHF", "calidad de energía", "mitigación de armónicos", "compensación de potencia reactiva", "IGBT", "carburo de silicio", "CHITEK"]
};

const otherArticles = [
  { title: "Filtros Activos de Armónicos para Sistemas VFD: Por Qué Son Críticos", category: "Tecnología", href: "/es/news/blog-active-harmonic-filter-for-vfd-systems", color: "blue" },
  { title: "AHF vs Reacciones de Línea: Comparación Técnica", category: "Tecnología", href: "/es/news/blog-ahf-vs-line-reactors", color: "purple" },
  { title: "Por Qué SVG Es el Guardián Invisible de la Infraestructura Moderna", category: "Tecnología", href: "/es/news/blog-svg-power-electronics-daily-life", color: "green" },
];

const relatedProducts = [
  { name: "Filtro Activo de Armónicos AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Generador Estático de Reactivos SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Serie Eficiente SiC-AHF/SVG", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Planta Industrial en Arabia Saudita", industry: "Manufactura" },
  { name: "Centro de Datos en Brasil", industry: "Centros de Datos" },
