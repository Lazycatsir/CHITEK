import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Relato de un Profesional de la Industria de Filtros Activos de Armónicos en 2026",
  category: "Noticias del Sector",
  date: "2026-04-28",
  dateDisplay: "Apr 28, 2026",
  author: "Equipo Editorial de CHITEK",
  readTime: "9 min de lectura",
  description: "A partir de casi una década de práctica en I+D y entrega de AHF en Shenzhen Qidian New Energy, una revisión sistemática de la cartera de productos, patentes, pruebas de cumplimiento y perspectiva de la industria para 2026.",
  keywords: ["active harmonic filter", "APF", "power quality", "harmonic mitigation", "SVG", "silicon carbide", "SiC AHF", "industry insight", "Shenzhen Qidian New Energy", "CHITEK"]
};

const otherArticles = [
  { title: "Actualización de los Estándares de Calidad de Energía de Arabia Saudita", category: "Noticias del Sector", href: "/es/news/saudi-arabia-standards", color: "blue" },
  { title: "Optimización de la Calidad de Energia en Granja Solar en Dubai", category: "Estudio de Caso", href: "/es/news/solar-farm-dubai", color: "green" },
  { title: "SiC vs IGBT: El Futuro de los Equipos de Calidad de Energía", category: "Tecnología", href: "/es/news/sic-vs-igbt", color: "purple" },
];

const relatedProducts = [
  { name: "Filtro Activo de Armónicos AHF", href: "/es/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Generador Estático de Var SVG", href: "/es/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG Alta Eficiencia", href: "/es/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Granja Solar Dubai 50MW", industry: "Energía Renovable" },
  { name: "Planta Industrial Saudita", industry: "Manufactura" },
  { name: "Centro de Datos Brasil", industry: "Centros de Datos" },
];
