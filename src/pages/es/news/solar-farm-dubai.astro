---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Optimización de la Calidad de Energia en Granja Solar en Dubai",
  category: "Estudio de Caso",
  date: "2024-11-10",
  author: "Equipo de Proyectos de CHITEK",
  readTime: "6 min de lectura"
,  keywords: ["solar farm","Dubai","power quality","active harmonic filter","SVG","renewable energy","harmonic mitigation","solar power","case study","CHITEK"]
};
---
<BaseLayout title={`${article.title} | CHITEK INNOPOWER`} description="Cómo las soluciones SVG de CHITEK mejoraron el factor de potencia de 0.85 a 0.99 para una instalación solar de 50MW en Dubai." lang="es">
  <Sidebar lang="es" />

  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-green-500/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-5 md:px-12 py-16 md:py-24">
      <a href="/es/news" class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Volver a Noticias
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-green-600 bg-green-500/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.date}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight mb-6">
        {article.title}
      </h1>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-green-500/20 rounded-full flex items-center justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-green-400">
            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <span class="text-sm text-gray-300">{article.author}</span>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <article class="max-w-4xl mx-auto px-5 md:px-12">
              <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-2.webp" alt="Optimización de la Calidad de Energia en Granja Solar en Dubai" class="w-full h-full object-cover" loading="eager" />
        </div>

      <div class="prose prose-lg max-w-none">
        <p class="text-text-mid text-lg leading-relaxed mb-6">
          Una instalación solar de 50MW en Dubai enfrentó importantes desafíos de calidad de energía, incluyendo un factor de potencia deficiente y distorsión armónica proveniente de los inversores. La solución SVG de CHITEK ofreció resultados transformadores.
        </p>

        <div class="bg-green-50 rounded-xl p-6 mb-8">
          <h3 class="font-bold text-text-dark text-lg mb-4">Aspectos Destacados del Proyecto</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600">50MW</div>
              <div class="text-sm text-text-mid">Capacidad</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600">0.85→0.99</div>
              <div class="text-sm text-text-mid">Factor de Potencia</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600">15%</div>
              <div class="text-sm text-text-mid">Reducción de Pérdidas</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600">$180K</div>
              <div class="text-sm text-text-mid">Ahorro Anual</div>
            </div>
          </div>
        </div>

        <h2 class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
          El Desafío
        </h2>
        <p class="text-text-mid leading-relaxed mb-6">
          Los sistemas fotovoltaicos solares generan corrientes armónicas significativas a través de sus inversores. En la instalación de Dubai, el efecto combinado de múltiples inversores creó:
        </p>
        <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
          <li>Factor de potencia tan bajo como 0.85 durante la generación máxima</li>
          <li>Niveles de THD superiores al 8% en el punto de acoplamiento común</li>
          <li>Fluctuaciones de voltaje que afectan equipos sensibles de la red</li>
          <li>Posibles penalizaciones por parte de la empresa eléctrica</li>
        </ul>

        <h2 class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
          La Solución
        </h2>
        <p class="text-text-mid leading-relaxed mb-6">
          CHITEK implementó una solución integral de calidad de energía que consiste en:
        </p>
        <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
          <li>4 × Generadores Estáticos de Var CHITEK SVG-300 para compensación de potencia reactiva</li>
          <li>2 × Filtros Activos de Armónicos CHITEK AHF-200 para mitigación de armónicos</li>
          <li>Sistema de monitoreo integrado para seguimiento de calidad de energía en tiempo real</li>
        </ul>

        <h2 class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
          Resultados
        </h2>
        <p class="text-text-mid leading-relaxed mb-6">
          A las pocas semanas de la instalación, la instalación logró:
        </p>
        <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
          <li>Factor de potencia mejorado de 0.85 a 0.99</li>
          <li>THD reducido del 8% a menos del 3%</li>
          <li>Eliminación de cargos por penalización de la empresa eléctrica</li>
          <li>Ahorro anual de energía de aproximadamente $180,000</li>
        </ul>
      </div>

              <!-- SEO Keywords -->
          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>

<div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
        <div class="flex items-center gap-4 mb-4 md:mb-0">
          <span class="text-sm text-text-muted">Compartir este artículo:</span>
          <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
        <a href="/es/news" class="inline-flex items-center text-brand-orange text-sm font-semibold hover:underline">
          Ver Todos los Artículos
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 ml-1">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </article>
  </section>
</BaseLayout>
