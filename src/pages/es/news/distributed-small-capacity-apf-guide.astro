---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Guía Completa de APF Distribuido de Pequeña Capacidad: Selección Técnica y Adaptación de Escenarios",
  category: "Tecnología",
  date: "2026-05-16",
  dateDisplay: "May 16, 2026",
  author: "Equipo Técnico de CHITEK",
  readTime: "8 min de lectura",
  description: "Una guía completa sobre soluciones de mitigación de armónicos con APF distribuido de pequeña capacidad para edificios comerciales, centros de datos y proyectos de modernización — que abarca principios técnicos, adaptación de escenarios, parámetros de selección, patentes y certificaciones de cumplimiento.",
  keywords: ["APF", "Filtro Activo de Potencia", "Distribuido", "Pequeña Capacidad", "Mitigación de Armónicos", "Filtro Activo", "IGBT", "Carburo de Silicio", "SiC", "CHITEK"]
};

const otherArticles = [
  { title: "Encuesta del Sector de Filtros Activos 2026", category: "Tendencias del Sector", href: "/es/news/apf-industry-practitioner-2026", color: "orange" },
  { title: "Tecnología y Ventajas del Filtro Activo de Potencia", category: "Tecnología", href: "/es/news/blog-chitek-ahf-advantages", color: "orange" },
  { title: "SiC vs IGBT: El Futuro de los Equipos de Calidad Eléctrica", category: "Tecnología", href: "/es/news/sic-vs-igbt", color: "purple" },
];

const relatedProducts = [
  { name: "Filtro Activo de Armónicos AHF", href: "/es/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Generador Estático de Vars SVG", href: "/es/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Serie Eficiente SiC-AHF/SVG", href: "/es/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Planta Solar 50MW Dubái", industry: "Energía Renovable" },
  { name: "Planta Industrial Saudí", industry: "Manufactura" },
  { name: "Centro de Datos Brasil", industry: "Centro de Datos" },
