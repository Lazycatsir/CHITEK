---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Recubrimiento Conformal en Módulos AHF de Baja Tensión: Cómo la Protección Alarga la Vida del Convertidor",
  category: "Technology",
  date: "2025-10-25",
  dateDisplay: "Oct 25, 2025",
  author: "CHITEK Technical Team",
  readTime: "5 min de lectura",
  description: "Cómo la protección por recubrimiento conformal (contra humedad, polvo y corrosión) alarga la vida de los módulos AHF de baja tensión en entornos hostiles, incluyendo tipos de recubrimiento, compromisos de materiales y el presupuesto térmico de IGBT frente a SiC.",
  keywords: ["filtro armónico activo", "AHF", "recubrimiento conformal", "protección triple", "fiabilidad", "IGBT", "SiC", "calidad de potencia", "AHF industrial", "CHITEK"]
};

const otherArticles = [
  { title: "Corrección Activa del Factor de Potencia y Compensación Dinámica", category: "Technology", href: "/es/news/active-pfc-dynamic-reactive-compensation", color: "orange" },
  { title: "Filtros Armónicos Activos vs Pasivos", category: "Technology", href: "/es/news/active-vs-passive-harmonic-filters", color: "purple" },
  { title: "Guía Enciclopédica de APF Distribuido de Baja Capacidad", category: "Technology", href: "/es/news/distributed-small-capacity-apf-guide", color: "orange" },
];

const relatedProducts = [
  { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" },
  { name: "Saudi Industrial Plant", industry: "Manufacturing" },
  { name: "Brazil Data Center", industry: "Data Centers" },
