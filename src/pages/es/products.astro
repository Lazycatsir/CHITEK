    // ===== Four Product Series Carousel (Mobile) =====
    (function() {
      var tracks = document.querySelectorAll('[data-product-track]');
      tracks.forEach(function(track) {
        var panel = track.closest('.tab-panel');
        var dotsContainer = panel && panel.querySelector('[data-product-dots]');
        if (!dotsContainer) return;
        var dotItems = dotsContainer.querySelectorAll('.carousel-dot');
        if (!dotItems.length) return;
        var cards = track.children;
        if (!cards.length) return;
        var current = 0;

        function goTo(idx) {
          if (idx < 0) idx = cards.length - 1;
          if (idx >= cards.length) idx = 0;
          current = idx;
          var offset = cards[current].getBoundingClientRect().left - track.getBoundingClientRect().left;
          track.style.transform = 'translateX(-' + offset + 'px)';
          dotItems.forEach(function(d, i) {
            if (i === current) {
              d.style.background = '#ff4d00';
              d.style.width = '24px';
              d.style.borderRadius = '4px';
            } else {
              d.style.background = '#d1d5db';
              d.style.width = '8px';
              d.style.borderRadius = '50%';
            }
          });
        }

        dotItems.forEach(function(d) {
          d.addEventListener('click', function() { goTo(parseInt(d.getAttribute('data-slide'))); });
        });

        setInterval(function() {
          if (window.innerWidth < 640) goTo(current + 1);
        }, 5000);

        var container = track.parentElement;
        var startX = 0;
        container.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
        container.addEventListener('touchend', function(e) {
          var diff = startX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
        }, { passive: true });

        window.addEventListener('resize', function() {
          track.style.transform = '';
          goTo(current);
        });

        goTo(0);
      });
    })();

    // ===== 产品系列四张卡片弹出加载（可反复触发） =====
    var seriesSection = document.getElementById('product-series');
    if (seriesSection) {
      // 给两套面板（AHF / SVG）的卡片统一打标
      seriesSection.querySelectorAll('[data-product-track] > div').forEach(function (c) {
        c.classList.add('ps-card');
      });

      function activeSeriesPanel() {
        var t = document.querySelector('.sticky-hero-tab.bg-brand-orange');
        var tab = t ? t.dataset.tab : '0';
        return seriesSection.querySelector('.tab-panel[data-tab="' + tab + '"]');
      }

      function popSeriesCards(panel) {
        if (!panel) return;
        panel.querySelectorAll('[data-product-track] > div').forEach(function (card, i) {
          card.classList.remove('popped');
          void card.offsetWidth; // 强制回流以重启 CSS 动画
          card.style.animationDelay = (i * 90) + 'ms';
          card.classList.add('popped');
        });
      }

      // 进入视口即弹出；离开后再次进入可重复触发（沿用 HMI 的 add/remove 思路）
      var seriesObserver = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            popSeriesCards(activeSeriesPanel());
          } else {
            var p = activeSeriesPanel();
            if (p) p.querySelectorAll('[data-product-track] > div').forEach(function (c) {
              c.classList.remove('popped');
            });
          }
        });
      }, { threshold: 0.2 });
      seriesObserver.observe(seriesSection);

      // 切换 AHF / SVG Tab 时重弹当前面板
      document.querySelectorAll('.sticky-hero-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var tab = btn.dataset.tab;
          if (tab === '0' || tab === '1') {
            requestAnimationFrame(function () { popSeriesCards(activeSeriesPanel()); });
          }
        });
      });
    }
</script>
