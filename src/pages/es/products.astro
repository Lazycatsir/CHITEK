    // ===== Case Carousel =====
    let caseIndex = 0;
    const caseTrack = document.getElementById('case-track');
    const caseSlides = document.querySelectorAll('#case-carousel .case-slide');
    const totalSlides = caseSlides.length;
    const dots = document.querySelectorAll('#case-dots .carousel-dot');

    function goToCase(idx) {
      caseIndex = idx;
      if (caseIndex < 0) caseIndex = totalSlides - 1;
      if (caseIndex >= totalSlides) caseIndex = 0;
      const slideWidth = caseSlides[0].offsetWidth;
      caseTrack.style.transform = 'translateX(-' + (caseIndex * slideWidth) + 'px)';
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === caseIndex);
        if (i === caseIndex) {
          d.style.background = '#ff4d00';
          d.style.width = '24px';
          d.style.borderRadius = '4px';
        } else {
          d.style.background = '#d1d5db';
          d.style.width = '8px';
          d.style.borderRadius = '50%';
        }
      });
    }

    document.getElementById('case-prev').addEventListener('click', () => goToCase(caseIndex - 1));
    document.getElementById('case-next').addEventListener('click', () => goToCase(caseIndex + 1));
    dots.forEach(d => {
      d.addEventListener('click', () => goToCase(parseInt(d.dataset.slide)));
    });

    // Auto-play
    setInterval(() => goToCase(caseIndex + 1), 6000);

    // Touch swipe
    let touchStartX = 0;
    const carousel = document.getElementById('case-carousel');
    carousel.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goToCase(diff > 0 ? caseIndex + 1 : caseIndex - 1);
    }, { passive: true });

    window.addEventListener('resize', () => goToCase(caseIndex));

