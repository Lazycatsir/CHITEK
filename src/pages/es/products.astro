---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK — Fabricante de AHF y SVG de Baja Tensión | Soluciones de Calidad de Energía',
  description: 'CHITEK ofrece Filtro Activo de Armónicos (AHF), Generador Estático de Var (SVG), AHF/SVG SiC para corrección de la calidad de energía en baja tensión.',
};
