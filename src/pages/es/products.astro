    // ===== FAQ Tab-Switch Navigation =====
    function initFaq(containerId, prefix) {
      const container = document.getElementById(containerId);
      if (!container) return;
      const navItems = container.querySelectorAll('.faq-nav-item');
      const faqFlex = container.closest('.faq-flex');
      if (!faqFlex) return;
      const panels = faqFlex.querySelectorAll('.faq-panel');

      navItems.forEach(item => {
        item.addEventListener('click', () => {
          const targetId = item.dataset.target;

          navItems.forEach(nav => {
            nav.classList.remove('active', 'bg-[#fff5f0]', 'border-l-brand-orange', 'text-brand-orange', 'font-semibold');
          });
          item.classList.add('active', 'bg-[#fff5f0]', 'border-l-brand-orange', 'text-brand-orange', 'font-semibold');

          panels.forEach(panel => {
            panel.classList.remove('active');
            panel.classList.add('hidden');
          });
          const panel = faqFlex.querySelector('#' + prefix + targetId);
          if (panel) {
            panel.classList.add('active');
            panel.classList.remove('hidden');
          }

          if (window.innerWidth <= 900) {
            const contentArea = faqFlex.querySelector('.flex-1.p-[clamp(16px,3vw,48px)]');
            if (contentArea) contentArea.scrollIntoView({ behavior: 'smooth' });
          }

          const currentQ = faqFlex.querySelector('.faq-current-question');
          if (currentQ) {
            currentQ.textContent = item.textContent;
          }
        });
      });
    }

