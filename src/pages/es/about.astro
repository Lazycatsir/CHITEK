---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Sobre CHITEK – Perfil de la Empresa y Certificaciones de Calidad de Energía',
  description: 'CHITEK es una empresa de alta tecnología fundada en 2019, especializada en I+D, fabricación y servicio de electrónica de potencia. Certificada ISO 9001 con más de 20 patentes.',
};
---

<BaseLayout lang="es" title={meta.title} description={meta.description}>
  <!-- ABOUT -->
  <section class="about relative overflow-hidden bg-bg-mid text-white mt-[72px] min-h-[calc(100vh-72px)] flex flex-col justify-center py-10 scroll-mt-[72px]" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>

    <!-- 顶部标题区域 -->
    <div class="relative z-10 text-center px-5 pt-6 pb-4 max-w-[900px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h1 class="font-barlow-condensed text-[clamp(36px,5vw,72px)] font-bold uppercase tracking-[0.02em] mb-[clamp(8px,2vw,32px)] text-white leading-[1.1]">PRESENTACIÓN DE LA EMPRESA</h1>
    </div>

    <!-- 主体大框 (包含左右内容) -->
    <div class="relative z-10 flex flex-col md:flex-row w-[clamp(320px,90vw,1800px)] mx-auto max-md:mx-3 mb-[clamp(8px,1.5vw,32px)] bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <!-- 左侧 About CHITEK 区域 -->
      <div class="flex-1 px-[clamp(12px,2vw,56px)] py-[clamp(16px,3vw,72px)] flex flex-col justify-center border-b md:border-b-0 md:border-r border-white/10">
        <h2 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-[clamp(12px,2vw,32px)] uppercase tracking-[0.02em] text-white">SOBRE <span class="text-brand-orange">CHITEK</span></h2>
        <div class="w-10 h-[3px] bg-brand-orange mb-[clamp(12px,2vw,32px)]"></div>
        <p class="text-[clamp(13px,0.9vw,16px)] leading-[1.8] text-white/75 mb-[clamp(16px,2.5vw,40px)]">
          Shenzhen CHITEK New Energy Technology Co., Ltd., fundada en 2019 y
          con sede en Shenzhen, es una empresa de alta tecnología especializada en
          la investigación, desarrollo, fabricación y servicio de productos de
          electrónica de potencia. Comprometida con construir un futuro eficiente
          en energía y ecológico.
        </p>
        <a href="#" class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          Ver Video
        </a>
      </div>

      <!-- 右侧四大优势区域 -->
      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <!-- 优势 1 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Equipo de I&amp;D Experimentado</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Capacidad Sólida Respaldada por un Equipo Altamente Calificado y Experimentado</p>
        </div>

        <!-- 优势 2 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Diseño Exclusivo</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Más de 20 Patentes que Cubren el Desarrollo y Fabricación de Productos</p>
        </div>

        <!-- 优势 3 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Productos Diversificados</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Gama Completa de Productos para Diferentes Aplicaciones de Clientes</p>
        </div>

        <!-- 优势 4 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Calidad Garantizada</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Fabricación Certificada ISO que Garanta los Más Altos Estándares de Calidad</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRY CASES -->
  <section class="relative w-full overflow-hidden bg-white" id="industry">
    <div class="relative z-10 w-full pt-12 max-md:pt-8">
      <div class="text-center mb-8 max-md:mb-5 fade-up">
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,52px)] font-bold text-text-dark uppercase tracking-wide">CASOS DE LA INDUSTRIA</h2>
        <div class="w-[60px] h-[3px] bg-brand-orange mx-auto mt-3"></div>
      </div>

      <div class="grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 fade-up">
        <a href="/solutions#industry" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-manufacturing.webp" alt="Fabricación Industrial" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">Fabricación Industrial</span>
          </div>
        </a>
        <a href="/solutions#commercial" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-commercial-medical.webp" alt="Edificios Comerciales y Médicos" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">Edificios Comerciales y Médicos</span>
          </div>
        </a>
        <a href="/solutions#datacenter" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-datacenter.webp" alt="Centros de Datos y Telecomunicaciones" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">Centros de Datos y Telecomunicaciones</span>
          </div>
        </a>
        <a href="/solutions#renewable" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-renewable.webp" alt="Energía Renovable" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">Energía Renovable</span>
          </div>
        </a>
        <a href="/solutions#rail" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-transportation.webp" alt="Transporte" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">Transporte</span>
          </div>
        </a>
        <a href="/solutions#grid" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-power-grid.webp" alt="Red Eléctrica y Servicios Públicos" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">Red Eléctrica y Servicios Públicos</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CORE ADVANTAGES -->
  <section class="core-advantages relative w-full min-h-[calc(100vh-72px)] flex items-center justify-center py-16 px-[clamp(24px,8vw,160px)] overflow-hidden" id="core-advantages">
    <div class="absolute inset-0 bg-[url('/assets/images/about-key-features.webp')] bg-cover bg-center z-0"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(10,20,40,0.65)] to-[rgba(10,20,40,0.82)] z-[1]"></div>

    <div class="relative z-10 w-full text-center">
      <div class="fade-up">
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,52px)] font-bold text-white uppercase tracking-wide mb-3">VENTAJAS PRINCIPALES</h2>
        <div class="w-[60px] h-[3px] bg-brand-orange mx-auto mb-[50px]"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[clamp(12px,3vw,48px)] w-full fade-up">
        <!-- Advantage 1: Expert R&D Team -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="text-[42px] font-bold leading-none text-brand-orange mb-4 text-left">60<sup class="text-[clamp(13px,1.1vw,17px)] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Equipo de I&amp;D Especializado</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Los miembros del equipo provienen de empresas líderes mundiales, con más del 60% con títulos de maestría o superiores, garantizando una profunda experiencia técnica en innovación en electrónica de potencia.</p>
        </div>

        <!-- Advantage 2: Core Patent Technologies -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Tecnologías de Patente Principales</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Derechos de propiedad intelectual independientes que cubren I&amp;D, diseño y fabricación, con más de 20 patentes protegiendo nuestras innovaciones.</p>
        </div>

        <!-- Advantage 3: Product Quality Control -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
              <polyline points="26,28 28,30 32,26" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Control de Calidad del Producto</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Todos los productos certificados según las normas internacionales CQC, CE e ISO 9001, garantizando un rendimiento fiable y cumplimiento en los mercados globales.</p>
        </div>

        <!-- Advantage 4: Full-Process Service -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <circle cx="32" cy="20" r="8" />
              <polygon points="16,52 24,32 40,32 48,52" stroke-linejoin="round" />
              <line x1="32" y1="40" x2="32" y2="50" />
              <line x1="24" y1="44" x2="40" y2="44" />
              <circle cx="28" cy="36" r="1.5" fill="currentColor" stroke="none" />
              <circle cx="36" cy="36" r="1.5" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Servicio de Proceso Completo</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Servicio integral y soluciones personalizadas que cubren las etapas de diseño, fabricación, operación y mantenimiento a lo largo del ciclo de vida del producto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS & HONORS -->
  <section class="relative overflow-hidden py-12 px-[clamp(24px,8vw,160px)] bg-white" id="certifications">
    <div>
      <!-- Section Header -->
      <div class="text-center mb-14 fade-up">
        <div class="inline-flex items-center gap-3 mb-4 justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-brand-orange"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          <span class="text-[clamp(10px,0.8vw,14px)] text-brand-orange tracking-[0.15em] uppercase">Certificaciones y Honores</span>
        </div>
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,56px)] font-bold text-text-dark uppercase tracking-[0.02em]">Garantía de Calidad Global</h2>
        <div class="w-[60px] h-[3px] bg-gradient-to-r from-transparent via-brand-orange to-transparent mx-auto mb-4"></div>
        <p class="text-[15px] text-text-secondary max-w-[600px] mx-auto leading-relaxed">Normas de gestión de calidad y seguridad de productos certificadas internacionalmente garantizan un rendimiento fiable en todos los mercados.</p>
      </div>

      <!-- Carousel -->
      <div class="relative fade-up" id="certCarousel">
        <div id="certTrack" class="flex transition-transform duration-500 ease-out">
          <!-- Card 1: CE -->
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(18px,1.4vw,24px)] font-bold text-brand-orange font-barlow-condensed">CE</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">Marcado CE</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">Certificado TÜV Rheinland, cumplimiento UE</p>
            </div>
          </div>
          <!-- Card 2: UL -->
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(18px,1.4vw,24px)] font-bold text-brand-orange font-barlow-condensed">UL</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">UL 508 Listado</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">Certificado de seguridad norteamericano</p>
            </div>
          </div>
          <!-- Card 3: ISO -->
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(16px,1.2vw,20px)] font-bold text-brand-orange font-barlow-condensed text-center leading-tight">ISO<br>9001</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">ISO 9001:2015</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">Gestión de calidad certificada por SGS</p>
            </div>
          </div>
          <!-- Card 4: IEC -->
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(18px,1.4vw,24px)] font-bold text-brand-orange font-barlow-condensed">IEC</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">Serie IEC 61000</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">Normas de EMC y emisión de armónicos</p>
            </div>
          </div>
          <!-- Card 5: RoHS -->
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(10px,0.8vw,14px)] font-bold text-brand-orange font-barlow-condensed text-center leading-tight">RoHS<br>REACH</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">RoHS y REACH</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">Cumplimiento de sustancias peligrosas</p>
            </div>
          </div>
        </div>

        <!-- Nav Arrows -->
        <button id="certPrev" class="absolute left-0 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-bg-card border border-border-card rounded-full text-text-dark hover:bg-brand-orange hover:text-white hover:border-brand-orange transition-all duration-200 cursor-pointer z-10 max-md:hidden">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button id="certNext" class="absolute right-0 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-bg-card border border-border-card rounded-full text-text-dark hover:bg-brand-orange hover:text-white hover:border-brand-orange transition-all duration-200 cursor-pointer z-10 max-md:hidden">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <!-- Dots -->
        <div class="flex items-center justify-center gap-2.5 mt-8" id="certDots">
          <span class="cert-dot w-2.5 h-2.5 rounded-full bg-brand-orange cursor-pointer transition-all duration-300" data-index="0"></span>
          <span class="cert-dot w-2.5 h-2.5 rounded-full bg-border-subtle cursor-pointer transition-all duration-300" data-index="1"></span>
          <span class="cert-dot w-2.5 h-2.5 rounded-full bg-border-subtle cursor-pointer transition-all duration-300" data-index="2"></span>
        </div>

        <!-- Mobile touch hint -->
        <p class="text-center text-[clamp(10px,0.8vw,14px)] text-text-secondary mt-4 md:hidden">Deslice o toque los puntos para navegar</p>
      </div>
    </div>
  </section>

  <!-- GLOBAL REACH -->
  <section class="relative overflow-hidden max-md:overflow-x-auto min-h-[70vh] max-md:min-h-[50vh] flex items-start justify-center pt-12 max-md:pt-16 px-[clamp(24px,8vw,160px)] bg-gray-100">
    <div class="absolute inset-0 bg-[url('/assets/images/about-global.webp')] bg-contain bg-center bg-no-repeat opacity-100 z-0 max-md:hidden"></div>
    <div class="absolute inset-0 hidden max-md:flex items-center z-0" style="min-width:150vw">
      <img src="/assets/images/about-global.webp" alt="Alcance Global" class="w-full h-full object-contain" />
    </div>
    <div class="relative z-10 text-center px-12 py-5 bg-[rgba(0,0,0,0.25)] backdrop-blur-[4px] border border-[rgba(255,255,255,0.15)]">
      <div class="inline-flex items-center gap-3 mb-4">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-brand-orange"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="text-[clamp(10px,0.8vw,14px)] text-brand-orange tracking-[0.15em] uppercase">Alcance Global</span>
      </div>
      <div class="w-[60px] h-[3px] mx-auto bg-gradient-to-r from-transparent via-brand-orange to-transparent"></div>
    </div>
  </section>

  <script>
    // Certification carousel
    (function () {
      if (window.AboutPage && window.AboutPage.certInit) return;
      var track = document.getElementById("certTrack");
      var prevBtn = document.getElementById("certPrev");
      var nextBtn = document.getElementById("certNext");
      var dots = document.querySelectorAll(".cert-dot");
      if (!track || !dots.length) return;

      var total = document.querySelectorAll(".cert-card").length;
      var current = 0;
      var maxPos = dots.length - 1;
      var autoTimer = null;

      function getCardWidth() {
        return window.innerWidth < 768 ? 100 : 33.333;
      }

      function goTo(idx) {
        if (idx < 0) idx = maxPos;
        if (idx > maxPos) idx = 0;
        current = idx;
        var offset = -(current * getCardWidth());
        track.style.transform = "translateX(" + offset + "%)";
        for (var i = 0; i < dots.length; i++) {
          dots[i].className =
            "cert-dot w-2.5 h-2.5 rounded-full cursor-pointer transition-all duration-300 " +
            (i === current ? "bg-brand-orange" : "bg-border-subtle");
        }
      }

      function nextSlide() { goTo(current + 1); }
      function prevSlide() { goTo(current - 1); }

      function startAuto() {
        stopAuto();
        autoTimer = setInterval(nextSlide, 4000);
      }
      function stopAuto() {
        if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
      }

      if (nextBtn) nextBtn.addEventListener("click", function () { stopAuto(); nextSlide(); });
      if (prevBtn) prevBtn.addEventListener("click", function () { stopAuto(); prevSlide(); });
      for (var j = 0; j < dots.length; j++) {
        dots[j].addEventListener("click", function () {
          stopAuto();
          goTo(parseInt(this.getAttribute("data-index")));
        });
      }

      track.addEventListener("mouseenter", stopAuto);
      track.addEventListener("mouseleave", startAuto);
      window.addEventListener("resize", function () {
        track.style.transform = "translateX(" + -(current * getCardWidth()) + "%)";
      });

      goTo(0);
      startAuto();

      window.AboutPage = window.AboutPage || {};
      window.AboutPage.certInit = true;
    })();
  </script>
</BaseLayout>
