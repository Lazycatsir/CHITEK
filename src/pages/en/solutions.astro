      renderScene();
      renderCases();
      resetSceneTimer();
      lucide.createIcons();
    }

    // ===================== UNIFIED SCENE RENDER =====================
    function renderTopologySVGHorizontal(scene) {
      const branches = scene.branches;
      const svgW = 860, svgH = 200, centerY = 65;

      const gridW = 80, trafoW = 100, devW = 170;
      const gridX = 20, trafoX = 145, devX = 290;

      const arrowColor = '#a8a6a1';
      const accentColor = '#f4a261';

      const branchStartX = 510;
      const branchGap = 42;
      const branchW = 210;

      return `<svg viewBox="0 0 ${svgW} ${svgH}" class="w-full max-w-[860px] h-auto mx-auto" style="overflow:visible">
        <defs>
          <marker id="ah-t" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><polygon points="0 0,8 3,0 6" fill="${arrowColor}"/></marker>
          <marker id="ah-o-t" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><polygon points="0 0,8 3,0 6" fill="${accentColor}"/></marker>
        </defs>

        <!-- Utility Grid -->
        <rect x="${gridX}" y="${centerY - 22}" width="${gridW}" height="44" rx="8" fill="#F5F6F8" stroke="#D0D5DD" stroke-width="1.5"/>
        <text x="${gridX + gridW/2}" y="${centerY + 5}" text-anchor="middle" fill="#4B5058" font-size="14" font-weight="600">Utility</text>

        <!-- Grid → Transformer -->
        <line x1="${gridX + gridW}" y1="${centerY}" x2="${trafoX}" y2="${centerY}" stroke="${arrowColor}" stroke-width="2" marker-end="url(#ah-t)"/>

        <!-- Transformer -->
        <rect x="${trafoX}" y="${centerY - 22}" width="${trafoW}" height="44" rx="8" fill="#F5F6F8" stroke="#D0D5DD" stroke-width="1.5"/>
        <text x="${trafoX + trafoW/2}" y="${centerY + 5}" text-anchor="middle" fill="#4B5058" font-size="13" font-weight="600">Transformer</text>

        <!-- Transformer → Device -->
        <line x1="${trafoX + trafoW}" y1="${centerY}" x2="${devX}" y2="${centerY}" stroke="${arrowColor}" stroke-width="2" marker-end="url(#ah-t)"/>

        <!-- Device (highlighted) -->
        <rect x="${devX}" y="${centerY - 28}" width="${devW}" height="56" rx="10" fill="rgba(244,162,97,0.06)" stroke="${accentColor}" stroke-width="2"/>
        <text x="${devX + devW/2}" y="${centerY - 6}" text-anchor="middle" fill="${accentColor}" font-size="15" font-weight="700">${escapeHtml(scene.deviceLabel)}</text>
        <text x="${devX + devW/2}" y="${centerY + 14}" text-anchor="middle" fill="${accentColor}" font-size="12" font-weight="500">${escapeHtml(scene.deviceType)}</text>

        <!-- Device → Branches (horizontal distribution) -->
        ${branches.map((b, i) => {
          const by = 30 + i * branchGap;
          const bx = branchStartX;
          return `
            <line x1="${devX + devW}" y1="${centerY}" x2="${bx}" y2="${by + 20}" stroke="${accentColor}" stroke-width="1.5" marker-end="url(#ah-o-t)"/>
            <rect x="${bx}" y="${by}" width="${branchW}" height="40" rx="8" fill="#F5F6F8" stroke="#D0D5DD" stroke-width="1"/>
            <text x="${bx + 14}" y="${by + 24}" text-anchor="start" fill="#4B5058" font-size="13" font-weight="500">${escapeHtml(b.label)}</text>
            <text x="${bx + branchW - 14}" y="${by + 24}" text-anchor="end" fill="#8B919A" font-size="11">${escapeHtml(b.sub)}</text>
          `;
        }).join('')}

        <!-- LV Busbar label -->
        <text x="${devX + devW/2}" y="${svgH - 8}" text-anchor="middle" fill="#8B919A" font-size="11">LV Busbar</text>
      </svg>`;
    }

    function renderScene() {
      const pts = dataMap[activeIndustry].painPoints;
