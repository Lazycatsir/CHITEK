    // ===================== SCROLL EFFECTS =====================
    function handleScroll() {
      // Sticky tabs: hidden on hero, revealed after scrolling past
      const stickyTabs = document.getElementById('sticky-tabs');
      if (stickyTabs) {
        const heroBottom = window.innerHeight * 0.55;
        if (window.scrollY > heroBottom) {
          stickyTabs.style.opacity = '1';
          stickyTabs.style.transform = 'translateY(0)';
          stickyTabs.style.pointerEvents = 'auto';
          stickyTabs.style.height = 'auto';
          stickyTabs.style.overflow = 'visible';
        } else {
          stickyTabs.style.opacity = '0';
          stickyTabs.style.transform = 'translateY(-8px)';
          stickyTabs.style.pointerEvents = 'none';
          stickyTabs.style.height = '0';
          stickyTabs.style.overflow = 'hidden';
        }
      }

      // Scroll reveal
      document.querySelectorAll('.scroll-reveal').forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.85) {
          el.classList.add('revealed');
        }
      });
    }

    // ===================== HASH-BASED NAVIGATION =====================
    const industryHashMap = {
      'industry': 'industry',
      'commercial': 'commercial',
      'datacenter': 'datacenter',
      'renewable': 'renewable',
      'rail': 'rail',
      'grid': 'grid',
    };

    function navigateToIndustryFromHash() {
      const hash = window.location.hash.replace('#', '');
      if (hash && industryHashMap[hash]) {
        window.setIndustry(hash);
        setTimeout(() => {
          document.getElementById('solutions')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    }

    window.addEventListener('hashchange', navigateToIndustryFromHash);

    // ===================== INIT =====================
    document.addEventListener('DOMContentLoaded', function() {
      renderIndustryTabs('sticky-industry-tabs');
      renderScene();
      renderCases();
      lucide.createIcons();

      // Check initial hash
      navigateToIndustryFromHash();

      // Start timer
      sceneTimer = setInterval(window.sceneNext, 8000);

      // Scroll listener
      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll(); // Initial check
    });
</script>
