      // Dots
      document.getElementById('sc-dots').innerHTML = pts.map((_, i) =>
        `<button onclick="sceneGo(${i})" class="w-2.5 h-2.5 rounded-full transition-colors duration-300 ${i === sceneIndex ? 'bg-brand-orange' : 'bg-gray-300'}"></button>`
