---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Services — OEM/ODM, Technical Support & Distributor Program | CHITEK',
  description: 'CHITEK offers OEM/ODM services, technical support, and global distributor programs for power quality products with 24/7 after-sales service.',
};

const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '/en' + p : p;
---

<BaseLayout title={meta.title} description={meta.description}>
  <div class="bg-bg-dark">
    <!-- ========== HERO ========== -->
    <section class="relative w-full overflow-hidden min-h-[70vh] mt-[72px] flex items-center justify-center">
      <div class="absolute inset-0">
        <img src="/assets/images/services-hero-bg.webp" alt="Industrial Power Equipment" class="w-full h-full object-cover opacity-40" />
        <div class="absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.03)1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03)1px,transparent 1px);background-size:50px 50px;opacity:0.3"></div>
      </div>
      <div class="relative z-10 text-center px-6 max-w-[80rem] mx-auto">
        <h1 class="font-barlow-condensed text-[clamp(2.5rem,6vw,5rem)] font-bold leading-tight mb-[clamp(12px,2vw,32px)] text-brand-orange">
          Comprehensive Services
        </h1>
        <p class="text-[clamp(1.1rem,2vw,1.5rem)] text-white/90 max-w-2xl mx-auto mb-[clamp(20px,3vw,48px)]">OEM/ODM, technical support, and global distribution — end-to-end power quality partnership.</p>
        <div class="flex items-center justify-center gap-[clamp(8px,1.5vw,20px)]">
          <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-[rgba(194,94,0,0.6)]"></div>
          <div class="w-2 h-2 rotate-45 border border-[rgba(194,94,0,0.6)]"></div>
          <div class="h-[1px] w-16 bg-gradient-to-r from-[rgba(194,94,0,0.6)] to-transparent"></div>
        </div>
      </div>
      <div class="absolute bottom-0 w-32 h-32 left-0 border-l-2 border-b-2 border-[rgba(194,94,0,0.2)]"></div>
      <div class="absolute bottom-0 w-32 h-32 right-0 border-r-2 border-b-2 border-[rgba(194,94,0,0.2)]"></div>
    </section>

    <!-- ========== OEM/ODM ========== -->
    <section id="oem" class="min-h-[calc(100vh-72px)] px-[clamp(24px,8vw,160px)] relative fade-up flex flex-col justify-center py-12 bg-white">
        <div class="text-center mb-[clamp(16px,2.5vw,40px)]">
          <div class="inline-flex items-center gap-3 mb-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-electric-orange-light"><polygon points="12 2 2 7 12 12 22 7"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            <span class="text-[clamp(12px,0.9vw,15px)] text-electric-orange-light tracking-[0.15em] uppercase">OEM / ODM</span>
          </div>
          <h2 class="font-barlow-condensed text-[clamp(1.75rem,3vw,4.5rem)] font-bold text-text-dark mb-2">True Capability Boundaries</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-[clamp(16px,3vw,40px)]">
          <!-- Card 1 -->
          <div class="bg-white p-[clamp(16px,3vw,40px)] border border-gray-200 relative shadow-lg">
            <div class="flex items-center gap-3 mb-[clamp(12px,2vw,32px)]">
              <div class="w-10 h-10 border border-[rgba(194,94,0,0.4)] flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.01 17.461 2 12 2z"/></svg>
              </div>
              <div>
                <h3 class="text-[clamp(16px,1.2vw,20px)] font-bold text-text-dark">Appearance Customization</h3>
                <p class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Standard Service</p>
              </div>
            </div>
            <div class="flex flex-col gap-[clamp(8px,1.5vw,20px)] mb-[clamp(16px,2.5vw,40px)]">
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Enclosure Color</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">RAL color chart specified</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Brand Silk-Screening</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Logo placement customized</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Nameplate Information</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Client-specified content</div></div>
              </div>
            </div>
            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center gap-2 text-[clamp(12px,0.9vw,15px)] text-text-dark/60">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent-blue"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Lead Time:</span>
              </div>
              <div class="text-[clamp(12px,0.9vw,15px)] text-text-dark/60 pl-6">2 weeks (stock enclosure) or 4 weeks (new color)</div>
            </div>
            <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
            <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
          </div>

          <!-- Card 2 -->
          <div class="bg-white p-[clamp(16px,3vw,40px)] border border-gray-200 relative shadow-lg">
            <div class="flex items-center gap-3 mb-[clamp(12px,2vw,32px)]">
              <div class="w-10 h-10 border border-[rgba(194,94,0,0.4)] flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
              <div>
                <h3 class="text-[clamp(16px,1.2vw,20px)] font-bold text-text-dark">Feature Configuration</h3>
                <p class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Selection Service</p>
              </div>
            </div>
            <div class="flex flex-col gap-[clamp(8px,1.5vw,20px)] mb-[clamp(16px,2.5vw,40px)]">
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Capacity Range</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">15A — 200A；10KVar — 180KVar</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Communication Protocol</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Modbus / Profinet / Ethernet</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Harmonic Order</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">2nd — 50th</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Parallel Units</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">1 — 16 units</div></div>
              </div>
            </div>
            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center gap-2 text-[clamp(12px,0.9vw,15px)] text-text-dark/60">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent-blue"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Lead Time:</span>
              </div>
              <div class="text-[clamp(12px,0.9vw,15px)] text-text-dark/60 pl-6">4–6 weeks</div>
            </div>
            <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
            <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
          </div>

          <!-- Card 3 -->
          <div class="bg-white p-[clamp(16px,3vw,40px)] border border-gray-200 relative shadow-lg">
            <div class="flex items-center gap-3 mb-[clamp(12px,2vw,32px)]">
              <div class="w-10 h-10 border border-[rgba(194,94,0,0.4)] flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              </div>
              <div>
                <h3 class="text-[clamp(16px,1.2vw,20px)] font-bold text-text-dark">Deep Customization</h3>
                <p class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Project-Based</p>
              </div>
            </div>
            <div class="flex flex-col gap-[clamp(8px,1.5vw,20px)] mb-[clamp(16px,2.5vw,40px)]">
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Voltage Level Customization</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Requires assessment</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Cabinet Size Adjustment</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">Subject to thermal limits</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-[clamp(12px,0.9vw,15px)] font-medium text-text-dark">Special Environment Protection</div><div class="text-[clamp(10px,0.8vw,12px)] text-text-dark/60">High altitude / Coastal</div></div>
              </div>
            </div>
            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center gap-2 text-[clamp(12px,0.9vw,15px)] text-text-dark/60">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent-blue"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Lead Time:</span>
              </div>
              <div class="text-[clamp(12px,0.9vw,15px)] text-text-dark/60 pl-6">8–12 weeks, technical review required</div>
            </div>
            <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
            <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
          </div>
        </div>

        <!-- Warning -->
        <div class="flex items-start gap-[clamp(8px,1.5vw,20px)] p-[clamp(8px,1.5vw,32px)] border border-yellow-400 bg-yellow-50 mt-12">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          <p class="text-[clamp(12px,0.9vw,15px)] text-text-dark/70 leading-relaxed">Core power modules are standardized platform components to ensure reliability and cost advantages. Customization scope is limited to the items listed above. Anything beyond requires specialized assessment.</p>
        </div>
    </section>

    <!-- ========== SUPPORTED BY A COMMITTED TEAM ========== -->
    <section class="w-full min-h-[calc(100vh-72px)] py-6 px-[clamp(24px,8vw,160px)] bg-bg-dark relative fade-up overflow-hidden flex flex-col justify-center">
      <div class="absolute inset-0">
        <img src="/assets/images/services-services-team.webp" alt="" class="w-full h-full object-cover opacity-30" loading="lazy" />
      </div>
      <div class="flex flex-col gap-[clamp(12px,3vw,48px)]">
        <div class="flex items-end justify-between mb-[clamp(12px,2vw,32px)]">
          <div>
            <div class="inline-flex items-center gap-3 mb-4">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-electric-orange-light"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <span class="text-[clamp(12px,0.9vw,15px)] text-electric-orange-light tracking-[0.15em] uppercase">Service Team</span>
            </div>
            <h2 class="font-barlow-condensed text-[clamp(1.75rem,3vw,4.5rem)] font-bold text-white mb-0">Supported by A Committed Team</h2>
          </div>
          <p class="text-[clamp(12px,0.9vw,15px)] text-white/80 text-right pb-1">Pre-sales &amp; after-sales — full lifecycle support.</p>
        </div>

        <!-- Row 1: Pre-sales Service -->
        <div class="flex max-lg:flex-col gap-[clamp(8px,1.5vw,20px)] items-stretch">
          <div class="flex-[0_0_240px] max-lg:flex-none max-lg:w-full max-lg:flex-row max-lg:items-center max-lg:gap-5 max-lg:p-[clamp(8px,1.5vw,32px)] flex flex-col justify-center p-[clamp(8px,1.5vw,32px)] text-white bg-gradient-to-br from-[#c25e00] to-[#e07b00] shadow-[0_6px_20px_rgba(194,94,0,0.25)] transition-transform duration-300 hover:-translate-y-1 relative">
            <div class="w-12 h-12 mb-4 max-lg:mb-0 max-lg:w-10 max-lg:h-10 opacity-90">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div>
              <h3 class="font-barlow-condensed text-[22px] font-bold uppercase tracking-[0.02em] mb-2">Pre-sales Service</h3>
              <p class="font-barlow text-[clamp(12px,0.9vw,15px)] opacity-85 font-medium">Professional Consultation</p>
            </div>
          </div>
          <div class="flex-1 grid grid-cols-3 max-lg:grid-cols-1 gap-[clamp(8px,1.5vw,20px)]">
            <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] border border-[rgba(255,255,255,0.12)] p-4 flex flex-col transition-all duration-300 hover:-translate-y-[6px] hover:shadow-[0_12px_24px_rgba(0,0,0,0.4)] hover:border-[rgba(194,94,0,0.35)] relative">
              <div class="w-10 h-10 mb-4 text-electric-orange-light">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="flex-1">
                <h4 class="font-barlow text-[clamp(14px,1vw,17px)] font-bold text-[#f5f5f5] mb-2">On-site Testing</h4>
                <p class="font-barlow text-[clamp(12px,0.9vw,15px)] text-white/75 leading-relaxed">Assisting customers with on-site testing, system design, and power quality assessment.</p>
              </div>
              <div class="absolute bottom-4 right-5 font-barlow-condensed text-[clamp(10px,0.8vw,12px)] font-semibold text-electric-orange-light tracking-[0.05em]">01</div>
              <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
              <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
            </div>
            <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] border border-[rgba(255,255,255,0.12)] p-4 flex flex-col transition-all duration-300 hover:-translate-y-[6px] hover:shadow-[0_12px_24px_rgba(0,0,0,0.4)] hover:border-[rgba(194,94,0,0.35)] relative">
              <div class="w-10 h-10 mb-4 text-electric-orange-light">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M7 8l3 3-3 3"/><path d="M13 14h4"/></svg>
              </div>
              <div class="flex-1">
                <h4 class="font-barlow text-[clamp(14px,1vw,17px)] font-bold text-[#f5f5f5] mb-2">Design Consulting</h4>
                <p class="font-barlow text-[clamp(12px,0.9vw,15px)] text-white/75 leading-relaxed">Providing blueprint design consultation and optimization advice for new infrastructure projects.</p>
              </div>
