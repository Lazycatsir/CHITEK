          <button onclick="window.location.href='/contact/?inquiry=' + encodeURIComponent('Request Sample Evaluation for Distributor Program')" class="inline-flex items-center gap-2.5 px-6 py-3 bg-electric-orange text-white text-[clamp(14px,1vw,17px)] font-bold tracking-[0.05em] border-none cursor-pointer transition-colors duration-200 hover:bg-electric-orange-light">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
            Request Sample Evaluation
          </button>
        </div>
      </div>
    </section>

    <!-- ========== GLOBAL CUSTOMER RECOGNITION ========== -->
    <section class="relative overflow-hidden max-md:overflow-x-auto min-h-[70vh] max-md:min-h-[50vh] flex items-start justify-center pt-12 max-md:pt-16 max-md:px-4 fade-up bg-[radial-gradient(ellipse_at_center,#1e3a5f,#0c1628)]">
      <div class="absolute inset-0 bg-[url('/assets/images/services-global.webp')] bg-contain bg-center bg-no-repeat opacity-100 z-0 max-md:hidden"></div>
      <div class="absolute inset-0 hidden max-md:flex items-center z-0" style="min-width:150vw">
        <img src="/assets/images/services-global.webp" alt="Global Reach" class="w-full h-full object-contain" />
      </div>
      <div class="relative z-10 text-center px-12 py-5 max-md:hidden bg-[rgba(7,16,30,0.7)] backdrop-blur-[4px] border border-white/15 inline-block shadow-sm">
        <div class="inline-flex items-center gap-3 mb-4 justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-electric-orange-light"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="text-[clamp(12px,0.9vw,15px)] text-electric-orange-light tracking-[0.15em] uppercase">Global Reach</span>
        </div>
        <div class="w-[60px] h-[3px] mx-auto bg-gradient-to-r from-transparent via-electric-orange to-transparent"></div>
      </div>
    </section>
  </div>

  <script>
    (function() {
      'use strict';

      // ─── Troubleshooting ───
      const diagnosisData = {
        'no-response': {
          cause: 'Control power not connected or main circuit not energized.',
          steps: ['Check control power wiring', 'Confirm main circuit breaker status', 'Inspect LED indicator status']
        },
        'harmonics': {
          cause: 'CT wiring error or harmonic source exceeds compensation range.',
          steps: ['Verify CT installation direction and ratio', 'Confirm harmonic order settings', 'Check load variation conditions']
        },
        'comm': {
          cause: 'Communication parameter mismatch or physical connection interrupted.',
          steps: ['Check baud rate / station address settings', 'Confirm RS485 wiring polarity', 'Test Ethernet cable continuity']
        },
        'overheat': {
          cause: 'Cooling channel blocked or ambient temperature exceeds limit.',
          steps: ['Clean intake and exhaust filters', 'Check if ambient temp > 45°C', 'Confirm fan operation is normal']
        }
      };

      const symptomBtns = document.querySelectorAll('.symptom-btn');
      const diagnosisResult = document.getElementById('diagnosisResult');
      const ticketBtn = document.getElementById('ticketBtn');
      const ticketForm = document.getElementById('ticketForm');

      if (symptomBtns && diagnosisResult && ticketBtn && ticketForm) {
        symptomBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            symptomBtns.forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            const id = btn.dataset.id;
            const data = diagnosisData[id];
            diagnosisResult.innerHTML =
              '<div class="border border-border-dark bg-bg-dark p-4 mt-4">' +
                '<h4 class="text-[clamp(12px,0.9vw,15px)] font-medium text-white/80 mb-3">Step 2: Auto-Match</h4>' +
                '<div>' +
                  '<div class="text-[clamp(10px,0.8vw,12px)] mb-1 text-electric-orange-light">Common Cause</div>' +
                  '<div class="text-[clamp(12px,0.9vw,15px)] mb-4 text-white">' + data.cause + '</div>' +
                '</div>' +
                '<div>' +
                  '<div class="text-[clamp(10px,0.8vw,12px)] mb-1 text-accent-blue">Action Steps</div>' +
                  '<div class="flex flex-col gap-1">' +
                    data.steps.map(function(s, i) {
                      return '<div class="flex items-start gap-2 text-[clamp(12px,0.9vw,15px)] text-white/80"><span class="text-electric-orange-light flex-shrink-0">' + (i + 1) + '.</span>' + s + '</div>';
                    }).join('') +
                  '</div>' +
                '</div>' +
              '</div>';
            ticketBtn.style.display = 'flex';
            ticketForm.style.display = 'none';
          });
        });

        ticketBtn.addEventListener('click', function() {
          const isVisible = ticketForm.style.display !== 'none';
          ticketForm.style.display = isVisible ? 'none' : 'block';
          if (!isVisible) {
            ticketForm.innerHTML =
              '<div class="mt-4 p-4 border border-border-dark bg-bg-dark">' +
                '<p class="text-[clamp(10px,0.8vw,12px)] text-white/80 mb-3">Ticket Form (Demo)</p>' +
                '<input type="text" placeholder="Equipment Model" class="w-full p-2 px-3 mb-2 bg-bg-dark border border-border-dark text-white text-[clamp(12px,0.9vw,15px)] outline-none focus:border-[rgba(194,94,0,0.5)]" />' +
                '<textarea placeholder="Problem Description" rows="3" class="w-full p-2 px-3 mb-2 bg-bg-dark border border-border-dark text-white text-[clamp(12px,0.9vw,15px)] outline-none focus:border-[rgba(194,94,0,0.5)] resize-none min-h-[5rem]"></textarea>' +
                '<button id="ticketSubmitBtn" class="w-full p-2 bg-[rgba(194,94,0,0.8)] border-none text-white text-[clamp(12px,0.9vw,15px)] font-medium cursor-pointer transition-colors duration-200 hover:bg-electric-orange">Submit Ticket</button>' +
              '</div>';
            document.getElementById('ticketSubmitBtn')?.addEventListener('click', function() {
              alert('Ticket submitted (demo)');
            });
          }
        });
      }

      // ─── FAQ Accordion ───
      document.querySelectorAll('.faq-header, .faq-toggle-btn').forEach(function(el) {
        el.addEventListener('click', function() {
          const category = this.closest('.faq-category');
          if (!category) return;
          const body = category.querySelector('.faq-body');
          const arrow = category.querySelector('.faq-arrow');
          const header = category.querySelector('.faq-header');
          const isOpen = body.classList.contains('open');
          document.querySelectorAll('.faq-body').forEach(function(b) {
            b.classList.remove('open');
            b.classList.add('hidden');
          });
          document.querySelectorAll('.faq-header').forEach(function(h) {
            h.classList.remove('border-l-brand-orange', 'bg-brand-orange/[0.05]');
            h.classList.add('border-transparent');
          });
          document.querySelectorAll('.faq-arrow').forEach(function(a) {
            a.classList.remove('rotate-180');
          });
          if (!isOpen) {
            body.classList.remove('hidden');
            body.classList.add('open');
            if (header) {
              header.classList.remove('border-transparent');
              header.classList.add('border-l-brand-orange', 'bg-brand-orange/[0.05]');
            }
            if (arrow) arrow.classList.add('rotate-180');
          }
        });
      });

      // ─── After-Sales FAQ ───
      document.querySelectorAll('.faq-nav-item').forEach(function(el) {
        el.addEventListener('click', function() {
          const container = this.closest('.faq-body');
          if (!container) return;
          container.querySelectorAll('.faq-nav-item').forEach(function(n) {
            n.classList.remove('active', 'bg-brand-orange/[0.15]', 'border-l-brand-orange', 'text-brand-orange', 'font-semibold');
            n.classList.add('border-l-transparent');
          });
          this.classList.remove('border-l-transparent');
          this.classList.add('active', 'bg-brand-orange/[0.15]', 'border-l-brand-orange', 'text-brand-orange', 'font-semibold');
          container.querySelectorAll('.faq-panel').forEach(function(p) {
            p.classList.remove('active');
            p.classList.add('hidden');
          });
          const panel = container.querySelector('#afterSalesPanel' + this.dataset.target);
          if (panel) {
            panel.classList.remove('hidden');
            panel.classList.add('active');
          }
          const currentQ = container.querySelector('.faq-current-question');
          if (currentQ) currentQ.textContent = this.textContent;
        });
      });
    })();
  </script>
</BaseLayout>
