            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href={lp('/news/solar-farm-dubai')} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
