import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Conformal Coating in Low-Voltage AHF Modules: How Three-Proof Protection Extends Converter Life",
  category: "Technology",
  date: "2025-10-25",
  dateDisplay: "Oct 25, 2025",
  author: "CHITEK Technical Team",
  readTime: "5 min read",
  description: "Conformal coating (three-proof) protection extends low-voltage AHF module life in harsh environments — covering coating types, materials trade-offs, and the IGBT vs SiC thermal budget.",
  keywords: ["Active Harmonic Filter", "AHF", "Conformal Coating", "Three-Proof Protection", "Reliability", "IGBT", "SiC", "Power Quality", "Industrial AHF", "CHITEK"]
};

const otherArticles = [
  { title: "Active PFC and Dynamic Reactive Compensation", category: "Technology", href: "/news/active-pfc-dynamic-reactive-compensation", color: "orange" },
  { title: "Active vs Passive Harmonic Filters", category: "Technology", href: "/news/active-vs-passive-harmonic-filters", color: "purple" },
  { title: "Distributed Small Capacity APF Guide", category: "Technology", href: "/news/distributed-small-capacity-apf-guide", color: "orange" },
];

const relatedProducts = [
  { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" },
  { name: "Saudi Industrial Plant", industry: "Manufacturing" },
  { name: "Brazil Data Center", industry: "Data Centers" },
];

const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '/en' + p : p;
