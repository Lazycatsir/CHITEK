  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Conformal Coating in Low-Voltage AHF Modules: How Three-Proof Protection Extends Converter Life",
    "description": "Conformal coating (three-proof) protection extends low-voltage AHF module life in harsh environments — covering coating types, materials trade-offs, and the IGBT vs SiC thermal budget.",
