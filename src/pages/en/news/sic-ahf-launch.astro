---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "New SiC-Based Active Harmonic Filter Series Launch",
  category: "Product Update",
  date: "2024-12-15",
  dateDisplay: "Dec 15, 2024",
  author: "CHITEK Technical Team",
  readTime: "5 min read",
  description: "CHITEK introduces its next-generation SiC AHF series, achieving 99% harmonic compensation with 20% reduced footprint.",
  keywords: ["active harmonic filter", "SiC AHF", "harmonic compensation", "power quality", "silicon carbide", "THD reduction", "industrial power", "VFD harmonic filter", "data center power quality", "CHITEK"]
};

const otherArticles = [
  { title: "Saudi Arabia Power Quality Standards Update", category: "Industry News", href: "/news/saudi-arabia-standards", color: "blue" },
  { title: "Solar Farm Power Quality Optimization in Dubai", category: "Case Study", href: "/news/solar-farm-dubai", color: "green" },
  { title: "SiC vs IGBT: The Future of Power Quality Equipment", category: "Technology", href: "/news/sic-vs-igbt", color: "purple" },
];

const relatedProducts = [
  { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" },
  { name: "Saudi Industrial Plant", industry: "Manufacturing" },
  { name: "Brazil Data Center", industry: "Data Centers" },
];
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="en"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek.com/assets/images/blog/sic-ahf-launch.webp"
>
  <!-- Schema.org Article Structured Data -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "New SiC-Based Active Harmonic Filter Series Launch",
    "description": "CHITEK introduces its next-generation SiC AHF series, achieving 99% harmonic compensation with 20% reduced footprint.",
    "image": "https://chitek.com/assets/images/blog/sic-ahf-launch.webp",
    "author": {
      "@type": "Organization",
      "name": "CHITEK Technical Team"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CHITEK INNOPOWER",
      "logo": {
        "@type": "ImageObject",
        "url": "https://chitek.com/assets/images/logo.webp"
      }
    },
    "datePublished": "2024-12-15",
    "dateModified": "2024-12-15",
    "keywords": "active harmonic filter, SiC AHF, harmonic compensation, power quality, silicon carbide, THD reduction, industrial power, VFD harmonic filter, data center power quality, CHITEK"
  }
  </script>

  <Sidebar lang="en" />

  <!-- Article Header -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href="/news" class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to News
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <!-- Article Content + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <!-- Main Content -->
      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
        <div class="w-full max-h-[300px] rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/blog/sic-ahf-launch.webp" alt="SiC-Based Active Harmonic Filter" class="w-full h-auto object-contain max-h-[300px]" loading="eager" />
        </div>

        <!-- Article Body -->
        <div class="prose prose-lg max-w-none">
          <p class="text-text-mid text-lg leading-relaxed mb-6">
            CHITEK INNOPOWER is proud to announce the launch of its next-generation SiC-Based Active Harmonic Filter (AHF) series, setting new standards in power quality optimization for industrial and commercial applications.
          </p>

          <h2 id="overview" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Product Overview
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            The new SiC AHF series leverages cutting-edge Silicon Carbide (SiC) MOSFET technology, delivering superior switching performance compared to traditional IGBT-based solutions. This advancement enables:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>99% harmonic compensation efficiency</li>
            <li>20% reduction in physical footprint</li>
            <li>Switching frequency up to 25kHz</li>
            <li>Lower thermal management requirements</li>
            <li>Extended operational lifespan</li>
          </ul>

          <h2 id="features" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Key Features
          </h2>
          <p class="text-text-mid leading-relaxed mb-4">
            The SiC AHF series incorporates advanced features designed for demanding industrial environments:
          </p>
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Real-Time Monitoring</h3>
              <p class="text-text-mid text-sm">Built-in power quality analyzer with continuous harmonic monitoring and remote diagnostics capabilities.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Modular Design</h3>
              <p class="text-text-mid text-sm">Scalable architecture allows easy expansion from 30A to 600A modules for growing facilities.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Smart Grid Ready</h3>
              <p class="text-text-mid text-sm">Compatible with modern smart grid protocols including Modbus TCP/IP and IEC 61850.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">IP54 Protection</h3>
              <p class="text-text-mid text-sm">Enhanced protection rating for harsh industrial environments with dust and moisture exposure.</p>
            </div>
          </div>

          <h2 id="specs" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Technical Specifications
          </h2>
          <div class="overflow-x-auto mb-6">
            <table class="w-full border-collapse">
              <thead>
                <tr class="bg-gray-50">
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Parameter</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Value</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Rated Current</td><td class="p-4 border-b border-border-light text-text-mid">50A - 200A</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Voltage</td><td class="p-4 border-b border-border-light text-text-mid">380V-480V AC</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">THD Compensation</td><td class="p-4 border-b border-border-light text-text-mid">Up to 99%</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Response Time</td><td class="p-4 border-b border-border-light text-text-mid">&lt; 5ms</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Efficiency</td><td class="p-4 border-b border-border-light text-text-mid">98.5%+</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Protection Rating</td><td class="p-4 border-b border-border-light text-text-mid">IP54</td></tr>
              </tbody>
            </table>
          </div>

          <h2 id="applications" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Application Scenarios
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            The SiC AHF series is ideal for applications requiring high-performance harmonic filtering:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>Variable Frequency Drive (VFD) systems</li>
            <li>Data center power distribution</li>
            <li>Medical facility power systems</li>
            <li>Industrial manufacturing lines</li>
            <li>Renewable energy installations</li>
          </ul>

          <h2 id="installation" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Installation Guide
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            The modular design enables quick installation with minimal downtime. Standard installation can be completed within 0.5 hours depending on system configuration. CHITEK provides comprehensive installation support including on-site technical assistance.
          </p>

          <!-- SEO Keywords -->
          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Author & Navigation -->
        <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <div class="w-12 h-12 bg-brand-orange/10 rounded-full flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-brand-orange">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-text-dark">CHITEK Technical Team</div>
              <div class="text-sm text-text-muted">Published {article.dateDisplay}</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">Share:</span>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <!-- Other Articles -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              More Articles
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={item.href} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Products -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              Related Products
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={product.href} class="flex items-center gap-2.5 p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="w-8 h-8 bg-brand-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-brand-orange">
                      <path d={product.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-text-dark truncate">{product.name}</div>
                  </div>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-text-muted shrink-0">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              Customer Cases
            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href="/news/solar-farm-dubai" class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
                  <div class="text-xs text-text-muted mt-1">{caseItem.industry}</div>
                </a>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
