  date: "2025-07-01",
  dateDisplay: "Jul 1, 2025",
  author: "CHITEK Technical Team",
  readTime: "8 min read",
  description: "Across African industrial sites, harmonics and poor power factor silently age transformers. Discover how CHITEK's low-voltage AHF and SVG solutions protect transformers and reclaim lost capacity.",
  keywords: ["harmonics", "transformer", "power factor", "AHF", "SVG", "Africa", "IEEE 519", "IGBT", "SiC", "power quality"]
};

const otherArticles = [
  { title: "Solar Inverter Harmonics Guide", category: "Technology", href: "/en/news/blog-solar-inverter-harmonics-ahf", color: "green" },
  { title: "Data Center AHF Case Study", category: "Case Study", href: "/en/news/blog-data-center-ahf-case-study", color: "blue" },
  { title: "AHF vs Line Reactors: Comparison", category: "Technology", href: "/en/news/blog-ahf-vs-line-reactors", color: "purple" }
];

const relatedProducts = [
  { name: "Active Harmonic Filter AHF", href: "/en/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Static Var Generator SVG", href: "/en/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency", href: "/en/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" }
