---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "A Practitioner's Account of the Active Harmonic Filter Industry in 2026",
  category: "Industry News",
  date: "2026-04-28",
  dateDisplay: "Apr 28, 2026",
  author: "CHITEK Editorial Team",
  readTime: "9 min read",
  description: "Drawing on nearly a decade of AHF R&D and delivery practice at Shenzhen Qidian New Energy, a systematic review of the product matrix, patents, compliance testing, and the 2026 industry outlook.",
  keywords: ["active harmonic filter", "APF", "power quality", "harmonic mitigation", "SVG", "silicon carbide", "SiC AHF", "industry insight", "Shenzhen Qidian New Energy", "CHITEK"]
};

const otherArticles = [
  { title: "Saudi Arabia Power Quality Standards Update", category: "Industry News", href: "/news/saudi-arabia-standards", color: "blue" },
  { title: "Solar Farm Power Quality Optimization in Dubai", category: "Case Study", href: "/news/solar-farm-dubai", color: "green" },
  { title: "SiC vs IGBT: The Future of Power Quality Equipment", category: "Technology", href: "/news/sic-vs-igbt", color: "purple" },
];

const relatedProducts = [
  { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" },
  { name: "Saudi Industrial Plant", industry: "Manufacturing" },
  { name: "Brazil Data Center", industry: "Data Centers" },
];

const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '/en' + p : p;
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="en"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/index-product-ahf.webp"
>
  <!-- Schema.org Article Structured Data -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "A Practitioner's Account of the Active Harmonic Filter Industry in 2026",
    "description": "Drawing on nearly a decade of AHF R&D and delivery practice at Shenzhen Qidian New Energy, a systematic review of the product matrix, patents, compliance testing, and the 2026 industry outlook.",
    "image": "https://chitek-inno.com/assets/images/index-product-ahf.webp",
    "author": {
      "@type": "Organization",
      "name": "CHITEK Editorial Team"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CHITEK INNOPOWER",
      "logo": {
        "@type": "ImageObject",
        "url": "https://chitek-inno.com/assets/images/logo.webp"
      }
    },
    "datePublished": "2026-04-28",
    "dateModified": "2026-04-28",
    "keywords": "active harmonic filter, APF, power quality, harmonic mitigation, SVG, silicon carbide, SiC AHF, industry insight, Shenzhen Qidian New Energy, CHITEK"
  }
  </script>

  <Sidebar lang="en" />

  <!-- Article Header -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href={lp('/news')} class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to News
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <!-- Article Content + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <!-- Main Content -->
      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
                <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-6.webp" alt="A Practitioner's Account of the Active Harmonic Filter Industry in 2026" class="w-full h-full object-cover" loading="eager" />
        </div>

        <!-- Article Body -->
        <div class="prose prose-lg max-w-none">
          <p class="text-text-mid text-lg leading-relaxed mb-6">
            Having worked in power quality equipment for nearly a decade—from early basic reactive power compensation devices to the widespread adoption of active harmonic filters across diverse distribution systems—we have witnessed harmonic mitigation evolve from an industrial exclusivity into a standard requirement across multiple scenarios, and accumulated extensive front-line experience working with customers from different industries. From a practitioner's perspective, this article systematically reviews the product portfolio, technology accumulation, compliance and measured performance, and our outlook for the industry in 2026.
          </p>

          <h2 id="application-boundary" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Industry Application Boundaries Keep Expanding
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Throughout 2026, the application boundaries of active harmonic filters continue to broaden. Harmonic mitigation is no longer confined to industrial manufacturing scenarios—data centers, telecom base stations, hospitals, and outdoor engineering, in short any scenario with demanding power stability requirements, have begun to incorporate harmonic mitigation into the standard considerations of their distribution systems.
          </p>

          <h2 id="about-us" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            About Us
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Shenzhen Qidian New Energy Technology Co., Ltd. was established in 2015 as a professional R&D and manufacturing enterprise dedicated to power quality products and solutions. The company has long been rooted in power electronics, with core business covering APF active harmonic filtering, SVG static var compensation, and other power quality equipment, while providing tailored power quality optimization solutions for customers across industries.
          </p>

          <h2 id="product-portfolio" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Complete Active Harmonic Filter Product Portfolio
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Spanning differentiated operating conditions and scenarios, we have built a complete product matrix covering multiple application domains:
          </p>
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Industrial Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">For industrial manufacturing and energy &amp; power sectors, optimized for harmonic interference caused by variable-frequency drives and high-power motors, adapted to complex industrial distribution environments and harmonic fluctuations from frequent equipment start-stop.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Retrofit Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">Designed for legacy plant power quality upgrades, requiring no change to the original switchgear layout, supporting flexible installation and compatible with 50Hz/60Hz as well as 208V–480V, three-phase three-wire / four-wire systems—no major rewiring of the existing lines.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Data Center Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">Targets the harmonics generated by high-density server clusters for precise compensation, preventing harmonic interference with stable server operation and reducing risks of data transmission lag and storage anomalies caused by power quality issues.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Telecom Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">Adapted to telecom operation scenarios, provides targeted mitigation for harmonics from base station power modules, ensures stability of the supply link, and reduces premature wear of power modules caused by harmonics.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Hospital Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">For medical service scenarios, optimized for the power quality demands of various high-precision medical devices, preventing harmonics from interfering with detection accuracy and ensuring stable power supply during diagnosis and treatment.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Compact Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">Meets harmonic mitigation needs of small commercial sites, compact and easy to install, delivering mitigation within limited distribution space while improving energy efficiency.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">High-Power Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">For high-power equipment harmonic mitigation in factories and energy &amp; power systems, efficiently compensating large-magnitude harmonics from high-power loads under continuous heavy-duty operation.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">High-Protection Active Harmonic Filter</h3>
              <p class="text-text-mid text-sm">Designed for outdoor, high-dust and high-humidity engineering scenarios; PCBs are fully potted for protection against dust and moisture, maintaining stable operation under harsh conditions.</p>
            </div>
          </div>

          <h2 id="patents" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Core Technology Accumulation: Multiple Granted Patents
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Building power electronics equipment without solid technology patents makes it easy to fail under complex field conditions. We have successively obtained multiple granted patents covering circuit design, control methods, and structural optimization, and maintain close technical cooperation with Harbin Institute of Technology and the University of Macau to continuously track the frontier of power electronics.
          </p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full border-collapse">
              <thead>
                <tr class="bg-gray-50">
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Patent Name</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Patent No.</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="p-4 border-b border-border-light text-text-mid">SICMOS driving circuit and electronic equipment</td><td class="p-4 border-b border-border-light text-text-mid">CN222127588U</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Distributed control method for unbalanced voltage compensation in isolated-grid AC microgrids</td><td class="p-4 border-b border-border-light text-text-mid">CN114243783B</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Resonance suppression method for reactive power generators</td><td class="p-4 border-b border-border-light text-text-mid">CN118487279B</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Parallel current-sharing device based on IGBT's own parameter characteristics</td><td class="p-4 border-b border-border-light text-text-mid">CN222814372U</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Active harmonic filter mechanism</td><td class="p-4 border-b border-border-light text-text-mid">CN222852255U</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">APF based on parallel connection of multiple discrete IGBTs</td><td class="p-4 border-b border-border-light text-text-mid">CN210780598U</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Aging cabinet with SVG module fixture testing function</td><td class="p-4 border-b border-border-light text-text-mid">CN22268956U</td></tr>
              </tbody>
            </table>
          </div>

          <h2 id="compliance" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Product Compliance and Measured Performance
          </h2>
          <p class="text-text-mid leading-relaxed mb-4">
            For power-related equipment, compliance is the baseline. The full product series has passed CQC (China Quality Certification Center) mandatory certification and EU CE safety certification, with technical indicators conforming to relevant national standards such as GB/T 15576-2008. Key measured performance includes:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>The full series adopts Infineon IGBT devices; third-party on-site acceptance tests show operating efficiency about 1.5% higher than conventional products, and SiC-based products achieve a measured peak efficiency of 99%.</li>
            <li>Supports open-loop and closed-loop parallel operation on both source and load sides, allowing flexible adjustment of installation position according to the field distribution layout.</li>
            <li>A patented "smart coupling" resonance suppression design effectively reduces the probability of system resonance.</li>
            <li>Foolproof wiring design reduces on-site wiring errors and simplifies commissioning.</li>
            <li>Fully potted PCBs resist dust, moisture, and corrosive gases.</li>
            <li>The full series reserves 4G/WiFi expansion interfaces, supporting remote commissioning and remote monitoring.</li>
          </ul>

          <h2 id="service" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Full-Process Service Support
          </h2>
          <p class="text-text-mid leading-relaxed mb-4">
            We have established technical service bases in Guangdong, Zhejiang, Jiangsu, Beijing, Henan, Hebei, Shandong, Shenyang, Hunan, Hubei, and Kunming, covering most regions in China. Differentiated support is provided for different project types:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>Standard warranty: 18 months from factory shipment or 12 months from energization (whichever comes first); extended warranty negotiable for special needs.</li>
            <li>New projects: collaborate with design institutes to provide professional design and selection advice based on actual distribution parameters and load types.</li>
            <li>Retrofit projects: technicians first conduct on-site surveys to identify existing harmonic conditions, then propose a suitable retrofit plan.</li>
            <li>Distributors / integrators: stable product supply and customized adjustments, jointly optimizing the supply chain.</li>
            <li>Engineering companies / general contractors / panel builders: technical documentation and product support coordinated with project schedules to meet configuration requirements.</li>
          </ul>

          <h2 id="manufacturing" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Manufacturing and Delivery Capability
          </h2>
          <p class="text-text-mid leading-relaxed mb-4">
            We operate a 2,300 m² self-owned production plant with a complete in-house production line—from component procurement, SMT soldering, final commissioning, to burn-in testing, all completed within our own facility. Key capabilities and specifications:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>Self-developed aging cabinet with SVG module fixture testing function (patent CN22268956U), ensuring every unit undergoes complete burn-in testing before shipment.</li>
            <li>AHF power range: 5A–200A; SVG reactive power compensation: 10Kvar–150Kvar.</li>
            <li>Unit heights: 1U, 2U, 3U, 4U, adaptable to different switchgear sizes.</li>
            <li>Products sold to over 10 countries worldwide, with multilingual interfaces for convenient overseas technical support.</li>
          </ul>

          <h2 id="ecosystem" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Industry Ecosystem and Peers
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Besides us, there are many niche companies in China's AHF industry, each accumulating distinctive strengths in their focused tracks: some focus on regional markets with rapid on-site response; some specialize in customized development for specific verticals; others lead with cost-effective standardized products. All market players keep deepening their efforts, jointly advancing the overall progress of harmonic mitigation technology.
          </p>

          <h2 id="principles" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Our Principles
          </h2>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li><span class="font-semibold text-text-dark">Customer First:</span> all product iteration and service optimization revolve around customer satisfaction; we respond and handle feedback promptly.</li>
            <li><span class="font-semibold text-text-dark">Create Value for Customers:</span> technology innovation is centered on delivering real value, avoiding flashy useless features.</li>
            <li><span class="font-semibold text-text-dark">Open to Learning:</span> continuously exchange with universities and industry partners, absorbing advanced ideas without complacency.</li>
            <li><span class="font-semibold text-text-dark">Transparent Conduct:</span> published product parameters match actual shipped performance; flat internal management ensures no buck-passing when serving customers.</li>
          </ul>

          <h2 id="outlook" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Industry Outlook for 2026
          </h2>
          <p class="text-text-mid leading-relaxed mb-4">
            Our judgment on the industry's subsequent development:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>Application scenarios will further extend downward; more small and medium scenarios previously unaware of harmonics will recognize issues such as equipment loss and cable heating, driving steady market growth.</li>
            <li>Intelligence will keep rising; AHFs with remote monitoring and big-data analytics become mainstream, automatically generating harmonic mitigation optimization reports.</li>
            <li>Customized products for different operating conditions will further segment; the share of general-purpose products will gradually decline.</li>
            <li>We will continue to deepen in power quality, iterating technology and products to provide stable and reliable solutions for more industries.</li>
          </ul>

          <!-- SEO Keywords -->
          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Author & Navigation -->
        <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <div class="w-12 h-12 bg-brand-orange/10 rounded-full flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-brand-orange">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-text-dark">CHITEK Editorial Team</div>
              <div class="text-sm text-text-muted">Published {article.dateDisplay}</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">Share:</span>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <!-- Other Articles -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              More Articles
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={item.href} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Products -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              Related Products
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={product.href} class="flex items-center gap-2.5 p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="w-8 h-8 bg-brand-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-brand-orange">
                      <path d={product.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-text-dark truncate">{product.name}</div>
                  </div>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-text-muted shrink-0">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
