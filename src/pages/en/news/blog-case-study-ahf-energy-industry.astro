---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Case Study: Low-Voltage AHF Restores an Oil & Gas Plant's Power Quality",
  category: "Case Study",
  date: "2026-07-05",
  dateDisplay: "Jul 5, 2026",
  author: "CHITEK Technical Team",
  readTime: "4 min read",
  description: "How a CHITEK low-voltage AHF reduced THDi from 32.5% to 3.8% in an oil and gas processing plant, restoring reliability and preventing shutdowns.",
  keywords: [
    "Case study",
    "Oil and gas",
    "AHF",
    "Active harmonic filter",
    "THD reduction",
    "Energy industry",
    "Harmonic mitigation",
    "Power quality",
    "Industrial AHF",
    "CHITEK"
  ]
};

const otherArticles = [
    { title: "Conformal Coating for AHF Reliability", category: "Technology", href: "/news/conformal-coating-ahf-reliability", color: "orange" },
    { title: "Active Harmonic Filters vs. Line Reactors", category: "Technology", href: "/news/blog-ahf-vs-line-reactors", color: "orange" },
    { title: "Power Quality in Water Treatment Plants", category: "Technology", href: "/news/blog-ahf-water-treatment-plants", color: "orange" }
  ];
const relatedProducts = [
    { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { name: "SiC-AHF/SVG High Efficiency", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" }
  ];
const relatedCases = [
    { name: "Saudi Industrial Plant", industry: "Manufacturing" },
    { name: "Brazil Data Center", industry: "Data Centers" },
    { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" }
  ];

const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '/en' + p : p;
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="en"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/index-product-ahf.webp"
>
  <!-- Schema.org Article Structured Data -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Case Study: Low-Voltage AHF Restores an Oil & Gas Plant's Power Quality",
    "description": "How a CHITEK low-voltage AHF reduced THDi from 32.5% to 3.8% in an oil and gas processing plant, restoring reliability and preventing shutdowns.",
    "image": "https://chitek-inno.com/assets/images/index-product-ahf.webp",
    "author": {"@type": "Organization","name": "CHITEK Technical Team"},
    "publisher": {"@type": "Organization","name": "CHITEK INNOPOWER","logo": {"@type": "ImageObject","url": "https://chitek-inno.com/assets/images/logo.webp"}},
    "datePublished": "2026-07-05",
    "dateModified": "2026-07-05",
    "keywords": "How, a, CHITEK, low-voltage, AHF, reduced"
  }
  </script>

  <Sidebar lang="en" />

  <!-- Article Header -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href={lp('/news')} class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to News
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-[#2e7d32] bg-[#e8f5e9] px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">&middot;</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <!-- Article Content + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <!-- Main Content -->
      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-7.webp" alt="Case Study: Low-Voltage AHF Restores an Oil & Gas Plant's Power Quality" class="w-full h-full object-cover" loading="eager" />
        </div>

        <div class="prose prose-lg max-w-none">

<p class="text-text-mid text-lg leading-relaxed mb-6">A mid-sized oil and gas processing plant relied on high-capacity centrifugal pumps driven by variable-frequency drives that injected substantial harmonic current into the local low-voltage (&le; ~1 kV) bus. Recurring distortion caused transformer overheating, control-system errors, and unplanned shutdowns. This case study shows how a CHITEK low-voltage Active Harmonic Filter (AHF) resolved it.</p>

<h2 id="problem" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">The Problem: Harmonic Distortion in the Energy Sector</h2>
<p class="text-text-mid leading-relaxed mb-6">The plant&rsquo;s VFDs returned harmonic currents to the grid. Technicians observed THDi frequently exceeding <strong>30%</strong> during peak production, causing transformer overheating, control-system synchronization errors, and unexpected plant shutdowns.</p>

<h2 id="solution" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">The AHF Solution</h2>
<p class="text-text-mid leading-relaxed mb-6">The plant chose a centralized low-voltage AHF at the main distribution board. The selected unit: 300 A modular, 380&ndash;415 V AC, 2nd&ndash;50th harmonic cancellation, 20 kHz switching, &lt; 100 &micro;s response.</p>

<h2 id="results" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">Measured Results</h2>
<p class="text-text-mid leading-relaxed mb-6">THDi fell from <strong>32.5% to 3.8%</strong>, voltage distortion from <strong>7.2% to 2.1%</strong>, transformer temperature dropped 18 &deg;C, and current imbalance collapsed from 8% to 1.5%. Nuisance tripping ceased and availability rose dramatically.</p>

<h2 id="igbt-sic" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">The Converter Core: IGBT and SiC</h2>
<p class="text-text-mid leading-relaxed mb-6"><strong>CHITEK</strong> low-voltage AHF platforms are built on the IGBT&rarr;SiC migration path. A future SiC upgrade holds even lower THDi under heavier VFD loading.</p>

<h2 id="takeaway" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">Engineering Takeaway</h2>
<p class="text-text-mid leading-relaxed mb-6">In the energy industry, harmonics are a strategic risk. Deploy a dynamically controlled, IGBT&rarr;SiC CHITEK low-voltage AHF sized to the actual harmonic current, and the complex electrical environment stays reliable.</p>

<h2 id="conclusion" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">Conclusion</h2>
<p class="text-text-mid leading-relaxed mb-6">This case study demonstrates that a properly sized, centrally deployed low-voltage AHF can restore power quality in oil and gas facilities, delivering measurable reliability gains and cost savings.</p>

        </div>

        <!-- SEO Keywords -->
        <div class="mt-10 pt-6 border-t border-border-light">
          <div class="flex flex-wrap gap-2">
            {article.keywords.map((keyword) => (
              <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
            ))}
          </div>
        </div>

        <!-- Author & Share -->
        <div class="mt-12 pt-8 border-t border-border-light">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-orange to-brand-orange-dark flex items-center justify-center text-white font-bold text-lg">C</div>
              <div>
                <p class="font-semibold text-text-dark">{article.author}</p>
                <p class="text-sm text-text-muted">{article.readTime}</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-sm text-text-muted">Share:</span>
              <button class="w-8 h-8 rounded-full bg-gray-100 hover:bg-brand-orange hover:text-white transition-colors flex items-center justify-center text-sm" aria-label="Share">&#x2197;</button>
            </div>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <!-- Other Articles -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              More Articles
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={lp(item.href)} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Products -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              Related Products
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={lp(product.href)} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="flex items-center gap-2">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-brand-orange shrink-0">
                      <path d={product.icon}/>
                    </svg>
                    <span class="text-sm font-semibold text-text-dark leading-snug">{product.name}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Customer Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Customer Cases
            </h3>
            <div class="space-y-2">
              {relatedCases.map((c) => (
                <div class="p-2.5 bg-white rounded-lg border border-border-light">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{c.name}</div>
                  <div class="text-xs text-text-muted mt-0.5">{c.industry}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>