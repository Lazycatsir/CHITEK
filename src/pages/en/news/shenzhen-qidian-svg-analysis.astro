---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Deep Dive into Power Quality: CHITEK SVG Reactive Power Compensation",
  category: "Technology",
  date: "2026-05-01",
  dateDisplay: "May 1, 2026",
  author: "CHITEK Technical Team",
  readTime: "7 min read",
  description: "A comprehensive analysis of CHITEK's SVG reactive power compensation equipment — from R&D capability, core patents, and product specifications to scenario-based solutions for power quality management.",
  keywords: ["SVG", "static var generator", "reactive power compensation", "power quality", "harmonic mitigation", "IGBT", "silicon carbide", "SiC", "CHITEK", "power factor correction"]
};

const otherArticles = [
  { title: "A Practitioner's Account of the AHF Industry in 2026", category: "Industry News", href: "/news/apf-industry-practitioner-2026", color: "orange" },
  { title: "SiC vs IGBT: The Future of Power Quality Equipment", category: "Technology", href: "/news/sic-vs-igbt", color: "purple" },
  { title: "Saudi Arabia Power Quality Standards Update", category: "Industry News", href: "/news/saudi-arabia-standards", color: "blue" },
];

const relatedProducts = [
  { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency Series", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" },
  { name: "Saudi Industrial Plant", industry: "Manufacturing" },
  { name: "Brazil Data Center", industry: "Data Centers" },
];

const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '/en' + p : p;
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="en"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/index-product-svg.webp"
>
  <!-- Schema.org Article Structured Data -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Deep Dive into Power Quality: CHITEK SVG Reactive Power Compensation",
    "description": "A comprehensive analysis of CHITEK's SVG reactive power compensation equipment — from R&D capability, core patents, and product specifications to scenario-based solutions for power quality management.",
    "image": "https://chitek-inno.com/assets/images/index-product-svg.webp",
    "author": {
      "@type": "Organization",
      "name": "CHITEK Technical Team"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CHITEK INNOPOWER",
      "logo": {
        "@type": "ImageObject",
        "url": "https://chitek-inno.com/assets/images/logo.webp"
      }
    },
    "datePublished": "2026-05-01",
    "dateModified": "2026-05-01",
    "keywords": "SVG, static var generator, reactive power compensation, power quality, harmonic mitigation, IGBT, SiC, CHITEK"
  }
  </script>

  <Sidebar lang="en" />

  <!-- Article Header -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href={lp('/news')} class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to News
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <!-- Article Content + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <!-- Main Content -->
      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
                <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-2.webp" alt="Deep Dive into Power Quality: CHITEK SVG Reactive Power Compensation" class="w-full h-full object-cover" loading="eager" />
        </div>

        <!-- Article Body -->
        <div class="prose prose-lg max-w-none">
          <p class="text-text-mid text-lg leading-relaxed mb-6">
            According to consensus in the power quality industry, reactive power compensation is a core technical measure for ensuring stable distribution system operation and reducing power losses. High-quality SVG reactive power compensation equipment is especially essential in environments with dense precision equipment and concentrated high-power loads.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK INNOPOWER, as a professional R&D and manufacturing enterprise rooted in the power quality domain, has built a comprehensive product system and service capability in SVG reactive power compensation through years of technology accumulation and market presence.
          </p>
          <p class="text-text-mid leading-relaxed mb-8">
            The following sections provide a full analysis of CHITEK's SVG reactive power compensation equipment — covering R&D capability, technology foundations, product specifications, performance advantages, solutions, quality certifications, after-sales service, and overseas deployment.
          </p>

          <h2 id="r-and-d" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Core R&D Strength in SVG Technology
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Shenzhen Qidian New Energy Technology Co., Ltd. was founded in 2015 as a high-tech enterprise integrating R&D and manufacturing. Its core business focuses on power electronics, with two main power quality product lines: APF active harmonic filters and SVG static var generators.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            The company has an experienced R&D team with extensive power electronics expertise, enabling rapid product iteration to address power quality pain points across different industries and meet diverse customer requirements.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            With a self-owned 2,300 m² standardized production line, CHITEK can not only produce standardized SVG products at scale but also support customized requirements for special power quality management scenarios.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            Since its founding, the company has adhered to a "Customer First, Value Innovation" philosophy, accumulating service experience across railway transportation, petrochemical, hospital, public venue, and new energy station sectors.
          </p>

          <h2 id="patents" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Core Patent Technologies for SVG Equipment
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK holds multiple independent patent technologies in SVG reactive power compensation equipment, providing solid technical support for product performance and scenario adaptability.
          </p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full border-collapse">
              <thead>
                <tr class="bg-gray-50">
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Patent Name</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Patent No.</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Distributed control method for unbalanced voltage compensation in isolated-grid AC microgrids</td><td class="p-4 border-b border-border-light text-text-mid">CN114243783B</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Resonance suppression method for reactive power generators</td><td class="p-4 border-b border-border-light text-text-mid">CN118487279B</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">Parallel current-sharing device based on IGBT's own parameter characteristics</td><td class="p-4 border-b border-border-light text-text-mid">CN222814372U</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-text-mid leading-relaxed mb-6">
            The patented "distributed control method for unbalanced voltage compensation in isolated-grid AC microgrids" (CN114243783B) enhances SVG applicability to modern grid topologies, enabling precise unbalanced voltage compensation in isolated microgrid scenarios. The "resonance suppression method for reactive power generators" (CN118487279B) addresses resonance issues in complex distribution circuits, significantly improving SVG operational reliability. The "parallel current-sharing device based on IGBT's own parameter characteristics" (CN222814372U) improves IGBT device consistency, reducing SVG failure rates and extending product service life.
          </p>

          <h2 id="specifications" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Full SVG Product Range and Scenario Adaptation
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK's SVG reactive power compensation equipment offers a rich specification system covering diverse power requirements and installation spaces.
          </p>
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Power Rating Coverage</h3>
              <p class="text-text-mid text-sm">10Kvar, 20Kvar, 35Kvar, 50Kvar, 75Kvar, 100Kvar, 150Kvar and more — enabling precise selection based on distribution system load conditions.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Form Factor Options</h3>
              <p class="text-text-mid text-sm">1U, 2U, 3U, 4U heights to fit various cabinet configurations — flexible for both new construction and retrofit projects.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Power Device Options</h3>
              <p class="text-text-mid text-sm">Supports both IGBT and silicon carbide (SiC) devices. SiC-based products deliver higher efficiency, further reducing power losses in high-power scenarios.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Application Coverage</h3>
              <p class="text-text-mid text-sm">Data centers, telecom facilities, transportation infrastructure (metro, high-speed rail, airports), new energy stations, commercial facilities, and more.</p>
            </div>
          </div>

          <h2 id="performance" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Core Performance Advantages of SVG Products
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK's SVG equipment delivers multiple performance advantages that create tangible value for customers.
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li><span class="font-semibold text-text-dark">High Efficiency:</span> Full series uses Infineon IGBT devices, achieving efficiency 1.5% higher than conventional products; SiC products reach up to 99% efficiency for significant energy cost savings over long-term operation.</li>
            <li><span class="font-semibold text-text-dark">Flexible Configuration:</span> Units can be freely combined and share cabinets with capacitor banks. The built-in capacitor controller directly manages conventional capacitors without extra equipment.</li>
            <li><span class="font-semibold text-text-dark">Versatile Paralleling:</span> Supports source-side and load-side paralleling (open-loop and closed-loop control) for flexible retrofit site adaptation, reducing on-site installation work.</li>
            <li><span class="font-semibold text-text-dark">Smart Resonance Suppression:</span> Patented "smart coupling" design effectively reduces the probability of system resonance, preventing equipment damage and grid fluctuations.</li>
          </ul>

          <h2 id="solutions" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            SVG Solutions for Different Project Types
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK provides tailored SVG solutions for both new construction and retrofit projects.
          </p>
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">New Construction</h3>
              <p class="text-text-mid text-sm">Collaborate with design institutes for professional design and selection recommendations, ensuring optimal power supply at the best cost with pre-reserved installation space and interfaces.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Retrofit Projects</h3>
              <p class="text-text-mid text-sm">Multiple installation methods, compatible with 50Hz/60Hz and 208V-480V systems, supporting three-phase three-wire and four-wire configurations with both source-side and load-side paralleling.</p>
            </div>
          </div>
          <p class="text-text-mid leading-relaxed mb-6">
            For professional distributors, integrators, and engineering contractors, CHITEK also provides supply chain support to optimize procurement and jointly deliver quality power quality solutions to end customers.
          </p>

          <h2 id="compliance" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Rigorous Quality Certification and Compliance
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK's SVG reactive power compensation equipment has passed multiple authoritative quality certifications to ensure compliance with domestic and international standards.
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li>ISO 9001 Quality Management System Certification</li>
            <li>CQC China Quality Certification Center mandatory certification</li>
            <li>EU CE Safety Certification</li>
            <li>Compliant with GB/T 15576-2008 and other national standards</li>
          </ul>
          <p class="text-text-mid leading-relaxed mb-6">
            Every SVG unit undergoes strict burn-in testing and performance verification before shipment, ensuring stable operation upon arrival and minimizing on-site commissioning effort.
          </p>

          <h2 id="service" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Full Lifecycle Service System
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK has established a full lifecycle service system covering product design, commissioning, and operational management. Standard warranty is 18 months from factory shipment or 12 months from energization (whichever comes first), with extended warranty options available.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            Technical service bases are located in Guangdong, Zhejiang, Jiangsu, Beijing, Henan, Hebei, Shandong, Shenyang, Hunan, Hubei, and Kunming, enabling rapid response to customer service needs. Remote commissioning guidance is also available to reduce customer service costs.
          </p>

          <h2 id="overseas" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Globally Recognized Standardized Product Capability
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            CHITEK's SVG equipment has been trusted by international customers since its inception, valued for standardized design, comprehensive product range, easy installation, and high reliability. Products support multiple languages with optional 4G/WiFi expansion modules for remote commissioning and monitoring.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            Currently, customers span more than a dozen countries worldwide. The wide application of products in overseas markets confirms their performance and quality have gained international recognition. CHITEK has optimized product adaptability for different voltage standards and grid conditions in overseas markets.
          </p>

          <!-- SEO Keywords -->
          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Author & Navigation -->
        <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <div class="w-12 h-12 bg-brand-orange/10 rounded-full flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-brand-orange">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-text-dark">CHITEK Technical Team</div>
              <div class="text-sm text-text-muted">Published {article.dateDisplay}</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">Share:</span>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <!-- Other Articles -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              More Articles
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={lp(item.href)} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Products -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              Related Products
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={lp(product.href)} class="flex items-center gap-2.5 p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="w-8 h-8 bg-brand-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-brand-orange">
                      <path d={product.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-text-dark truncate">{product.name}</div>
                  </div>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-text-muted shrink-0">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              Customer Cases
            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href={lp('/news/solar-farm-dubai')} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
                  <div class="text-xs text-text-muted mt-1">{caseItem.industry}</div>
                </a>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
