---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "Active PFC and Dynamic Reactive Compensation on the Low-Voltage Bus",
  category: "Technology",
  date: "2025-11-20",
  dateDisplay: "Nov 20, 2025",
  author: "CHITEK Technical Team",
  readTime: "6 min read",
  description: "Active Power Factor Correction and Static Var Generator (SVG) technology for dynamic reactive compensation on the low-voltage bus — covering principles, IGBT/SiC comparison, and deployment checklist.",
  keywords: ["Active Power Factor Correction", "PFC", "SVG", "Dynamic Compensation", "Power Factor", "IGBT", "SiC", "Low Voltage", "Reactive Power", "CHITEK"]
};

const otherArticles = [
  { title: "Active vs Passive Harmonic Filters", category: "Technology", href: "/news/active-vs-passive-harmonic-filters", color: "orange" },
  { title: "Conformal Coating for AHF Reliability", category: "Technology", href: "/news/conformal-coating-ahf-reliability", color: "purple" },
  { title: "Distributed Small Capacity APF Guide", category: "Technology", href: "/news/distributed-small-capacity-apf-guide", color: "orange" },
];

const relatedProducts = [
  { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG High Efficiency", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "Dubai 50MW Solar Farm", industry: "Renewable Energy" },
  { name: "Saudi Industrial Plant", industry: "Manufacturing" },
  { name: "Brazil Data Center", industry: "Data Centers" },
];

const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '/en' + p : p;
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="en"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/index-product-svg.webp"
>
  <!-- Schema.org Article Structured Data -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Active PFC and Dynamic Reactive Compensation on the Low-Voltage Bus",
    "description": "Active Power Factor Correction and Static Var Generator (SVG) technology for dynamic reactive compensation on the low-voltage bus — covering principles, IGBT/SiC comparison, and deployment checklist.",
    "image": "https://chitek-inno.com/assets/images/index-product-svg.webp",
    "author": {
      "@type": "Organization",
      "name": "CHITEK Technical Team"
    },
    "publisher": {
      "@type": "Organization",
      "name": "CHITEK INNOPOWER",
      "logo": {
        "@type": "ImageObject",
        "url": "https://chitek-inno.com/assets/images/logo.webp"
      }
    },
    "datePublished": "2025-11-20",
    "dateModified": "2025-11-20",
    "keywords": "Active Power Factor Correction, PFC, SVG, Dynamic Compensation, Power Factor, IGBT, SiC, Low Voltage, Reactive Power, CHITEK"
  }
  </script>

  <Sidebar lang="en" />

  <!-- Article Header -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href={lp('/news')} class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to News
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <!-- Article Content + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <!-- Main Content -->
      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-2.webp" alt="Active PFC and Dynamic Reactive Compensation" class="w-full h-full object-cover" loading="eager" />
        </div>

        <!-- Article Body -->
        <div class="prose prose-lg max-w-none">
          <p class="text-text-mid text-lg leading-relaxed mb-6">
            Modern low-voltage (≤ ~1 kV) loads — VFDs, arc furnaces, welders, UPS, PV inverters — swing their reactive demand rapidly and often inject harmonics at the same time. Fixed capacitor banks cannot keep up. Active Power Factor Correction (PFC) and dynamic reactive compensation, built on voltage-source converters, close that gap.
          </p>

          <h2 id="active-pfc" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Active PFC: Canceling Reactive Current
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Active PFC measures real-time load current and voltage, computes the required compensation, and uses a PWM-controlled IGBT inverter to inject opposite-phase reactive current. The result: the source sees only the fundamental active component. Key components: IGBT-based VSI, DC-link capacitor, DSP/FPGA control. Advantages over passive PFC: Millisecond response, No over-compensation (cannot drive PF leading), Works with harmonic loads.
          </p>

          <h2 id="svg" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Dynamic Reactive Compensation: The SVG
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            A Static Var Generator (SVG) delivers dynamic reactive support continuously. It controls the magnitude and phase of its AC output to inject or absorb reactive current within <code class="text-brand-orange bg-brand-orange/10 px-1.5 py-0.5 rounded text-sm font-mono">&lt; 1 ms</code> — versus <code class="text-brand-orange bg-brand-orange/10 px-1.5 py-0.5 rounded text-sm font-mono">&gt; 20 ms</code> for a switched capacitor bank. It holds PF at 0.99+ (vs. the 0.8–0.95 wander of stepped banks), suppresses flicker from impact loads, and supports the bus during load swings.
          </p>

          <h2 id="passive-vs-active" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Passive vs. Active — Engineering Trade
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            A comparison table:
          </p>
          <div class="overflow-x-auto mb-6">
            <table class="w-full border-collapse">
              <thead>
                <tr class="bg-gray-50">
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Feature</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Passive (capacitor bank)</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">Active (SVG / AHF)</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="p-4 border-b border-border-light font-semibold text-text-dark">Response</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Slow (seconds / &gt; 20 ms)</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Fast (&lt; 1 ms)</td>
                </tr>
                <tr>
                  <td class="p-4 border-b border-border-light font-semibold text-text-dark">Harmonic handling</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Fails / can resonate</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Compensates / damps</td>
                </tr>
                <tr>
                  <td class="p-4 border-b border-border-light font-semibold text-text-dark">Over-compensation</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Yes (leading PF risk)</td>
                  <td class="p-4 border-b border-border-light text-text-mid">No (adaptive)</td>
                </tr>
                <tr>
                  <td class="p-4 border-b border-border-light font-semibold text-text-dark">Maintenance</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Low (passive)</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Higher (cooling, firmware)</td>
                </tr>
                <tr>
                  <td class="p-4 border-b border-border-light font-semibold text-text-dark">Cost</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Low</td>
                  <td class="p-4 border-b border-border-light text-text-mid">Higher</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-text-mid leading-relaxed mb-6">
            For stable, predictable, low-harmonic loads a detuned capacitor bank is enough. For fast, harmonic-rich loads — VFD plants, data centers, renewable LV sidings — active correction is the engineering-correct choice.
          </p>

          <h2 id="applications" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Typical LV Application Profiles
          </h2>
          <div class="grid md:grid-cols-3 gap-6 mb-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">VFD-Heavy Plants</h3>
              <p class="text-text-mid text-sm">Arc furnaces and welders cause rapid PF swings; an SVG stabilizes the bus and an AHF cleans the harmonics.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Data Centers</h3>
              <p class="text-text-mid text-sm">UPS and server farms swing PF between 0.8 and 0.9; active PFC holds PF &gt; 0.95.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">Renewable LV Sidings</h3>
              <p class="text-text-mid text-sm">PV inverters can drive PF leading at low generation; an SVG injects lagging VAr to hold the target PF.</p>
            </div>
          </div>

          <h2 id="converter-core" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            The Converter Core: IGBT and SiC
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Both AHF and SVG are bounded by their power switch. A standard IGBT is rated to ~150 °C junction temperature, switching typically below 20 kHz. A SiC MOSFET lifts that: silicon carbide is a wide-bandgap material (3.26 eV vs. silicon's 1.12 eV), tolerates ~200 °C, switches at 2–3× the IGBT frequency, and cuts switching loss by ~50% — gaining +1–3% efficiency. CHITEK low-voltage AHF/SVG platforms are built on this IGBT→SiC migration path.
          </p>

          <h2 id="deployment-checklist" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Engineering Deployment Checklist
          </h2>
          <ol class="list-decimal list-inside text-text-mid leading-relaxed mb-6 space-y-3">
            <li>Measure reactive demand and THDi across a full duty cycle.</li>
            <li>Size to the worst swing, with 10–20% headroom.</li>
            <li>Place at or near the LV PCC / load bus.</li>
            <li>Detune any retained capacitor bank to avoid LC resonance.</li>
            <li>Integrate with the site controller (PMS/EMS).</li>
          </ol>

          <h2 id="conclusion" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            Conclusion
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            Active PFC and dynamic SVG compensation replace stepped, resonance-prone banks with millisecond, adaptive correction — essential wherever LV loads swing and distort.
          </p>

          <!-- CTA Question -->
          <div class="bg-brand-orange/5 border-l-4 border-brand-orange rounded-r-lg p-6 mb-6">
            <p class="text-text-dark font-semibold">
              Need help selecting the right active compensation solution for your low-voltage bus?
            </p>
            <p class="text-text-mid text-sm mt-2">
              Contact CHITEK for a technical assessment and sizing recommendation.
            </p>
          </div>

          <!-- SEO Keywords -->
          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Author & Navigation -->
        <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <div class="w-12 h-12 bg-brand-orange/10 rounded-full flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-brand-orange">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-text-dark">CHITEK Technical Team</div>
              <div class="text-sm text-text-muted">Published {article.dateDisplay}</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">Share:</span>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <!-- Other Articles -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              More Articles
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={lp(item.href)} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Products -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              Related Products
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={lp(product.href)} class="flex items-center gap-2.5 p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="w-8 h-8 bg-brand-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-brand-orange">
                      <path d={product.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-text-dark truncate">{product.name}</div>
                  </div>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-text-muted shrink-0">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              Customer Cases
            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href={lp('/news/solar-farm-dubai')} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
                  <div class="text-xs text-text-muted mt-1">{caseItem.industry}</div>
                </a>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
