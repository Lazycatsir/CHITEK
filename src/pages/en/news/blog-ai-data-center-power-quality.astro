    { title: "Enhancing AHF Reliability with Conformal Coating", category: "Technology", href: "/news/conformal-coating-ahf-reliability", color: "orange" },
    { title: "Active Harmonic Filters vs. Line Reactors", category: "Technology", href: "/news/blog-ahf-vs-line-reactors", color: "orange" },
    { title: "AHF for VFD Systems", category: "Technology", href: "/news/blog-active-harmonic-filter-for-vfd-systems", color: "orange" }
  ];
const relatedProducts = [
    { name: "Active Harmonic Filter AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { name: "Static Var Generator SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
