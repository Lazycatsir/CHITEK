---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
---
<BaseLayout title="News & Insights | CHITEK INNOPOWER" description="Stay updated with the latest news, technical papers, and industry insights from CHITEK INNOPOWER power quality solutions." lang="en">
  <Sidebar lang="en" />

  <!-- Hero Section -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-20 md:py-28">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight mb-6">
        News & <span class="text-brand-orange">Insights</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
        Stay informed with the latest developments in power quality technology, industry trends, and CHITEK solutions.
      </p>
    </div>
  </section>

  <!-- Latest Articles -->
  <section id="articles" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <h2 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mb-4">
        Latest Articles
      </h2>
      <p class="text-text-mid text-lg mb-12 max-w-2xl">
        Explore our latest news, product updates, and company announcements.
      </p>

      <div class="space-y-6">
        <!-- Article 1 - Jul 9, 2026 -->
        <a href="/news/blog-chitek-ahf-advantages" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-brand-orange/10 to-brand-orange/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-brand-orange/40">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div class="p-6 md:p-8 flex flex-col justify-center flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-semibold text-brand-orange bg-brand-orange/10 px-3 py-1 rounded-full">Technology</span>
              <span class="text-xs text-text-muted">Jul 9, 2026</span>
            </div>
            <h3 class="text-xl font-bold text-text-dark mb-3 group-hover:text-brand-orange transition-colors">
              Active Harmonic Filter Technology: A Comprehensive Analysis of CHITEK's Advantages
            </h3>
            <p class="text-text-mid text-sm leading-relaxed mb-4">
              From core technology patents to a complete product lineup, an in-depth analysis of AHF's role in industrial manufacturing, data centers, and beyond.
            </p>
            <span class="inline-flex items-center text-brand-orange text-sm font-semibold">
              Read More
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 ml-1">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Article 2 - Jun 15, 2026 -->
