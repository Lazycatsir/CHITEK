        (function() {
          var items = document.querySelectorAll('.series-heading, .series-subtitle, .series-card');
          if (!items.length) return;
          // stagger card delays within each reveal-group (relative to each element's own trigger)
          document.querySelectorAll('.reveal-group').forEach(function(g) {
            var cards = g.querySelectorAll('.series-card');
            cards.forEach(function(c, i) { c.style.transitionDelay = (0.12 + i * 0.12) + 's'; });
          });
          if (!('IntersectionObserver' in window)) {
            items.forEach(function(el) { el.classList.add('revealed'); });
            return;
          }
          var io = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
              } else {
                entry.target.classList.remove('revealed');
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -18% 0px' });
          items.forEach(function(el) { io.observe(el); });
        })();
      </script>
