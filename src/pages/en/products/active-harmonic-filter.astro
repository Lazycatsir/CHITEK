---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const meta = {
  title: 'Active Harmonic Filter (AHF) Manufacturer | CHITEK',
  description: 'CHITEK Active Harmonic Filter (AHF) — IGBT-based dynamic harmonic mitigation, <5% THD, power factor correction and load balancing for VFD, UPS and industrial loads.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="en">
  <script is:inline>document.documentElement.classList.add('js');</script>
  <!-- Structured data: BreadcrumbList + Product + FAQPage -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://en.chitek-inno.com/" },
      { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://en.chitek-inno.com/products" },
      { "@type": "ListItem", "position": 3, "name": "Active Harmonic Filter", "item": "https://en.chitek-inno.com/products/active-harmonic-filter" }
    ]
  }
  </script>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "CHITEK Active Harmonic Filter (AHF)",
    "brand": { "@type": "Brand", "name": "CHITEK INNOPOWER" },
    "description": "IGBT / SiC based active harmonic filter that dynamically cancels harmonic currents, corrects power factor and balances loads to keep THDi below 5% per IEEE 519.",
    "category": "Power Quality / Harmonic Mitigation",
    "additionalProperty": [
      { "@type": "PropertyValue", "name": "Rated Voltage", "value": "220-690V" },
      { "@type": "PropertyValue", "name": "Rated Capacity", "value": "15A-200A per module, parallel expandable" },
      { "@type": "PropertyValue", "name": "Frequency", "value": "50/60 Hz" },
      { "@type": "PropertyValue", "name": "Wiring", "value": "3P3W / 3P4W" },
      { "@type": "PropertyValue", "name": "Filtering Range", "value": "2nd-51st order harmonic" },
      { "@type": "PropertyValue", "name": "Full Response Time", "value": "<50 us" },
      { "@type": "PropertyValue", "name": "Efficiency", "value": ">=97%" },
      { "@type": "PropertyValue", "name": "THDi", "value": "<5% (IEEE 519)" },
      { "@type": "PropertyValue", "name": "Topology", "value": "3-level NPC, IGBT / SiC" },
      { "@type": "PropertyValue", "name": "Standard", "value": "IEC 61000 / IEC 62477" },
      { "@type": "PropertyValue", "name": "Communication", "value": "MODBUS / optional Ethernet" }
    ]
  }
  </script>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is an Active Harmonic Filter (AHF)?", "acceptedAnswer": { "@type": "Answer", "text": "An Active Harmonic Filter (AHF) is a power quality device that continuously measures the load current with a CT, calculates the harmonic, reactive and unbalanced components with a DSP/FPGA, and injects an equal and opposite compensation current through an IGBT or SiC inverter — cancelling harmonics in real time and keeping Total Harmonic Distortion (THDi) below 5%." } },
      { "@type": "Question", "name": "How does an active harmonic filter work?", "acceptedAnswer": { "@type": "Answer", "text": "The AHF samples the load current via an external CT, runs an FFT in the DSP to separate 2nd-51st order harmonics, then commands the IGBT/SiC bridge to synthesize a counter-phase current. The grid then sees only the fundamental — harmonics, reactive power and neutral current are all compensated dynamically." } },
      { "@type": "Question", "name": "Active harmonic filter vs passive filter: what is the difference?", "acceptedAnswer": { "@type": "Answer", "text": "A passive filter uses fixed LC tanks tuned to specific frequencies; it can resonate with the grid impedance and only treats known harmonics. An AHF measures and cancels any harmonic spectrum in real time, avoids resonance, and also corrects power factor and imbalance — ideal for variable and dynamic loads." } },
      { "@type": "Question", "name": "When should I use an AHF instead of an SVG?", "acceptedAnswer": { "@type": "Answer", "text": "Use an AHF when harmonic distortion (THDi) is the problem — VFDs, UPS, rectifiers, welding. Use an SVG (Static Var Generator) when the priority is reactive power and voltage stability with low harmonic content. Many sites deploy AHF + SVG together for full power-quality correction." } },
      { "@type": "Question", "name": "What THD limit must my system meet?", "acceptedAnswer": { "@type": "Answer", "text": "IEEE 519 limits harmonic current distortion to typically 5%-8% depending on the short-circuit ratio at the point of common coupling; G5/4 and regional grids set similar thresholds. Exceeding them risks utility fines, supply restrictions and failed commissioning. A properly sized AHF holds THDi under 5%." } },
      { "@type": "Question", "name": "How do I size and select an active harmonic filter?", "acceptedAnswer": { "@type": "Answer", "text": "Size the AHF from the load's harmonic spectrum and total current. Rule of thumb: select 20%-30% of the nonlinear load rated current for harmonic compensation, plus reactive-power needs. CHITEK offers a selection matrix by voltage class, series and capacity (15A-200A per module, parallel expandable to 3000A+)." } },
      { "@type": "Question", "name": "Can an AHF handle 3-phase 4-wire neutral current?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. In 3-phase 4-wire systems the 3rd harmonic accumulates in the neutral and can reach 1.7x the phase current. CHITEK AHF in 3P4W mode injects compensating neutral current, eliminating overload, insulation aging and fire risk." } },
      { "@type": "Question", "name": "Wall-mounted or cabinet AHF — which should I choose?", "acceptedAnswer": { "@type": "Answer", "text": "The Ultra-Slim (U-Series) wall-mounted unit fits space-constrained switchrooms up to ~100A. For larger capacities, outdoor or parallel duty, choose a floor-standing Standard (L-Series) or Distributed (D-Series) cabinet. Selection depends on capacity, cooling and installation space." } },
      { "@type": "Question", "name": "How is the AHF installed and commissioned?", "acceptedAnswer": { "@type": "Answer", "text": "Install the AHF in parallel with the load downstream of the metering point, connect the CT around the incoming feeder, and power on. Configuration is done on the front HMI: set the compensation priority (harmonic / reactive / balance), and up to 10 units auto-synchronize in under 5 minutes with hot-swappable modules." } }
    ]
  }
  </script>

  <!-- Hero -->
  <section class="relative w-full overflow-hidden" style="background:url('/assets/images/products-hero-bg.webp') center/cover no-repeat">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 py-[clamp(56px,8vw,110px)]">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-brand-orange font-barlow-condensed tracking-widest text-[clamp(13px,1.2vw,18px)] font-semibold mb-3">POWER QUALITY SOLUTIONS</p>
          <h1 class="text-[clamp(2.2rem,5vw,4.2rem)] font-bold leading-tight mb-5 font-barlow-condensed text-white">Active Harmonic Filter (AHF)</h1>
          <p class="text-[clamp(1rem,1.6vw,1.3rem)] text-white/90 max-w-xl leading-relaxed">Dynamic, IGBT / SiC-based harmonic mitigation that drives THDi below 5%, corrects power factor and balances loads for VFD, UPS and industrial applications.</p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/en/contact" class="inline-block bg-brand-orange hover:bg-brand-orange-dark text-white font-semibold rounded-lg px-6 py-3 text-[clamp(14px,1.1vw,16px)] transition-colors">Request a Quote</a>
            <a href="#overview" class="inline-block border border-white/30 text-white hover:bg-white/10 font-semibold rounded-lg px-6 py-3 text-[clamp(14px,1.1vw,16px)] transition-colors">Learn More</a>
          </div>
        </div>
        <div class="relative">
          <img src="/assets/images/products-hero.webp" alt="CHITEK Active Harmonic Filter rack-mounted module" class="rounded-2xl shadow-2xl border border-white/10 w-full object-cover aspect-[4/3]" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Breadcrumb (visible) -->
  <nav class="bg-[#fafbfc] border-b border-border-light" aria-label="Breadcrumb">
    <div class="mx-auto max-w-7xl px-6 py-3 text-[clamp(12px,0.9vw,14px)] text-text-muted">
      <a href="/en" class="hover:text-brand-orange transition-colors">Home</a>
      <span class="mx-2 text-border-light">/</span>
      <a href="/en/products" class="hover:text-brand-orange transition-colors">Products</a>
      <span class="mx-2 text-border-light">/</span>
      <span class="text-text-dark font-medium">Active Harmonic Filter</span>
    </div>
  </nav>

  <!-- Sticky section sub-navigation -->
  <nav class="sticky top-[72px] z-[999] bg-white/95 backdrop-blur border-b border-border-light" aria-label="Section navigation">
    <div class="mx-auto max-w-7xl px-6">
      <div class="subnav-scroll flex gap-1 overflow-x-auto" id="subnav">
        <a href="#overview" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Overview</a>
        <a href="#how-it-works" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">How It Works</a>
        <a href="#benefits" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Features</a>
        <a href="#specifications" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Specifications</a>
        <a href="#series" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Series</a>
        <a href="#applications" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Applications</a>
        <a href="#cases" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Case Studies</a>
        <a href="#why" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Why CHITEK</a>
        <a href="#production" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">Production</a>
        <a href="#vs-passive" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">AHF vs Passive</a>
        <a href="#faq" class="subnav-link whitespace-nowrap px-3.5 py-3 text-[13px] font-medium text-text-muted border-b-2 border-transparent hover:text-brand-orange hover:border-brand-orange transition-colors">FAQ</a>
      </div>
    </div>
  </nav>

  <!-- Key Specifications at a glance -->
  <section class="bg-white py-7 border-b border-border-light">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        <div class="rounded-xl bg-[#fafbfc] border border-border-light p-4 text-center">
          <div class="text-[11px] uppercase tracking-wider text-text-muted mb-1">Rated Voltage</div>
          <div class="text-[clamp(15px,1.2vw,18px)] font-bold text-text-dark font-barlow-condensed">220–690V</div>
        </div>
        <div class="rounded-xl bg-[#fafbfc] border border-border-light p-4 text-center">
          <div class="text-[11px] uppercase tracking-wider text-text-muted mb-1">Capacity</div>
          <div class="text-[clamp(15px,1.2vw,18px)] font-bold text-text-dark font-barlow-condensed">15–200A/mod</div>
        </div>
        <div class="rounded-xl bg-[#fafbfc] border border-border-light p-4 text-center">
          <div class="text-[11px] uppercase tracking-wider text-text-muted mb-1">THDi</div>
          <div class="text-[clamp(15px,1.2vw,18px)] font-bold text-brand-orange font-barlow-condensed">&lt; 5%</div>
        </div>
        <div class="rounded-xl bg-[#fafbfc] border border-border-light p-4 text-center">
          <div class="text-[11px] uppercase tracking-wider text-text-muted mb-1">Response</div>
          <div class="text-[clamp(15px,1.2vw,18px)] font-bold text-text-dark font-barlow-condensed">&lt; 50 μs</div>
        </div>
        <div class="rounded-xl bg-[#fafbfc] border border-border-light p-4 text-center">
          <div class="text-[11px] uppercase tracking-wider text-text-muted mb-1">Efficiency</div>
          <div class="text-[clamp(15px,1.2vw,18px)] font-bold text-text-dark font-barlow-condensed">≥ 97%</div>
        </div>
        <div class="rounded-xl bg-[#fafbfc] border border-border-light p-4 text-center">
          <div class="text-[11px] uppercase tracking-wider text-text-muted mb-1">Topology</div>
          <div class="text-[clamp(13px,1vw,15px)] font-bold text-text-dark font-barlow-condensed mt-0.5">3-level IGBT/SiC</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section id="overview" class="bg-white py-[clamp(48px,5vw,96px)] scroll-mt-[150px]">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex items-center justify-center gap-4 mb-6">
        <div class="h-[2px] w-12 bg-gradient-to-r from-transparent to-brand-orange/60"></div>
        <div class="h-[3px] w-24 bg-gradient-to-r from-brand-orange/60 via-brand-orange to-brand-orange/60"></div>
        <div class="h-[2px] w-12 bg-gradient-to-r from-brand-orange/60 to-transparent"></div>
      </div>
      <p class="text-brand-orange font-barlow-condensed text-sm font-semibold tracking-[0.2em] mb-3 text-center">01 / OVERVIEW</p>
      <h2 class="text-[clamp(24px,2.5vw,44px)] font-bold text-text-dark mb-6 font-barlow-condensed text-center">What Is an Active Harmonic Filter</h2>

      <!-- Category + tags -->
      <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/10 px-3 py-1 rounded-full">Power Quality / Harmonic Mitigation</span>
        <span class="text-xs text-text-muted border border-border-light px-3 py-1 rounded-full">IGBT / SiC</span>
        <span class="text-xs text-text-muted border border-border-light px-3 py-1 rounded-full">IEEE 519</span>
        <span class="text-xs text-text-muted border border-border-light px-3 py-1 rounded-full">VFD-ready</span>
        <span class="text-xs text-text-muted border border-border-light px-3 py-1 rounded-full">3P3W / 3P4W</span>
        <span class="text-xs text-text-muted border border-border-light px-3 py-1 rounded-full">Parallel Expandable</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center mt-10">
        <div class="text-[clamp(14px,1.1vw,17px)] leading-relaxed text-text-mid space-y-4">
          <p>An <strong class="text-text-dark">Active Harmonic Filter (AHF)</strong> is a solid-state power-quality device that eliminates harmonic distortion at its source. Nonlinear loads — variable frequency drives (VFDs), UPS systems, LED drivers, rectifiers and welding equipment — generate 3rd, 5th, 7th and higher-order harmonics that overheat transformers, waste cable capacity and trip sensitive equipment.</p>
          <p>Instead of tuning fixed reactors, the CHITEK AHF measures the load current in real time and injects a precisely equal, opposite-phase compensation current. The result is a clean sinusoidal grid current with <strong class="text-text-dark">THDi held below 5%</strong> per IEEE 519 — without the resonance risk of passive filters.</p>
        </div>
        <div class="relative rounded-2xl overflow-hidden border border-border-light shadow-sm">
          <img src="/assets/images/index-product-ahf.webp" alt="CHITEK Active Harmonic Filter module" class="w-full h-full object-cover aspect-[4/3]" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="relative py-[clamp(48px,5vw,96px)] overflow-hidden scroll-mt-[150px]" style="background: linear-gradient(rgba(7,16,30,0.92), rgba(7,16,30,0.92)), url('/assets/images/products-key-features.jpg') center/cover no-repeat">
    <div class="mx-auto max-w-7xl px-6">
      <p class="text-brand-orange font-barlow-condensed text-sm font-semibold tracking-[0.2em] mb-3 text-center">02 / HOW IT WORKS</p>
      <h2 class="text-[clamp(24px,2.5vw,44px)] font-bold text-white mb-10 font-barlow-condensed text-center">How an Active Harmonic Filter Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-5">
        <div class="bg-white/5 backdrop-blur-sm border border-brand-orange/30 rounded-2xl p-6">
          <div class="text-brand-orange font-barlow-condensed text-2xl font-bold mb-2">01</div>
          <h3 class="text-white font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Sense (CT)</h3>
          <p class="text-white/80 text-[clamp(13px,1vw,15px)] leading-relaxed">An external current transformer samples the load current continuously at the point of common coupling.</p>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-brand-orange/30 rounded-2xl p-6">
          <div class="text-brand-orange font-barlow-condensed text-2xl font-bold mb-2">02</div>
          <h3 class="text-white font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Analyze (FFT + DSP)</h3>
          <p class="text-white/80 text-[clamp(13px,1vw,15px)] leading-relaxed">A DSP / FPGA runs an FFT to separate 2nd–51st order harmonics, reactive power and imbalance in microseconds.</p>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-brand-orange/30 rounded-2xl p-6">
          <div class="text-brand-orange font-barlow-condensed text-2xl font-bold mb-2">03</div>
          <h3 class="text-white font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Command (IGBT / SiC)</h3>
          <p class="text-white/80 text-[clamp(13px,1vw,15px)] leading-relaxed">The inverter bridge is commanded to synthesize the required compensation current at 20 kHz switching.</p>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-brand-orange/30 rounded-2xl p-6">
          <div class="text-brand-orange font-barlow-condensed text-2xl font-bold mb-2">04</div>
          <h3 class="text-white font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Inject</h3>
          <p class="text-white/80 text-[clamp(13px,1vw,15px)] leading-relaxed">A counter-phase current is injected in parallel, cancelling the harmonic component at its source.</p>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-brand-orange/30 rounded-2xl p-6">
          <div class="text-brand-orange font-barlow-condensed text-2xl font-bold mb-2">05</div>
          <h3 class="text-white font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Clean Grid</h3>
          <p class="text-white/80 text-[clamp(13px,1vw,15px)] leading-relaxed">The utility sees only the fundamental — THDi &lt; 5%, improved power factor, balanced phases.</p>
        </div>
      </div>
        <div class="mt-12 max-w-3xl mx-auto">
          <div class="rounded-2xl overflow-hidden border border-brand-orange/30 shadow-lg">
            <img src="/assets/images/products-monitoring.webp" alt="Real-time harmonic monitoring on the CHITEK AHF HMI" class="w-full object-cover" loading="lazy" />
          </div>
          <p class="text-center text-white/60 text-sm mt-3">Real-time harmonic spectrum and compensation status on the front HMI.</p>
        </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section id="benefits" class="bg-white py-[clamp(48px,5vw,96px)] scroll-mt-[150px]">
    <div class="mx-auto max-w-7xl px-6">
      <p class="text-brand-orange font-barlow-condensed text-sm font-semibold tracking-[0.2em] mb-3 text-center">03 / KEY FEATURES</p>
      <div class="reveal-group">
        <h2 class="series-heading text-[clamp(24px,2.5vw,44px)] font-bold text-text-dark mb-3 font-barlow-condensed text-center">Key Features</h2>
        <p class="series-subtitle text-center text-text-mid max-w-2xl mx-auto mb-10 text-[clamp(14px,1.1vw,16px)]">Core Technology Advantages</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          <div class="series-card rounded-2xl border border-border-light p-6">
            <h3 class="text-brand-orange font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Harmonic Mitigation</h3>
            <p class="text-text-mid text-[clamp(13px,1vw,15px)] leading-relaxed">Suppresses 2nd–51st order harmonics, holding THDi below 5% and eliminating resonance risk.</p>
          </div>
          <div class="series-card rounded-2xl border border-border-light p-6">
            <h3 class="text-brand-orange font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Power Factor Correction</h3>
            <p class="text-text-mid text-[clamp(13px,1vw,15px)] leading-relaxed">Dynamic reactive compensation keeps PF in the 0.95–1.0 range and avoids utility penalty charges.</p>
          </div>
          <div class="series-card rounded-2xl border border-border-light p-6">
            <h3 class="text-brand-orange font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Neutral Current Relief</h3>
            <p class="text-text-mid text-[clamp(13px,1vw,15px)] leading-relaxed">3P4W mode cancels accumulated 3rd-harmonic neutral current, preventing overload and fire hazard.</p>
          </div>
          <div class="series-card rounded-2xl border border-border-light p-6">
            <h3 class="text-brand-orange font-semibold mb-2 text-[clamp(15px,1.1vw,18px)]">Load Balancing</h3>
            <p class="text-text-mid text-[clamp(13px,1vw,15px)] leading-relaxed">Redistributes phase currents to remove three-phase unbalance and stabilize voltage.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Specifications (static HTML table) -->
  <section id="specifications" class="bg-[#fafbfc] py-[clamp(48px,5vw,96px)] scroll-mt-[150px]">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-brand-orange font-barlow-condensed text-sm font-semibold tracking-[0.2em] mb-3 text-center">04 / SPECIFICATIONS</p>
      <h2 class="text-[clamp(24px,2.5vw,44px)] font-bold text-text-dark mb-8 font-barlow-condensed text-center">Technical Specifications</h2>
      <div class="overflow-x-auto rounded-2xl border border-border-light bg-white">
        <table class="w-full border-collapse text-[clamp(13px,1vw,15px)]">
          <tbody>
            <tr class="border-b border-border-light"><th class="text-left p-4 bg-[#fafbfc] font-semibold text-text-dark w-1/2">Rated Voltage</th><td class="p-4 text-text-mid">220–690 V</td></tr>
            <tr class="border-b border-border-light"><th class="text-left p-4 bg-[#fafbfc] font-semibold text-text-dark">Rated Capacity</th><td class="p-4 text-text-mid">15 A – 200 A per module (parallel expandable to 3000 A+)</td></tr>
