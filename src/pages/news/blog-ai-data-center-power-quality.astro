---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const article = {
  title: "数据中心电能质量：低压 AHF + SVG 在 UPS 和冷却母线侧的应用",
  category: "技术",
  date: "2026-07-10",
  dateDisplay: "2026年7月10日",
  author: "CHITEK 技术团队",
  readTime: "5 分钟阅读",
  description: "介绍低压AHF和SVG如何解决AI/HPC数据中心中UPS和VFD冷却系统带来的谐波、低功率因数和电压波动问题。",
  keywords: [
    "Data center",
    "Power quality",
    "AHF",
    "SVG",
    "UPS harmonics",
    "AI/HPC",
    "VFD cooling",
    "Active harmonic filter",
    "Static var generator",
    "CHITEK"
  ]
};

const otherArticles = [
    { title: "三防涂层防护提升AHF可靠性", category: "技术", href: "/news/conformal-coating-ahf-reliability", color: "orange" },
    { title: "有源谐波滤波器与进线电抗器对比", category: "技术", href: "/news/blog-ahf-vs-line-reactors", color: "orange" },
    { title: "VFD系统的有源谐波滤波器方案", category: "技术", href: "/news/blog-active-harmonic-filter-for-vfd-systems", color: "orange" }
  ];
const relatedProducts = [
    { name: "有源谐波滤波器 AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { name: "静止无功发生器 SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
    { name: "SiC-AHF/SVG 高效系列", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" }
  ];
const relatedCases = [
    { name: "巴西数据中心", industry: "数据中心" },
    { name: "沙特工业厂房", industry: "制造业" },
    { name: "迪拜50MW光伏电站", industry: "新能源" }
  ];

const lp = (p: string) => p;
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="zh"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/index-product-ahf.webp"
>
  <!-- Schema.org Article Structured Data -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "数据中心电能质量：低压 AHF + SVG 在 UPS 和冷却母线侧的应用",
    "description": "介绍低压AHF和SVG如何解决AI/HPC数据中心中UPS和VFD冷却系统带来的谐波、低功率因数和电压波动问题。",
    "image": "https://chitek-inno.com/assets/images/index-product-ahf.webp",
    "author": {"@type": "Organization","name": "CHITEK Technical Team"},
    "publisher": {"@type": "Organization","name": "CHITEK INNOPOWER","logo": {"@type": "ImageObject","url": "https://chitek-inno.com/assets/images/logo.webp"}},
    "datePublished": "2026-07-10",
    "dateModified": "2026-07-10",
    "keywords": "介绍低压AHF和SVG如何解决AI/HPC数据中心中UPS和VFD冷却系统带来的谐波、低功率因数和电压波动问题。"
  }
  </script>

  <Sidebar lang="zh" />

  <!-- Article Header -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href={'/news'} class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        返回新闻
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/10 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">&middot;</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <!-- Article Content + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <!-- Main Content -->
      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-5.webp" alt="数据中心电能质量：低压 AHF + SVG 在 UPS 和冷却母线侧的应用" class="w-full h-full object-cover" loading="eager" />
        </div>

        <div class="prose prose-lg max-w-none">

<p class="text-text-mid text-lg leading-relaxed mb-6">现代数据中心是密集的非线性负载集群——UPS系统、服务器开关电源、VFD冷却设备(CRAH/CRAC、冷冻水泵、风机)和整流器。随着机架密度提升和AI/HPC工作负载增加，低压(&le; ~1 kV)配电的治理越来越困难。本文介绍低压AHF和SVG如何应对，以及为什么仅靠UPS不能完全解决问题。</p>
<h2 id="why-harder" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">为什么数据中心电能质量越来越难</h2>
<p class="text-text-mid leading-relaxed mb-6">非线性负载产生脉冲电流并注入谐波，THDi通常达到8&ndash;30%，超出IEEE 519的<strong>&lt; 5%</strong>限值。后果包括变压器/电缆过热、断路器误跳闸、效率降低和电压不稳定。</p>
<h2 id="ahf" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">AHF的作用</h2>
<p class="text-text-mid leading-relaxed mb-6"><strong>AHF</strong>响应时间<strong>&lt; 1 ms</strong>，跟踪VFD冷却和服务器负载的变化谐波曲线，将THDi从30%+降至<strong>5%</strong>以下。</p>
<h2 id="svg" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">SVG的重要性</h2>
<p class="text-text-mid leading-relaxed mb-6"><strong>低压SVG</strong>在<strong>&lt; 1 ms</strong>内注入或吸收无功电流，将功率因数维持在<strong>0.99+</strong>并稳定电压。</p>
<h2 id="combined" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">AHF + SVG联合应用</h2>
<p class="text-text-mid leading-relaxed mb-6">AHF治理谐波畸变，SVG处理无功补偿和电压支撑。两者配合，特别适用于拥有大型UPS、VFD冷却和AI/HPC负载的数据中心。</p>
<h2 id="igbt-sic" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">功率核心：IGBT与SiC</h2>
<p class="text-text-mid leading-relaxed mb-6"><strong>CHITEK</strong>低压AHF/SVG平台基于IGBT&rarr;SiC演进路径，非常适合数据中心的连续波动负载。</p>
<h2 id="conclusion" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">结论</h2>
<p class="text-text-mid leading-relaxed mb-6">基于IGBT&rarr;SiC核心的低压AHF + SVG方案，提供UPS单独无法实现的实时自适应校正。</p>

        </div>

        <!-- SEO Keywords -->
        <div class="mt-10 pt-6 border-t border-border-light">
          <div class="flex flex-wrap gap-2">
            {article.keywords.map((keyword) => (
              <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
            ))}
          </div>
        </div>

        <!-- Author & Share -->
        <div class="mt-12 pt-8 border-t border-border-light">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-orange to-brand-orange-dark flex items-center justify-center text-white font-bold text-lg">C</div>
              <div>
                <p class="font-semibold text-text-dark">{article.author}</p>
                <p class="text-sm text-text-muted">{article.readTime}</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-sm text-text-muted">分享：</span>
              <button class="w-8 h-8 rounded-full bg-gray-100 hover:bg-brand-orange hover:text-white transition-colors flex items-center justify-center text-sm" aria-label="Share">&#x2197;</button>
            </div>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <!-- Other Articles -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              更多文章
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={lp(item.href)} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Products -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              相关产品
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={lp(product.href)} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="flex items-center gap-2">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-brand-orange shrink-0">
                      <path d={product.icon}/>
                    </svg>
                    <span class="text-sm font-semibold text-text-dark leading-snug">{product.name}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Customer Cases -->
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              客户案例
            </h3>
            <div class="space-y-2">
              {relatedCases.map((c) => (
                <div class="p-2.5 bg-white rounded-lg border border-border-light">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{c.name}</div>
                  <div class="text-xs text-text-muted mt-0.5">{c.industry}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>