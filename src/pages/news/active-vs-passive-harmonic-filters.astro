  title: "有源与无源谐波滤波器：各自真正的用武之地",
  category: "技术",
  date: "2025-12-15",
  dateDisplay: "2025年12月15日",
  author: "CHITEK 技术团队",
  readTime: "6 分钟阅读",
  description: "对无源（调谐 LC）滤波器与有源电力滤波器（AHF）在低压母线谐波治理中的实用对比——涵盖产生根源、局限性以及 IGBT→SiC 的技术演进路径。",
  keywords: ["有源电力滤波器", "AHF", "无源滤波器", "谐波", "电能质量", "IGBT", "SiC", "IEEE 519", "低压", "CHITEK"]
};

const otherArticles = [
  { title: "SVG 无功补偿装置百科指南", category: "技术", href: "/news/svg-reactive-power-compensation-factory-guide", color: "orange" },
  { title: "分布式小容量 APF 百科指南", category: "技术", href: "/news/distributed-small-capacity-apf-guide", color: "orange" },
  { title: "有源功率因数校正与动态无功补偿", category: "技术", href: "/news/active-pfc-dynamic-reactive-compensation", color: "purple" },
];

const relatedProducts = [
  { name: "有源电力滤波器 AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "静止无功发生器 SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG 高效系列", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
