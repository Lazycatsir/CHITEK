    function renderCases() {
      const cs = dataMap[activeIndústria].cases;
      document.getElementById('cases-list').innerHTML = cs.map((c, i) => {
        const isExpanded = expandedCaseIndex === i;
        return `
        <div class="bg-bg-card border border-border-card rounded-xl overflow-hidden transition-all duration-300 ease-out hover:bg-[#F9FAFB] hover:border-[#D0D5DD] hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)]">
          <!-- Header (always visible) -->
          <div onclick="toggleCase(${i})" class="flex flex-col ${i === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-[clamp(12px,3vw,48px)] p-[clamp(8px,1.5vw,32px)] lg:p-[clamp(16px,3vw,40px)] cursor-pointer">
            <div class="w-full md:w-[45%] md:max-w-[400px] aspect-[4/3] rounded-lg overflow-hidden flex-shrink-0">
              <img src="${escapeHtml(c.image)}" alt="${escapeHtml(c.title)}" class="w-full h-full object-cover transition-transform duration-300 ease-out hover:scale-105" loading="lazy">
            </div>
            <div class="flex-1 flex flex-col justify-center">
              <span class="inline-flex self-start px-3 py-1 rounded text-[clamp(11px,0.9vw,14px)] font-semibold ${c.colorClass} ${c.bgClass} mb-4">${escapeHtml(c.industry)}</span>
              <h3 class="text-[clamp(18px,1.6vw,28px)] font-semibold text-text-primary mb-3 font-barlow-condensed">${escapeHtml(c.title)}</h3>
              <p class="text-[clamp(11px,0.9vw,14px)] text-text-secondary mb-4 leading-relaxed">${escapeHtml(c.highlight)}</p>
              ${c.solution && c.solution.length > 0 ? `
              <div class="mb-4 flex flex-wrap gap-x-5 gap-y-1.5 text-[clamp(11px,0.9vw,14px)] text-text-muted">
                ${c.solution.map(s => `<span class="font-medium text-text-secondary">${escapeHtml(s.product)} <span class="text-electric-orange">×</span> ${s.qty} units</span>`).join('')}
              </div>` : ''}
              <span class="inline-flex items-center gap-1.5 text-electric-orange font-medium text-[clamp(11px,0.9vw,14px)]">
                ${isExpanded ? 'Recolher' : 'Ver Detalhes'}
                <i data-lucide="${isExpanded ? 'chevron-up' : 'chevron-down'}" class="w-4 h-4"></i>
              </span>
            </div>
          </div>

          <!-- Expanded Content -->
          <div class="transition-all duration-300" style="${isExpanded ? '' : 'height:0;overflow:hidden;'}">
            <div class="px-6 lg:px-8 pb-8 border-t border-border-card">
              <!-- Visão Geral do Projeto -->
              <div class="pt-6 pb-4">
                <h4 class="text-[clamp(13px,1.1vw,17px)] font-bold text-brand-navy mb-3 font-barlow-condensed">Visão Geral do Projeto</h4>
                <p class="text-[clamp(11px,0.9vw,14px)] text-text-secondary leading-relaxed">${escapeHtml(c.overview)}</p>
              </div>

              <!-- Trend -->
              <div class="bg-bg-alt-1 rounded-xl p-[clamp(8px,1.5vw,32px)] mb-6">
                <h4 class="text-[clamp(11px,0.9vw,14px)] font-semibold text-brand-navy mb-3">Antes / Depois</h4>
                <p class="text-[28px] font-bold text-brand-orange leading-tight mb-1">${escapeHtml(c.trend)}</p>
                <div class="flex items-center gap-3 mt-3">
                  <span class="h-2 flex-1 rounded-full bg-electric-orange/20"></span>
                  <span class="h-2 flex-1 rounded-full bg-brand-orange/30"></span>
                  <span class="h-2 flex-1 rounded-full bg-brand-orange/50"></span>
                  <span class="h-2 w-16 rounded-full bg-brand-orange"></span>
                </div>
              </div>

              <!-- Solução Implementada -->
              <div class="mb-6">
                <h4 class="text-[clamp(13px,1.1vw,17px)] font-bold text-brand-navy mb-3 font-barlow-condensed">Solução Implementada</h4>
                <div class="space-y-3">
                  ${c.solution.map(s => `
                    <div class="flex items-center gap-4 bg-bg-alt-1 rounded-lg px-5 py-3">
                      <span class="text-[clamp(11px,0.9vw,14px)] font-bold text-electric-orange w-[90px]">${escapeHtml(s.product)}</span>
                      <span class="text-[clamp(11px,0.9vw,14px)] text-text-secondary">× ${s.qty} units</span>
                      <span class="text-xs text-text-muted">${escapeHtml(s.use)}</span>
                    </div>
                  `).join('')}
                </div>
              </div>

              <!-- Resultados Principais -->
              <div class="mb-6">
                <h4 class="text-[clamp(13px,1.1vw,17px)] font-bold text-brand-navy mb-3 font-barlow-condensed">Resultados Principais</h4>
                <div class="space-y-2">
                  ${c.results.map(r => `
                    <div class="flex items-start gap-2.5">
                      <i data-lucide="check-circle" class="w-5 h-5 text-commercial-green flex-shrink-0 mt-0.5"></i>
                      <span class="text-[clamp(11px,0.9vw,14px)] text-text-secondary">${escapeHtml(r)}</span>
                    </div>
                  `).join('')}
                </div>
              </div>

            </div>
          </div>
        </div>`;
      }).join('');
      lucide.createIcons();
    }

    // ===================== SCROLL EFFECTS =====================
    function handleScroll() {
      // Sticky tabs: hidden on hero, revealed after scrolling past
      const stickyTabs = document.getElementById('sticky-tabs');
      if (stickyTabs) {
        const heroBottom = window.innerHeight * 0.55;
        if (window.scrollY > heroBottom) {
          stickyTabs.style.opacity = '1';
          stickyTabs.style.transform = 'translateY(0)';
          stickyTabs.style.pointerEvents = 'auto';
          stickyTabs.style.height = 'auto';
          stickyTabs.style.overflow = 'visible';
        } else {
          stickyTabs.style.opacity = '0';
          stickyTabs.style.transform = 'translateY(-8px)';
          stickyTabs.style.pointerEvents = 'none';
          stickyTabs.style.height = '0';
          stickyTabs.style.overflow = 'hidden';
        }
      }

      // Scroll reveal
      document.querySelectorTodos('.scroll-reveal').forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.85) {
          el.classList.add('revealed');
        }
      });
    }

    // ===================== HASH-BASED NAVIGATION =====================
    const industryHashMap = {
      'industry': 'industry',
      'commercial': 'commercial',
      'datacenter': 'datacenter',
      'renewable': 'renewable',
      'rail': 'rail',
      'grid': 'grid',
    };

    function navigateToIndústriaFromHash() {
      const hash = window.location.hash.replace('#', '');
      if (hash && industryHashMap[hash]) {
        window.setIndústria(hash);
        setTimeout(() => {
          document.getElementById('solutions')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    }

    window.addEventListener('hashchange', navigateToIndústriaFromHash);

    // ===================== INIT =====================
    document.addEventListener('DOMContentLoaded', function() {
      renderIndústriaTabs('sticky-industry-tabs');
      renderScene();
      renderCases();
      lucide.createIcons();

      // Check initial hash
      navigateToIndústriaFromHash();

      // Start timer
      sceneTimer = setInterval(window.sceneNext, 8000);

      // Scroll listener
      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll(); // Initial check
    });
</script>
