---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Soluções de Qualidade de Energia – Aplicações Industriais e de Utilidade | CHITEK',
  description: 'A CHITEK fornece soluções de qualidade de energia para Manufatura Industrial, Edifícios Comerciais, Data Centers, Energia Renovável, Transporte e Redes Elétricas em todo o mundo.',
};
---

<BaseLayout lang="pt" title={meta.title} description={meta.description}>
  <!-- ============ HERO ============ -->
  <section class="relative min-h-[70vh] flex flex-col justify-end overflow-hidden mt-[72px]">
    <div class="absolute inset-0 animate-fade-in">
      <img id="hero-image" src="/assets/images/solutions-commercial-medical-hero-bg.jpg" alt="" class="object-cover w-full h-full" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    </div>
    <div class="relative z-10 max-w-page mx-auto w-full px-6 md:px-10 lg:px-20 pb-8">
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-brand-orange drop-shadow-[0_2px_20px_rgba(0,0,0,0.5)] font-barlow-condensed animate-slide-up-300">Comercial e Médico</h1>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-brand-orange drop-shadow-[0_2px_20px_rgba(0,0,0,0.5)] font-barlow-condensed animate-slide-up-450">Soluções de Qualidade de Energia</h1>
        <p class="mt-6 text-lg md:text-xl text-white/80 max-w-xl leading-relaxed animate-slide-up-600">De salas de cirurgia de precisão a escritórios Classe A — garantia de qualidade de energia em todos os cenários</p>
      </div>
    </div>
  </section>

  <!-- ============ STICKY INDUSTRY TABS ============ -->
  <div id="sticky-tabs" class="sticky top-[72px] z-40 transition-all duration-[400ms] bg-white border-b-2 border-border-subtle shadow-[0_2px_16px_rgba(38,70,83,0.08)] opacity-0 -translate-y-2 pointer-events-none h-0 overflow-hidden">
    <div class="max-w-page mx-auto px-6 md:px-10 lg:px-20">
      <div class="flex items-center gap-0 md:gap-4 overflow-x-auto" id="sticky-industry-tabs"></div>
    </div>
  </div>

  <!-- ============ SOLUTIONS CAROUSEL ============ -->
  <section id="solutions" class="scroll-reveal opacity-0 translate-y-10 transition-all duration-700 ease-out px-6 md:px-10 lg:px-20 py-20 lg:py-[120px] relative overflow-hidden bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/images/solutions-scenario.webp')">
    <div class="max-w-page mx-auto">
      <div class="flex items-end justify-between mb-6">
        <div>
          <h2 class="text-[28px] md:text-[36px] font-bold text-brand-navy leading-tight font-barlow-condensed">Solução de Qualidade de Energia Baseada em Cenários</h2>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-text-secondary font-medium" id="sc-counter">1 / 3</span>
          <div class="flex gap-2" id="sc-dots"></div>
        </div>
      </div>
      <div class="mb-10">
        <div class="flex items-center gap-2" id="sc-scene-label"></div>
      </div>
      <div class="mb-12">
        <h3 class="text-[20px] font-bold text-brand-navy mb-6 pb-3 border-b-2 border-border-subtle">Pontos Problemáticos</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 transition-[opacity,transform,height] duration-300 ease-out carousel-content" id="sc-painpoints"></div>
      </div>
      <div class="mb-12">
        <h3 class="text-[20px] font-bold text-brand-navy mb-6 pb-3 border-b-2 border-border-subtle">Topologia do Sistema</h3>
        <div class="bg-bg-card border border-border-card rounded-xl p-6 lg:p-10 transition-[opacity,transform,height] duration-300 ease-out carousel-content" id="sc-topology"></div>
      </div>
      <div class="flex items-center justify-center gap-6 mt-12" id="sc-indicators"></div>
    </div>
  </section>

  <!-- ============ CASES ============ -->
  <section id="cases" class="scroll-reveal opacity-0 translate-y-10 transition-all duration-700 ease-out bg-bg-page px-6 md:px-10 lg:px-20 py-20 lg:py-[120px]">
    <div class="max-w-page mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary leading-tight mb-10 font-barlow-condensed" id="cases-title">Estudos de Caso — Edifícios Comerciais e Médicos</h2>
      <div class="space-y-6" id="cases-list"></div>
    </div>
  </section>

</BaseLayout>

<style>
  .scroll-reveal {
    opacity: 0;
    translate: 0 10px;
  }
  .scroll-reveal.revealed {
    opacity: 1;
    translate: 0 0;
  }
</style>

<!-- Lucide icons library -->
<script is:inline src="/assets/js/lucide.min.js">
</script>

