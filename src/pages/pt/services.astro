        <img src="/assets/images/services-global.webp" alt="Alcance Global" class="w-full h-full object-contain" />
      </div>
      <div class="relative z-10 text-center px-12 py-5 max-md:px-6 max-md:py-8 bg-[rgba(7,16,30,0.7)] backdrop-blur-[4px] border border-white/15 inline-block shadow-sm max-md:hidden">
        <div class="inline-flex items-center gap-3 mb-4 justify-center">
