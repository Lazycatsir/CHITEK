---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Serviços — OEM/ODM, Suporte Técnico e Programa de Distribuidores | CHITEK',
  description: 'A CHITEK oferece serviços OEM/ODM, suporte técnico e programas globais de distribuidores para produtos de qualidade de energia com serviço pós-venda 24/7.',
};
---

<BaseLayout lang="pt" title={meta.title} description={meta.description}>
  <div class="bg-bg-dark">
    <!-- ========== HERO ========== -->
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-nav">
      <div class="absolute inset-0">
        <img src="/assets/images/services-hero-bg.webp" alt="Equipamento Industrial de Energia" class="w-full h-full object-cover opacity-40" />
        <div class="absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.03)1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03)1px,transparent 1px);background-size:50px 50px;opacity:0.3"></div>
      </div>
      <div class="relative z-10 text-center px-6 max-w-[80rem] mx-auto">
        <h1 class="font-barlow-condensed text-[clamp(2.5rem,6vw,5rem)] font-bold leading-tight mb-6 text-brand-orange">
          Serviços Abrangentes
        </h1>
        <p class="text-[clamp(1.1rem,2vw,1.5rem)] text-white/90 max-w-2xl mx-auto mb-10">OEM/ODM, suporte técnico e distribuição global — parceria completa em qualidade de energia.</p>
        <div class="flex items-center justify-center gap-4">
          <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-[rgba(194,94,0,0.6)]"></div>
          <div class="w-2 h-2 rotate-45 border border-[rgba(194,94,0,0.6)]"></div>
          <div class="h-[1px] w-16 bg-gradient-to-r from-[rgba(194,94,0,0.6)] to-transparent"></div>
        </div>
      </div>
      <div class="absolute bottom-0 w-32 h-32 left-0 border-l-2 border-b-2 border-[rgba(194,94,0,0.2)]"></div>
      <div class="absolute bottom-0 w-32 h-32 right-0 border-r-2 border-b-2 border-[rgba(194,94,0,0.2)]"></div>
    </section>

    <!-- ========== OEM/ODM ========== -->
    <section id="oem" class="py-20 px-6 relative fade-up" style="background-image:linear-gradient(rgba(255,255,255,0.03)1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03)1px,transparent 1px);background-size:50px 50px">
      <div class="max-w-page mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-3 mb-4">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-electric-orange-light"><polygon points="12 2 2 7 12 12 22 7"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            <span class="text-sm text-electric-orange-light tracking-[0.15em] uppercase">OEM / ODM</span>
          </div>
          <h2 class="font-barlow-condensed text-[clamp(1.75rem,3vw,2.5rem)] font-bold text-white mb-2">Verdadeiros Limites de Capacidade</h2>
          <p class="text-sm text-electric-orange-light/75">Três níveis. Classificação honesta.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Card 1 -->
          <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] p-8 border border-[rgba(255,255,255,0.12)] relative shadow-[0_0_20px_rgba(194,94,0,0.15)]">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 border border-[rgba(194,94,0,0.4)] flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.01 17.461 2 12 2z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white">Personalização de Aparência</h3>
                <p class="text-xs text-text-dim">Serviço Padrão</p>
              </div>
            </div>
            <div class="flex flex-col gap-4 mb-8">
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Cor do Gabinete</div><div class="text-xs text-text-dim">Especificado pela tabela de cores RAL</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Serigrafia da Marca</div><div class="text-xs text-text-dim">Posicionamento do logotipo personalizado</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Informação da Placa de Identificação</div><div class="text-xs text-text-dim">Conteúdo especificado pelo cliente</div></div>
              </div>
            </div>
            <div class="border-t border-border-dark pt-4">
              <div class="flex items-center gap-2 text-sm text-text-dim">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Prazo de Entrega:</span>
              </div>
              <div class="text-sm text-text-dim pl-6">2 semanas (gabinete padrão) ou 4 semanas (nova cor)</div>
            </div>
            <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
            <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
          </div>

          <!-- Card 2 -->
          <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] p-8 border border-[rgba(255,255,255,0.12)] relative shadow-[0_0_20px_rgba(194,94,0,0.15)]">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 border border-[rgba(194,94,0,0.4)] flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white">Configuração de Recursos</h3>
                <p class="text-xs text-text-dim">Serviço de Seleção</p>
              </div>
            </div>
            <div class="flex flex-col gap-4 mb-8">
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Faixa de Capacidade</div><div class="text-xs text-text-dim">50kvar — 600kvar</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Protocolo de Comunicação</div><div class="text-xs text-text-dim">Modbus / Profinet / Ethernet</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Ordem Harmônica</div><div class="text-xs text-text-dim">2ª — 13ª</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Unidades em Paralelo</div><div class="text-xs text-text-dim">1 — 10 unidades</div></div>
              </div>
            </div>
            <div class="border-t border-border-dark pt-4">
              <div class="flex items-center gap-2 text-sm text-text-dim">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Prazo de Entrega:</span>
              </div>
              <div class="text-sm text-text-dim pl-6">4–6 semanas</div>
            </div>
            <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
            <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
          </div>

          <!-- Card 3 -->
          <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] p-8 border border-[rgba(255,255,255,0.12)] relative shadow-[0_0_20px_rgba(194,94,0,0.15)]">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 border border-[rgba(194,94,0,0.4)] flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white">Personalização Profunda</h3>
                <p class="text-xs text-text-dim">Baseada em Projeto</p>
              </div>
            </div>
            <div class="flex flex-col gap-4 mb-8">
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Personalização de Nível de Tensão</div><div class="text-xs text-text-dim">Requer avaliação</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Ajuste de Tamanho do Gabinete</div><div class="text-xs text-text-dim">Sujeito a limites térmicos</div></div>
              </div>
              <div class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light mt-0.5 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
                <div><div class="text-sm font-medium text-white">Proteção para Ambientes Especiais</div><div class="text-xs text-text-dim">Grande altitude / Costeiro</div></div>
              </div>
            </div>
            <div class="border-t border-border-dark pt-4">
              <div class="flex items-center gap-2 text-sm text-text-dim">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-electric-orange-light"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Prazo de Entrega:</span>
              </div>
              <div class="text-sm text-text-dim pl-6">8–12 semanas, revisão técnica necessária</div>
            </div>
            <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
            <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
          </div>
        </div>

        <!-- Warning -->
        <div class="flex items-start gap-4 p-6 border border-[rgba(202,138,4,0.3)] bg-[rgba(202,138,4,0.05)] mt-12">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-electric-orange-light flex-shrink-0 mt-0.5"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          <p class="text-sm text-[#aaa] leading-relaxed">Os módulos principais de energia são componentes de plataforma padronizados para garantir confiabilidade e vantagens de custo. O escopo de personalização é limitado aos itens listados acima. Qualquer coisa além disso requer avaliação especializada.</p>
        </div>
      </div>
    </section>

    <!-- ========== SUPPORTED BY A COMMITTED TEAM ========== -->
    <section class="w-full min-h-screen py-10 px-8 md:px-12 bg-bg-dark relative fade-up overflow-hidden flex flex-col justify-center">
      <div class="absolute inset-0"><img src="/assets/images/services-services-team.webp" alt="" class="w-full h-full object-cover opacity-30" loading="lazy" /></div>
      <div class="max-w-page mx-auto flex flex-col gap-6">
        <div class="text-left mb-6">
          <div class="inline-flex items-center gap-3 mb-4">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-electric-orange-light"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span class="text-sm text-electric-orange-light tracking-[0.15em] uppercase">Equipe de Serviço</span>
          </div>
          <h2 class="font-barlow-condensed text-[clamp(1.75rem,3vw,2.5rem)] font-bold text-white mb-2">Apoiado por uma Equipe Comprometida</h2>
          <p class="text-sm text-white/80">Pré-venda e pós-venda — suporte completo ao ciclo de vida.</p>
        </div>

        <!-- Row 1: Pre-sales Service -->
        <div class="flex max-lg:flex-col gap-4 items-stretch">
          <div class="flex-[0_0_240px] max-lg:flex-none max-lg:w-full max-lg:flex-row max-lg:items-center max-lg:gap-5 max-lg:p-6 flex flex-col justify-center p-8 text-white bg-gradient-to-br from-[#c25e00] to-[#e07b00] shadow-[0_6px_20px_rgba(194,94,0,0.25)] transition-transform duration-300 hover:-translate-y-1 relative">
            <div class="w-12 h-12 mb-4 max-lg:mb-0 max-lg:w-10 max-lg:h-10 opacity-90">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div>
              <h3 class="font-barlow-condensed text-[22px] font-bold uppercase tracking-[0.02em] mb-2">Serviço de Pré-venda</h3>
              <p class="font-barlow text-sm opacity-85 font-medium">Consultoria Profissional</p>
            </div>
          </div>
          <div class="flex-1 grid grid-cols-3 max-lg:grid-cols-1 gap-4">
            <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] border border-[rgba(255,255,255,0.12)] p-6 flex flex-col transition-all duration-300 hover:-translate-y-[6px] hover:shadow-[0_12px_24px_rgba(0,0,0,0.4)] hover:border-[rgba(194,94,0,0.35)] relative">
              <div class="w-10 h-10 mb-4 text-electric-orange-light">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="flex-1">
                <h4 class="font-barlow text-base font-bold text-[#f5f5f5] mb-2">Testes In Loco</h4>
                <p class="font-barlow text-sm text-white/75 leading-relaxed">Auxiliando clientes com testes in loco, projeto de sistemas e avaliação de qualidade de energia.</p>
              </div>
              <div class="absolute bottom-4 right-5 font-barlow-condensed text-xs font-semibold text-electric-orange-light tracking-[0.05em]">01</div>
              <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
              <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
            </div>
            <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] border border-[rgba(255,255,255,0.12)] p-6 flex flex-col transition-all duration-300 hover:-translate-y-[6px] hover:shadow-[0_12px_24px_rgba(0,0,0,0.4)] hover:border-[rgba(194,94,0,0.35)] relative">
              <div class="w-10 h-10 mb-4 text-electric-orange-light">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M7 8l3 3-3 3"/><path d="M13 14h4"/></svg>
              </div>
              <div class="flex-1">
                <h4 class="font-barlow text-base font-bold text-[#f5f5f5] mb-2">Consultoria de Projeto</h4>
                <p class="font-barlow text-sm text-white/75 leading-relaxed">Oferecendo consultoria de projeto e conselhos de otimização para novos projetos de infraestrutura.</p>
              </div>
              <div class="absolute bottom-4 right-5 font-barlow-condensed text-xs font-semibold text-electric-orange-light tracking-[0.05em]">02</div>
              <div class="absolute top-[-1px] left-[-1px] w-5 h-5 border-t-2 border-l-2 border-[rgba(194,94,0,0.5)]"></div>
              <div class="absolute bottom-[-1px] right-[-1px] w-5 h-5 border-b-2 border-r-2 border-[rgba(194,94,0,0.5)]"></div>
            </div>
            <div class="bg-[rgba(17,17,17,0.8)] backdrop-blur-[8px] border border-[rgba(255,255,255,0.12)] p-6 flex flex-col transition-all duration-300 hover:-translate-y-[6px] hover:shadow-[0_12px_24px_rgba(0,0,0,0.4)] hover:border-[rgba(194,94,0,0.35)] relative">
              <div class="w-10 h-10 mb-4 text-electric-orange-light">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div class="flex-1">
                <h4 class="font-barlow text-base font-bold text-[#f5f5f5] mb-2">Soluções Personalizadas</h4>
                <p class="font-barlow text-sm text-white/75 leading-relaxed">Entregando soluções de compensação de qualidade de energia ideais, adaptadas às necessidades específicas do cliente.</p>
              </div>
