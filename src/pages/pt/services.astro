      const ticketForm = document.getElementById('ticketForm');

      if (symptomBtns && diagnosisResult && ticketBtn && ticketForm) {
        symptomBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            symptomBtns.forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            const id = btn.dataset.id;
            const data = diagnosisData[id];
            diagnosisResult.innerHTML =
              '<div class="border border-border-dark bg-bg-dark p-4 mt-4">' +
                '<h4 class="text-sm font-medium text-text-muted-dark mb-3">Step 2: Auto-Match</h4>' +
                '<div>' +
                  '<div class="text-xs mb-1 text-electric-orange-light">Common Cause</div>' +
                  '<div class="text-sm mb-4 text-white">' + data.cause + '</div>' +
                '</div>' +
                '<div>' +
                  '<div class="text-xs mb-1 text-electric-orange-light">Action Steps</div>' +
                  '<div class="flex flex-col gap-1">' +
                    data.steps.map(function(s, i) {
                      return '<div class="flex items-start gap-2 text-sm text-text-muted-dark"><span class="text-electric-orange-light flex-shrink-0">' + (i + 1) + '.</span>' + s + '</div>';
                    }).join('') +
                  '</div>' +
                '</div>' +
              '</div>';
            ticketBtn.style.display = 'flex';
            ticketForm.style.display = 'none';
          });
        });

        ticketBtn.addEventListener('click', function() {
          const isVisible = ticketForm.style.display !== 'none';
          ticketForm.style.display = isVisible ? 'none' : 'block';
          if (!isVisible) {
            ticketForm.innerHTML =
              '<div class="mt-4 p-4 border border-border-dark bg-bg-dark">' +
                '<p class="text-xs text-text-dim mb-3">Ticket Form (Demo)</p>' +
                '<input type="text" placeholder="Equipment Model" class="w-full p-2 px-3 mb-2 bg-bg-dark border border-border-dark text-white text-sm outline-none focus:border-[rgba(194,94,0,0.5)]" />' +
                '<textarea placeholder="Problem Description" rows="3" class="w-full p-2 px-3 mb-2 bg-bg-dark border border-border-dark text-white text-sm outline-none focus:border-[rgba(194,94,0,0.5)] resize-none min-h-[5rem]"></textarea>' +
                '<button id="ticketSubmitBtn" class="w-full p-2 bg-[rgba(194,94,0,0.8)] border-none text-white text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-electric-orange">Submit Ticket</button>' +
              '</div>';
            document.getElementById('ticketSubmitBtn')?.addEventListener('click', function() {
              alert('Ticket submitted (demo)');
            });
          }
        });
      }

      // ─── FAQ Accordion ───
      document.querySelectorAll('.faq-header, .faq-toggle-btn').forEach(function(el) {
        el.addEventListener('click', function() {
          const category = this.closest('.faq-category');
          if (!category) return;
          const body = category.querySelector('.faq-body');
          const arrow = category.querySelector('.faq-arrow');
          const header = category.querySelector('.faq-header');
          const isOpen = body.classList.contains('open');
          document.querySelectorAll('.faq-body').forEach(function(b) {
            b.classList.remove('open');
            b.classList.add('hidden');
          });
          document.querySelectorAll('.faq-header').forEach(function(h) {
            h.classList.remove('border-l-brand-orange', 'bg-brand-orange/[0.05]');
            h.classList.add('border-transparent');
          });
          document.querySelectorAll('.faq-arrow').forEach(function(a) {
            a.classList.remove('rotate-180');
          });
          if (!isOpen) {
            body.classList.remove('hidden');
            body.classList.add('open');
            if (header) {
              header.classList.remove('border-transparent');
              header.classList.add('border-l-brand-orange', 'bg-brand-orange/[0.05]');
            }
            if (arrow) arrow.classList.add('rotate-180');
          }
        });
      });

      // ─── After-Sales FAQ ───
      document.querySelectorAll('.faq-nav-item').forEach(function(el) {
        el.addEventListener('click', function() {
          const container = this.closest('.faq-body');
          if (!container) return;
          container.querySelectorAll('.faq-nav-item').forEach(function(n) {
            n.classList.remove('active', 'bg-brand-orange/[0.15]', 'border-l-brand-orange', 'text-brand-orange', 'font-semibold');
            n.classList.add('border-l-transparent');
          });
          this.classList.remove('border-l-transparent');
          this.classList.add('active', 'bg-brand-orange/[0.15]', 'border-l-brand-orange', 'text-brand-orange', 'font-semibold');
          container.querySelectorAll('.faq-panel').forEach(function(p) {
            p.classList.remove('active');
            p.classList.add('hidden');
          });
          const panel = container.querySelector('#afterSalesPanel' + this.dataset.target);
          if (panel) {
            panel.classList.remove('hidden');
            panel.classList.add('active');
          }
          const currentQ = container.querySelector('.faq-current-question');
          if (currentQ) currentQ.textContent = this.textContent;
        });
      });
    })();
  </script>
</BaseLayout>
