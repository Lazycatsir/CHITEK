---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK INNOPOWER – Fabricante de Soluções de Qualidade de Energia',
  description: 'A CHITEK é um fabricante líder de soluções de qualidade de energia de baixa tensão — Filtro Ativo de Harmónicos (AHF), Gerador Estático de Reativos (SVG) e Regulador Automático de Tensão (AVR) para aplicações industriais e comerciais.',
};
---

<BaseLayout lang="pt" title={meta.title} description={meta.description}>
  <!-- HERO -->
  <section id="hero-section" class="hero relative overflow-hidden mt-[72px] min-h-[calc(100vh-72px)] max-lg:min-h-[550px] max-md:min-h-[480px] flex items-center">
    <img src="/assets/images/index-hero-bg.webp" alt="Fundo do Herói" class="absolute inset-0 w-full h-full object-cover object-[center_35%] max-lg:object-[center_25%] max-md:object-[center_15%] z-0 pointer-events-none" />

    <div class="flex flex-col justify-center px-[clamp(24px,8vw,160px)] py-20 max-md:py-16 relative z-10 w-full mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h1 class="font-barlow-condensed text-[clamp(38px,4.5vw,72px)] font-bold leading-[1.1] text-white mb-5">
        <span class="text-brand-orange">Principais OEM</span> de Soluções AHF e SVG de Baixa Tensão
      </h1>
      <p class="text-[clamp(13px,1.2vw,19px)] font-normal text-white/85 leading-[1.75] max-w-[560px] mb-9">
        Otimize a Qualidade de Energia para Maior Produtividade. A Atender Mais de 30 Países em Todo o Mundo.
      </p>
      <div class="flex gap-3.5 items-center">
        <a href="#products" class="bg-brand-orange text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-brand-orange hover:bg-brand-orange-dark hover:border-brand-orange-dark transition-[background,border-color] duration-200">Explorar Produtos</a>
        <a href="#about" class="text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-white/60 hover:bg-white/10 hover:border-white transition-all duration-200">Saber Mais</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="relative overflow-hidden bg-bg-mid text-white min-h-[calc(100vh-72px)] flex flex-col justify-center py-10" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center bg-no-repeat opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>

    <!-- 顶部标题区域 -->
    <div class="relative z-10 text-center px-5 pt-6 pb-4 max-w-[900px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h2 class="font-barlow-condensed text-[clamp(36px,4vw,72px)] font-bold uppercase tracking-[0.02em] mb-[clamp(8px,2vw,32px)] text-white leading-[1.1]">APRESENTAÇÃO DA EMPRESA</h2>
    </div>

    <!-- 主体大框 -->
    <div class="relative z-10 flex flex-col md:flex-row w-[clamp(320px,90vw,1800px)] mx-auto max-md:mx-3 mb-[clamp(8px,1.5vw,32px)] bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <!-- 左侧 About CHITEK 区域 -->
      <div class="flex-1 px-[clamp(12px,2vw,56px)] py-[clamp(16px,3vw,72px)] flex flex-col justify-center border-b md:border-b-0 md:border-r border-white/10">
        <h2 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-[clamp(12px,2vw,32px)] uppercase tracking-[0.02em] text-white">SOBRE A <span class="text-brand-orange">CHITEK</span></h2>
        <div class="w-10 h-[3px] bg-brand-orange mb-[clamp(12px,2vw,32px)]"></div>
        <p class="text-[clamp(13px,0.9vw,16px)] leading-[1.8] text-white/75 mb-[clamp(16px,2.5vw,40px)]">
          A Shenzhen CHITEK New Energy Technology Co., Ltd., fundada em 2019 e
          com sede em Shenzhen, é uma empresa de alta tecnologia especializada em
          investigação, desenvolvimento, fabrico e serviço de produtos de
          eletrónica de potência. Comprometida em construir um futuro energeticamente
          eficiente e verde.
        </p>
        <a href="#" class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          Ver Vídeo
        </a>
      </div>

      <!-- 右侧四大优势区域 -->
      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <!-- 优势 1 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Equipa de I&amp;D Experiente</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Capacidade Sólida Apoiada por uma Equipa Altamente Qualificada e Experiente</p>
        </div>

        <!-- 优势 2 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Design Exclusivo</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Mais de 20 Patentes que Abrangem o Desenvolvimento e Fabrico de Produtos</p>
        </div>

        <!-- 优势 3 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Produtos Diversificados</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Gama Completa de Produtos para Diferentes Aplicações de Clientes</p>
        </div>

        <!-- 优势 4 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Qualidade Garantida</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Fabrico Certificado ISO que Garante os Mais Elevados Padrões de Qualidade</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="min-h-[calc(100vh-72px)] px-[clamp(24px,8vw,160px)] bg-[url('/assets/images/index-products-bg.webp')] bg-cover bg-center bg-no-repeat relative flex flex-col justify-center py-12" id="products">
    <div class="relative z-10">
      <div class="text-center mb-[clamp(16px,3vw,48px)] opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <h2 class="font-barlow-condensed text-[clamp(36px,4vw,72px)] font-bold uppercase tracking-[0.01em] leading-[1.1] mb-[clamp(4px,2vw,32px)]">Série de Produtos</h2>
        <div class="flex justify-center gap-1 mt-[clamp(8px,2vw,32px)] relative border-b border-border-light max-w-[740px] mx-auto">
          <div class="tab active text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap" data-product="ahf">Filtro Ativo de Harmónicos</div>
          <div class="tab text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap" data-product="svg">Gerador Estático de Reativos</div>
          <div class="tab text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap" data-product="avr">Regulador Automático de Tensão</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr_1fr] gap-[clamp(12px,3vw,48px)] items-start opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <!-- 左侧：文字介绍 -->
        <div class="min-h-[240px] relative">
          <div class="product-info-item active block" id="info-ahf">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">AHF</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">
              Filtros Ativos de Potência que cobrem de 208V a 800V, com eficiência até
              99%. Cobertura completa de aplicações para cenários industriais, comerciais
              e de utilidade pública.
            </p>
            <a href="#" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">Centro de Produtos &rarr;</a>
          </div>
          <div class="product-info-item hidden" id="info-svg">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">SVG</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">O Gerador Estático de Reativos CHITEK utiliza comutação IGBT avançada até 25,6 kHz para regular com precisão a magnitude e fase da tensão do inversor. Fornece compensação dinâmica de potência reativa e equilíbrio de carga trifásico com excecional precisão para aplicações industriais exigentes.</p>
            <a href="#" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">Centro de Produtos &rarr;</a>
          </div>
          <div class="product-info-item hidden" id="info-avr">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">AVR</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">O Regulador Automático de Tensão CHITEK mantém a tensão de saída dentro de ±1% apesar de variações de entrada até ±30%. Utiliza comutador de taps e controlo PWM avançados para proteger equipamentos críticos contra quedas, picos e subtensões em sistemas de 208V–480V em ambientes de rede instáveis.</p>
            <a href="#" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">Centro de Produtos &rarr;</a>
          </div>
        </div>

        <!-- 中间：功能特征网格 -->
        <div class="grid grid-cols-2 gap-px bg-border-light h-full">
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">Inteligente e Conveniente</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">Transferência de picos de carga, corte de picos e modulação de frequência, aumento de capacidade virtual e modo fora da rede.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">Alta Eficiência</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">Valor calórico ultrabaixo, baixo consumo em espera, eficiência até 98,5–99,2%. Tecnologia SiC.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">Compatibilidade Versátil</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">Compatível com padrões de tensão globais trifásicos 3-fios / 4-fios. Suporta filtragem ativa de harmónicos.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">Amigo das Baterias</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">Diferentes conjuntos de baterias funcionam independentemente, evitando corrente de circulação paralela.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">Manutenção Fácil</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">Quando um módulo está com defeito, não afeta os outros circuitos. Manutenção rápida em menos de 5 min.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">Seguro e Fiável</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">Funções completas de proteção contra falhas, sem corrente de circulação nas baterias, classificado para Nível de Poluição III.</div>
          </div>
        </div>

        <!-- 右侧：图片介绍 -->
        <div class="flex items-center justify-end">
          <div class="w-[clamp(220px,25vw,340px)] h-[clamp(300px,34vw,460px)] rounded-sm relative overflow-hidden bg-contain bg-center bg-no-repeat bg-[url('/assets/images/index-product-ahf.webp')]" id="product-visual"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const productData = {
      ahf: { visual: '/assets/images/index-product-ahf.webp', infoId: 'info-ahf' },
      svg: { visual: '/assets/images/index-product-svg.webp', infoId: 'info-svg' },
      avr: { visual: '/assets/images/index-product-avr.webp', infoId: 'info-avr' }
    };

    const tabs = document.querySelectorAll('.tab');
    const infoItems = document.querySelectorAll('.product-info-item');
    const productVisual = document.getElementById('product-visual');

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const key = this.getAttribute('data-product');
        const data = productData[key];

        // 1. 切换 Tab 样式
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');

        // 2. 切换左侧文字
        infoItems.forEach(item => {
          item.classList.remove('active', 'block');
          item.classList.add('hidden');
        });
        const target = document.getElementById(data.infoId);
        target.classList.remove('hidden');
        target.classList.add('active', 'block');

        // 3. 切换右侧图片
        productVisual.style.backgroundImage = `url('${data.visual}')`;
      });
    });
  </script>

  <style>
    .tab.active {
      color: #ff6b1a;
      border-bottom-color: #ff6b1a;
    }
  </style>

  <!-- SOLUTIONS -->
  <section class="min-h-[calc(100vh-72px)] px-[clamp(24px,8vw,160px)] bg-white flex flex-col py-12" id="solutions">
    <div class="text-center mb-[clamp(8px,1.5vw,24px)] opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h2 class="font-barlow-condensed text-[clamp(36px,4vw,72px)] font-bold uppercase tracking-[0.02em] mb-[clamp(4px,2vw,32px)]">Visão Geral das Soluções</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-y-6 md:gap-y-0 gap-x-[clamp(16px,3vw,48px)] w-full max-w-[1320px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <!-- Hospital -->
      <div class="group relative rounded-2xl overflow-hidden h-[clamp(400px,48vh,620px)] cursor-pointer hover:-translate-y-1.5 hover:shadow-2xl transition-all duration-300">
        <div class="absolute inset-0 w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105 bg-[url('/assets/images/index-solution-hospital.webp')]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/50 transition-[background] duration-300 group-hover:from-black/10 group-hover:to-black/60"></div>
        <div class="absolute inset-0 p-[clamp(16px,3vw,48px)] flex flex-col justify-between z-10">
          <div>
            <div class="w-14 h-14 mb-8">
              <svg viewBox="0 0 56 56" class="w-full h-full stroke-white stroke-[1.5] fill-none [stroke-linecap:round] [stroke-linejoin:round]">
                <path d="M12 20h32v28H12z"/>
                <path d="M8 20l20-12 20 12"/>
                <path d="M28 8v12"/>
                <rect x="20" y="28" width="6" height="6"/>
                <rect x="30" y="28" width="6" height="6"/>
                <rect x="20" y="36" width="6" height="6"/>
                <rect x="30" y="36" width="6" height="6"/>
              </svg>
            </div>
            <h3 class="text-[clamp(16px,1.4vw,22px)] font-bold leading-[1.3] mb-5 text-brand-orange capitalize min-h-[2.6em]">Elimine Harmónicos em Hospitais</h3>
            <p class="text-[clamp(11px,1vw,16px)] text-white/90 leading-[1.7]">Garanta uma qualidade de energia ininterrupta para equipamentos médicos críticos e sistemas de suporte de vida com filtragem avançada de harmónicos e estabilização de tensão.</p>
          </div>
          <a href="/solutions#commercial" class="text-[12px] font-semibold tracking-[0.08em] uppercase text-white no-underline inline-flex items-center gap-2 hover:text-brand-orange transition-colors duration-200 group/link">
              Saber mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 transition-transform duration-200 group-hover/link:translate-x-1">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
        </div>
      </div>

      <!-- Data Center -->
      <div class="group relative rounded-2xl overflow-hidden h-[clamp(400px,48vh,620px)] cursor-pointer hover:-translate-y-1.5 hover:shadow-2xl transition-all duration-300">
        <div class="absolute inset-0 w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105 bg-[url('/assets/images/index-solution-datacenter.webp')]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/50 transition-[background] duration-300 group-hover:from-black/10 group-hover:to-black/60"></div>
        <div class="absolute inset-0 p-[clamp(16px,3vw,48px)] flex flex-col justify-between z-10">
          <div>
            <div class="w-14 h-14 mb-8">
              <svg viewBox="0 0 56 56" class="w-full h-full stroke-white stroke-[1.5] fill-none [stroke-linecap:round] [stroke-linejoin:round]">
                <rect x="8" y="12" width="40" height="32" rx="2"/>
                <line x1="8" y1="22" x2="48" y2="22"/>
                <line x1="8" y1="32" x2="48" y2="32"/>
                <circle cx="16" cy="17" r="2"/>
                <circle cx="24" cy="17" r="2"/>
                <circle cx="32" cy="17" r="2"/>
                <path d="M20 26h16M20 36h16"/>
              </svg>
            </div>
