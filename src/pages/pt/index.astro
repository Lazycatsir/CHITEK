---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK INNOPOWER – Fabricante de Soluções de Qualidade de Energia',
  description: 'A CHITEK é líder em soluções de qualidade de energia de baixa tensão — Filtro Harmônico Ativo (AHF), Gerador Estático de Var (SVG) e Regulador Automático de Tensão (AVR) para aplicações industriais e comerciais.',
};
---
<BaseLayout lang="pt" title={meta.title} description={meta.description}>
  <!-- HERO -->
  <section id="hero-section" class="hero relative overflow-hidden mt-[72px] min-h-[calc(100vh-72px)] max-lg:min-h-[550px] max-md:min-h-[480px] flex items-center">
    <img src="/assets/images/index-hero-bg.webp" alt="Hero Background" class="absolute inset-0 w-full h-full object-cover object-[center_35%] max-lg:object-[center_25%] max-md:object-[center_15%] z-0 pointer-events-none" />

    <div class="flex flex-col justify-center px-16 max-md:px-6 py-20 max-md:py-16 relative z-10 max-w-page w-full mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h1 class="font-barlow-condensed text-[clamp(38px,4.5vw,62px)] font-bold leading-[1.1] text-white mb-5">
        <span class="text-brand-orange">Fabricante OEM Líder</span> de Soluções AHF e SVG de Baixa Tensão
      </h1>
      <p class="text-[16px] font-normal text-white/85 leading-[1.75] max-w-[560px] mb-9">
        Otimize a Qualidade de Energia para Maior Produtividade. Atendendo mais de 30 Países em Todo o Mundo.
      </p>
      <div class="flex gap-3.5 items-center">
        <a href="/pt/products" class="bg-brand-orange text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-brand-orange hover:bg-brand-orange-dark hover:border-brand-orange-dark transition-[background,border-color] duration-200">Ver Produtos</a>
        <a href="#about" class="text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-white/60 hover:bg-white/10 hover:border-white transition-all duration-200">Saiba Mais</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="relative overflow-hidden bg-bg-mid text-white min-h-screen flex flex-col justify-center" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center bg-no-repeat opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>

    <div class="relative z-10 text-center px-5 pt-6 pb-4 max-w-[900px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h2 class="font-barlow-condensed text-[clamp(36px,5vw,56px)] font-bold uppercase tracking-[0.02em] mb-4 text-white leading-[1.1]">APRESENTAÇÃO DA EMPRESA</h2>
    </div>

    <div class="relative z-10 flex flex-col md:flex-row max-w-page mx-auto max-md:mx-5 mb-6 bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <div class="flex-1 px-8 md:px-12 py-10 md:py-16 flex flex-col justify-center border-b md:border-b-0 md:border-r border-white/10">
        <h2 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-6 uppercase tracking-[0.02em] text-white">SOBRE A <span class="text-brand-orange">CHITEK</span></h2>
        <div class="w-10 h-[3px] bg-brand-orange mb-6"></div>
        <p class="text-[14px] leading-[1.8] text-white/75 mb-8">
          Shenzhen CHITEK New Energy Technology Co., Ltd., fundada em 2019 e
          sediada em Shenzhen, é uma empresa de alta tecnologia especializada em
          pesquisa, desenvolvimento, fabricação e serviços de produtos
          eletrônicos de potência. Comprometida em construir um futuro
          energeticamente eficiente e verde.
        </p>
        <a href="#" class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          Assistir Vídeo
        </a>
      </div>

      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <div class="px-8 py-12 flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[15px] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Equipe P&amp;D Experiente</h3>
          <p class="text-[12px] leading-[1.6] text-white max-w-[180px]">Capacidade robusta apoiada por equipe bem-educada e altamente experiente</p>
        </div>

        <div class="px-8 py-12 flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[15px] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Design Proprietário</h3>
          <p class="text-[12px] leading-[1.6] text-white max-w-[180px]">Mais de 20 Patentes cobrindo Desenvolvimento de Produtos e Fabricação</p>
        </div>

        <div class="px-8 py-12 flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[15px] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Produtos Diversificados</h3>
          <p class="text-[12px] leading-[1.6] text-white max-w-[180px]">Linha completa de produtos para diferentes aplicações de clientes</p>
        </div>

        <div class="px-8 py-12 flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[15px] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Qualidade Garantida</h3>
          <p class="text-[12px] leading-[1.6] text-white max-w-[180px]">Fabricação certificada ISO garantindo os mais altos padrões de qualidade</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="py-24 px-16 max-md:px-6 bg-[url('/assets/images/index-products-bg.webp')] bg-cover bg-center bg-no-repeat relative" id="products">
    <div class="relative z-10">
      <div class="text-center mb-16 opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <h2 class="font-barlow-condensed text-[clamp(36px,4vw,52px)] font-bold uppercase tracking-[0.01em] leading-[1.1] mb-3">Linha de Produtos</h2>
        <div class="flex justify-center gap-1 mt-8 relative border-b border-border-light max-w-[560px] mx-auto">
          <div class="tab active text-[14px] font-medium text-text-muted px-6 py-3 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange" data-product="ahf">Filtro Harmônico Ativo</div>
          <div class="tab text-[14px] font-medium text-text-muted px-6 py-3 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange" data-product="svg">Gerador Estático de Var</div>
          <div class="tab text-[14px] font-medium text-text-muted px-6 py-3 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange" data-product="avr">Regulador Automático de Tensão</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr_340px] gap-8 items-start opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <div class="min-h-[240px] relative">
          <div class="product-info-item active block" id="info-ahf">
            <h3 class="font-barlow-condensed text-[28px] font-bold uppercase mb-2">AHF</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">
              Filtros de Potência Ativos cobrindo 208V a 800V, com eficiência de até
              99%. Cobertura completa para aplicações industriais, comerciais e
              de utilidades.
            </p>
            <a href="/pt/products" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">Central de Produtos &rarr;</a>
          </div>
          <div class="product-info-item hidden" id="info-svg">
            <h3 class="font-barlow-condensed text-[28px] font-bold uppercase mb-2">SVG</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">O Gerador Estático de Var CHITEK utiliza comutação IGBT avançada de até 25,6kHz para regular com precisão a magnitude e fase da tensão do inversor. Fornece compensação dinâmica de reativos e balanceamento de carga trifásico com excepcional precisão para aplicações industriais exigentes.</p>
            <a href="/pt/products" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">Central de Produtos &rarr;</a>
          </div>
          <div class="product-info-item hidden" id="info-avr">
            <h3 class="font-barlow-condensed text-[28px] font-bold uppercase mb-2">AVR</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">O Regulador Automático de Tensão CHITEK mantém a tensão de saída dentro de ±1% apesar de variações de entrada de até ±30%. Utiliza comutador de tap e controle PWM avançados para proteger equipamentos críticos contra quedas, picos e subtensões em sistemas de 208V–480V em redes instáveis.</p>
            <a href="/pt/products" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">Central de Produtos &rarr;</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-px bg-border-light h-full">
          <div class="bg-white p-6 cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[13px] font-semibold text-brand-orange mb-2">Inteligente e Conveniente</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[13px] text-text-muted leading-[1.6]">Deslocamento de pico, redução de pico e modulação de frequência, aumento virtual de capacidade e modo off-grid.</div>
          </div>
          <div class="bg-white p-6 cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[13px] font-semibold text-brand-orange mb-2">Alta Eficiência</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[13px] text-text-muted leading-[1.6]">Valor calórico ultrabaixo, baixo consumo em espera, eficiência de até 98,5–99,2%. Tecnologia SiC.</div>
          </div>
          <div class="bg-white p-6 cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[13px] font-semibold text-brand-orange mb-2">Compatibilidade Versátil</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[13px] text-text-muted leading-[1.6]">Compatível com padrões globais de tensão trifásico 3-fios / 4-fios. Suporta filtragem harmônica ativa.</div>
          </div>
          <div class="bg-white p-6 cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[13px] font-semibold text-brand-orange mb-2">Amigável com Baterias</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[13px] text-text-muted leading-[1.6]">Diferentes conjuntos de baterias funcionam de forma independente, evitando corrente de circulação paralela.</div>
          </div>
          <div class="bg-white p-6 cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[13px] font-semibold text-brand-orange mb-2">Fácil Manutenção</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[13px] text-text-muted leading-[1.6]">Quando um módulo falha, não afeta outros circuitos. Manutenção rápida em até 5 minutos.</div>
          </div>
          <div class="bg-white p-6 cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[13px] font-semibold text-brand-orange mb-2">Seguro e Confiável</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[13px] text-text-muted leading-[1.6]">Funções completas de proteção contra falhas, sem corrente de circulação na bateria, Grau de Poluição III.</div>
          </div>
        </div>

        <div class="flex items-center justify-end">
          <div class="w-[340px] h-[460px] rounded-sm relative overflow-hidden bg-contain bg-center bg-no-repeat bg-[url('/assets/images/index-product-ahf.webp')]" id="product-visual"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const productData = {
      ahf: { visual: '/assets/images/index-product-ahf.webp', infoId: 'info-ahf' },
      svg: { visual: '/assets/images/index-product-svg.webp', infoId: 'info-svg' },
      avr: { visual: '/assets/images/index-product-avr.webp', infoId: 'info-avr' }
    };

    const tabs = document.querySelectorAll('.tab');
    const infoItems = document.querySelectorAll('.product-info-item');
    const productVisual = document.getElementById('product-visual');

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const key = this.getAttribute('data-product');
        const data = productData[key];

        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');

        infoItems.forEach(item => {
          item.classList.remove('active', 'block');
          item.classList.add('hidden');
        });
        const target = document.getElementById(data.infoId);
        target.classList.remove('hidden');
        target.classList.add('active', 'block');

        productVisual.style.backgroundImage = `url('${data.visual}')`;
      });
    });
  </script>

  <!-- SOLUTIONS -->
  <section class="py-24 px-16 max-md:px-6 bg-white" id="solutions">
    <div class="text-center mb-14 opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h2 class="font-barlow-condensed text-[clamp(28px,3vw,42px)] font-bold uppercase tracking-[0.02em] mb-2.5">Soluções</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <!-- Hospital -->
      <div class="group relative rounded overflow-hidden h-[520px] cursor-pointer hover:-translate-y-1.5 hover:shadow-2xl transition-all duration-300">
        <div class="absolute inset-0 w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105 bg-[url('/assets/images/index-solution-hospital.webp')]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/50 transition-[background] duration-300 group-hover:from-black/10 group-hover:to-black/60"></div>
        <div class="absolute inset-0 p-10 flex flex-col z-10">
          <div class="w-14 h-14 mb-6">
            <svg viewBox="0 0 56 56" class="w-full h-full stroke-white stroke-[1.5] fill-none [stroke-linecap:round] [stroke-linejoin:round]">
              <path d="M12 20h32v28H12z"/>
              <path d="M8 20l20-12 20 12"/>
              <path d="M28 8v12"/>
              <rect x="20" y="28" width="6" height="6"/>
              <rect x="30" y="28" width="6" height="6"/>
              <rect x="20" y="36" width="6" height="6"/>
              <rect x="30" y="36" width="6" height="6"/>
            </svg>
          </div>
          <div class="mt-auto">
            <h3 class="text-[20px] font-bold leading-[1.3] mb-3 text-brand-orange capitalize">Elimine Harmônicos em Hospitais</h3>
            <p class="text-[14px] text-white/90 leading-[1.7] mb-5">Garanta qualidade de energia ininterrupta para equipamentos médicos críticos e sistemas de suporte à vida com filtragem harmônica avançada e estabilização de tensão.</p>
            <a href="/pt/solutions#commercial" class="text-[12px] font-semibold tracking-[0.08em] uppercase text-white no-underline inline-flex items-center gap-2 hover:text-brand-orange transition-colors duration-200 group/link">
              Saiba Mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 transition-transform duration-200 group-hover/link:translate-x-1">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Data Center -->
      <div class="group relative rounded overflow-hidden h-[520px] cursor-pointer hover:-translate-y-1.5 hover:shadow-2xl transition-all duration-300">
        <div class="absolute inset-0 w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105 bg-[url('/assets/images/index-solution-datacenter.webp')]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/50 transition-[background] duration-300 group-hover:from-black/10 group-hover:to-black/60"></div>
        <div class="absolute inset-0 p-10 flex flex-col z-10">
          <div class="w-14 h-14 mb-6">
            <svg viewBox="0 0 56 56" class="w-full h-full stroke-white stroke-[1.5] fill-none [stroke-linecap:round] [stroke-linejoin:round]">
              <rect x="8" y="12" width="40" height="32" rx="2"/>
              <line x1="8" y1="22" x2="48" y2="22"/>
              <line x1="8" y1="32" x2="48" y2="32"/>
              <circle cx="16" cy="17" r="2"/>
              <circle cx="24" cy="17" r="2"/>
              <circle cx="32" cy="17" r="2"/>
              <path d="M20 26h16M20 36h16"/>
            </svg>
          </div>
          <div class="mt-auto">
            <h3 class="text-[20px] font-bold leading-[1.3] mb-3 text-brand-orange capitalize">Evite Multas de FP em Data Centers</h3>
            <p class="text-[14px] text-white/90 leading-[1.7] mb-5">Sustentáveis, autônomos e onipresentes, alimentando a IA para ajudar a resolver os problemas atuais com infraestrutura confiável de qualidade de energia.</p>
            <a href="/pt/solutions#datacenter" class="text-[12px] font-semibold tracking-[0.08em] uppercase text-white no-underline inline-flex items-center gap-2 hover:text-brand-orange transition-colors duration-200 group/link">
              Saiba Mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 transition-transform duration-200 group-hover/link:translate-x-1">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Manufacturing -->
      <div class="group relative rounded overflow-hidden h-[520px] cursor-pointer hover:-translate-y-1.5 hover:shadow-2xl transition-all duration-300">
        <div class="absolute inset-0 w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105 bg-[url('/assets/images/index-solution-manufacturing.webp')]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/50 transition-[background] duration-300 group-hover:from-black/10 group-hover:to-black/60"></div>
        <div class="absolute inset-0 p-10 flex flex-col z-10">
          <div class="w-14 h-14 mb-6">
            <svg viewBox="0 0 56 56" class="w-full h-full stroke-white stroke-[1.5] fill-none [stroke-linecap:round] [stroke-linejoin:round]">
              <path d="M12 16h32v28H12z"/>
              <path d="M20 16V8l8 4 8-4v8"/>
              <rect x="18" y="22" width="8" height="8"/>
              <rect x="30" y="22" width="8" height="8"/>
              <rect x="18" y="34" width="8" height="6"/>
              <rect x="30" y="34" width="8" height="6"/>
            </svg>
          </div>
          <div class="mt-auto">
            <h3 class="text-[20px] font-bold leading-[1.3] mb-3 text-brand-orange capitalize">Estabilize a Tensão na Indústria</h3>
            <p class="text-[14px] text-white/90 leading-[1.7] mb-5">Soluções inteligentes, autônomas e capazes de se adaptar instantaneamente com soluções inteligentes de qualidade de energia que otimizam a eficiência da produção.</p>
            <a href="/pt/solutions#industry" class="text-[12px] font-semibold tracking-[0.08em] uppercase text-white no-underline inline-flex items-center gap-2 hover:text-brand-orange transition-colors duration-200 group/link">
              Saiba Mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 transition-transform duration-200 group-hover/link:translate-x-1">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
