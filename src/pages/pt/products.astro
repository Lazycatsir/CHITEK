                          <th class="p-3 text-left text-text-dark font-semibold">CHITEK SVG</th>
                          <th class="p-3 text-left text-text-dark font-semibold">Banco de Capacitores</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr class="border-b border-border-light">
                          <td class="p-3 text-text-dark">Tempo de Resposta</td>
                          <td class="p-3 text-text-dim">&lt;10ms</td>
                          <td class="p-3 text-text-dim">1-5 ciclos (20-100ms)</td>
                        </tr>
                        <tr class="border-b border-border-light">
                          <td class="p-3 text-text-dark">Tipo de Compensação</td>
                          <td class="p-3 text-text-dim">Contínua, suave</td>
                          <td class="p-3 text-text-dim">Escalonada, discreta</td>
                        </tr>
                        <tr class="border-b border-border-light">
                          <td class="p-3 text-text-dark">Risco de Ressonância</td>
                          <td class="p-3 text-text-dim">Nenhum (injeção ativa)</td>
                          <td class="p-3 text-text-dim">Alto (formação de circuito LC)</td>
                        </tr>
                        <tr>
                          <td class="p-3 text-text-dark">Filtragem Harmônica</td>
