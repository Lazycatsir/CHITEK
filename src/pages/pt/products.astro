    // ===== Case Carousel =====
    let caseIndex = 0;
    const caseTrack = document.getElementById('case-track');
    const caseSlides = document.querySelectorAll('#case-carousel .case-slide');
    const totalSlides = caseSlides.length;
    const dots = document.querySelectorAll('#case-dots .carousel-dot');

    function goToCase(idx) {
      caseIndex = idx;
      if (caseIndex < 0) caseIndex = totalSlides - 1;
      if (caseIndex >= totalSlides) caseIndex = 0;
      const slideWidth = caseSlides[0].offsetWidth;
      caseTrack.style.transform = 'translateX(-' + (caseIndex * slideWidth) + 'px)';
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === caseIndex);
        if (i === caseIndex) {
          d.style.background = '#ff4d00';
          d.style.width = '24px';
          d.style.borderRadius = '4px';
        } else {
          d.style.background = '#d1d5db';
          d.style.width = '8px';
          d.style.borderRadius = '50%';
        }
      });
    }

    document.getElementById('case-prev').addEventListener('click', () => goToCase(caseIndex - 1));
    document.getElementById('case-next').addEventListener('click', () => goToCase(caseIndex + 1));
    dots.forEach(d => {
      d.addEventListener('click', () => goToCase(parseInt(d.dataset.slide)));
    });

    // Auto-play
    setInterval(() => goToCase(caseIndex + 1), 6000);

    // Touch swipe
    let touchStartX = 0;
    const carousel = document.getElementById('case-carousel');
    carousel.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goToCase(diff > 0 ? caseIndex + 1 : caseIndex - 1);
    }, { passive: true });

    window.addEventListener('resize', () => goToCase(caseIndex));

    // ===== SVG Case Carousel =====
    let svgCaseIndex = 0;
    const svgCaseTrack = document.getElementById('case-track-svg');
    const svgCaseSlides = document.querySelectorAll('#case-carousel-svg .case-slide');
    const svgTotalSlides = svgCaseSlides.length;
    const svgDots = document.querySelectorAll('#case-dots-svg .carousel-dot');

    function goToSvgCase(idx) {
      svgCaseIndex = idx;
      if (svgCaseIndex < 0) svgCaseIndex = svgTotalSlides - 1;
      if (svgCaseIndex >= svgTotalSlides) svgCaseIndex = 0;
      const slideWidth = svgCaseSlides[0].offsetWidth;
      svgCaseTrack.style.transform = 'translateX(-' + (svgCaseIndex * slideWidth) + 'px)';
      svgDots.forEach((d, i) => {
        d.classList.toggle('active', i === svgCaseIndex);
        if (i === svgCaseIndex) {
          d.style.background = '#ff4d00';
          d.style.width = '24px';
          d.style.borderRadius = '4px';
        } else {
          d.style.background = '#d1d5db';
          d.style.width = '8px';
          d.style.borderRadius = '50%';
        }
      });
    }

    document.getElementById('case-prev-svg').addEventListener('click', () => goToSvgCase(svgCaseIndex - 1));
    document.getElementById('case-next-svg').addEventListener('click', () => goToSvgCase(svgCaseIndex + 1));
    svgDots.forEach(d => {
      d.addEventListener('click', () => goToSvgCase(parseInt(d.dataset.slide)));
    });

    setInterval(() => goToSvgCase(svgCaseIndex + 1), 6000);

    let svgTouchStartX = 0;
    const svgCarousel = document.getElementById('case-carousel-svg');
    svgCarousel.addEventListener('touchstart', e => { svgTouchStartX = e.touches[0].clientX; }, { passive: true });
    svgCarousel.addEventListener('touchend', e => {
      const diff = svgTouchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goToSvgCase(diff > 0 ? svgCaseIndex + 1 : svgCaseIndex - 1);
    }, { passive: true });

