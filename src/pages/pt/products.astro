---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK — Fabricante de AHF, SVG e AVR de Baixa Tensão | Soluções de Qualidade de Energia',
  description: 'A CHITEK oferece Filtro Harmônico Ativo (AHF), Gerador Estático de Var (SVG), AHF/SVG SiC e Regulador Automático de Tensão (AVR) para correção da qualidade de energia em baixa tensão.',
};
---

<BaseLayout lang="pt" title={meta.title} description={meta.description}>
  <!-- Sticky Tab Bar (visible after scrolling past hero) -->
  <div id="sticky-tab-bar" class="sticky top-[72px] z-40 transition-all duration-[400ms] bg-white border-b-2 border-border-light shadow-[0_2px_16px_rgba(0,0,0,0.08)] opacity-0 -translate-y-2 pointer-events-none h-0 overflow-hidden">
    <div class="max-w-page mx-auto px-6 lg:px-10">
      <div class="flex items-center justify-center gap-0 md:gap-4 overflow-x-auto">
        <button class="sticky-hero-tab text-sm font-semibold whitespace-nowrap px-5 py-3 rounded-lg transition-all duration-200 relative text-white bg-brand-orange shadow-sm" data-tab="0"><span class="font-barlow-condensed">Filtro Harmônico Ativo</span></button>
        <button class="sticky-hero-tab text-sm font-semibold whitespace-nowrap px-5 py-3 rounded-lg transition-all duration-200 relative text-[#374151] hover:text-brand-orange hover:bg-orange-50" data-tab="1"><span class="font-barlow-condensed">Gerador Estático de Var</span></button>
        <button class="sticky-hero-tab text-sm font-semibold whitespace-nowrap px-5 py-3 rounded-lg transition-all duration-200 relative text-[#374151] hover:text-brand-orange hover:bg-orange-50" data-tab="2"><span class="font-barlow-condensed">Regulador Automático de Tensão</span></button>
      </div>
    </div>
  </div>

  <!-- Hero Section -->
  <section id="hero" class="relative w-full overflow-hidden min-h-[70vh] mt-[72px] flex items-center justify-center" style="background:url('/assets/images/products-hero-bg.jpg') center/cover no-repeat">
    <canvas id="hero-canvas" class="absolute inset-0 z-[1] pointer-events-none"></canvas>
    <div class="relative z-[2]">
      <div class="text-center">
        <h1 id="hero-title" class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-tight mb-6 hero-fade font-barlow-condensed text-brand-orange">
          Produtos Excelentes
        </h1>
        <p id="hero-subtitle" class="text-[clamp(1.1rem,2vw,1.5rem)] text-white/90 hero-fade max-w-2xl mx-auto">Soluções avançadas de qualidade de energia para aplicações industriais e comerciais.</p>
        <div class="flex items-center justify-center gap-4 mt-8 opacity-0 animate-[decorIn_0.8s_0.6s_ease_forwards]">
          <div class="h-px w-16 bg-gradient-to-r from-transparent to-brand-orange/60"></div>
          <div class="w-2 h-2 rotate-45 border border-brand-orange/60"></div>
          <div class="h-px w-16 bg-gradient-to-r from-brand-orange/60 to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proposta de Valor -->
  <section id="value-prop" class="relative min-h-screen py-20 lg:py-28 overflow-hidden" style="background:url('/assets/images/products-hero.png') center/cover no-repeat">
    <canvas id="vp-canvas" class="absolute inset-0 z-[1] pointer-events-none"></canvas>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0f1117]/10 via-[#161b22]/10 to-[#0d1117]/10 z-[2]"></div>
    <!-- Tab 0: AHF -->
    <div class="tab-panel relative z-[3]" data-tab="0">
      <div class="max-w-page mx-auto px-4 lg:px-[180px] relative">
        <div class="text-center mb-16 reveal">
          <p class="text-brand-orange text-base font-medium tracking-widest uppercase mb-3 font-barlow-condensed">Proposta de Valor</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text-dark font-barlow-condensed">Problemas e Soluções</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24">
          <div class="vp-card bg-[rgba(255,255,255,0.04)] border border-white/10 p-8 reveal shadow-sm backdrop-blur-sm">
            <div class="w-12 h-12 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-text-dark mb-3">Flutuação de Tensão</h3>
            <p class="text-text-dark text-sm leading-relaxed">Paradas inesperadas de equipamentos, perda de dados e interrupções na linha de produção causadas por tensão instável da rede elétrica.</p>
          </div>
          <div class="vp-card bg-[rgba(255,255,255,0.04)] border border-white/10 rounded-lg p-8 reveal shadow-sm backdrop-blur-sm" style="transition-delay:100ms">
            <div class="w-12 h-12 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h20M2 12c0-5 4-9 9-9s9 4 9 9M2 12c0 5 4 9 9 9s9-4 9-9"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-text-dark mb-3">Distorção Harmônica</h3>
            <p class="text-text-dark text-sm leading-relaxed">Superaquecimento de transformadores, perdas adicionais em cabos e mau funcionamento de equipamentos de precisão devido à poluição harmônica.</p>
          </div>
          <div class="vp-card bg-[rgba(255,255,255,0.04)] border border-white/10 rounded-lg p-8 reveal shadow-sm backdrop-blur-sm" style="transition-delay:200ms">
            <div class="w-12 h-12 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M6 12h.01M6 16h.01M10 8h8M10 12h5M10 16h7"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-text-dark mb-3">Multas por Fator de Potência</h3>
            <p class="text-text-dark text-sm leading-relaxed">Custos ocultos crescentes nas faturas de eletricidade, com concessionárias cobrando taxas extras por baixo fator de potência.</p>
          </div>
        </div>

        <!-- Tech Roadmap -->
        <div class="relative reveal">
          <p class="text-center text-sm text-text-dark mb-8 tracking-widest uppercase font-barlow-condensed">Fluxo do Processo Técnico</p>
          <div class="relative flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
            <div class="hidden md:block absolute top-[28px] left-[12%] right-[12%] h-px bg-white/10"></div>
            <div class="md:hidden absolute left-[28px] top-[12%] bottom-[12%] w-px bg-white/10"></div>
            <div class="hidden md:block absolute -bottom-8 left-[12%] right-[12%]">
              <svg width="100%" height="30" viewBox="0 0 800 30" preserveAspectRatio="none"><path d="M 0 25 Q 400 5 800 25" fill="none" stroke="rgba(255,107,26,0.4)" stroke-width="1" stroke-dasharray="4 4"/><polygon points="790,22 800,28 790,28" fill="rgba(255,107,26,0.5)"/></svg>
              <p class="text-center text-xs text-brand-orange/70 mt-1 font-barlow-condensed">Controle em malha fechada, resposta &lt;50&mu;s</p>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Amostragem V/I trifásica&#10;128 pontos/ciclo">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">01</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Amostragem da Rede</p></div>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Detecção de harmônicas 2ª-50ª&#10;Análise espectral em tempo real">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">02</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Análise FFT</p></div>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Frequência de Comutação >20kHz&#10;Redução de perdas 30%">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">03</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Inversão SiC/IGBT</p></div>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Resposta &lt;50&mu;s&#10;Injeção em malha fechada em tempo real">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">04</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Injeção de Harmônicos</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: SVG -->
    <div class="tab-panel hidden relative z-[3]" data-tab="1">
      <div class="max-w-page mx-auto px-4 lg:px-[180px] relative">
        <div class="text-center mb-16 reveal">
          <p class="text-brand-orange text-base font-medium tracking-widest uppercase mb-3 font-barlow-condensed">Proposta de Valor</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text-dark font-barlow-condensed">Problemas e Soluções</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24">
          <div class="vp-card bg-[rgba(255,255,255,0.04)] border border-white/10 p-8 reveal shadow-sm backdrop-blur-sm">
            <div class="w-12 h-12 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-text-dark mb-3">Deficiência de Potência Reativa</h3>
            <p class="text-text-dark text-sm leading-relaxed">Baixo fator de potência causa sobrecarga do transformador, perdas em linhas e multas de concessionárias para cargas industriais.</p>
          </div>
          <div class="vp-card bg-[rgba(255,255,255,0.04)] border border-white/10 rounded-lg p-8 reveal shadow-sm backdrop-blur-sm" style="transition-delay:100ms">
            <div class="w-12 h-12 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h20M2 12c0-5 4-9 9-9s9 4 9 9M2 12c0 5 4 9 9 9s9-4 9-9"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-text-dark mb-3">Cintilação e Afundamento de Tensão</h3>
            <p class="text-text-dark text-sm leading-relaxed">Mudanças súbitas de carga causam quedas e cintilação de tensão, afetando equipamentos sensíveis e a qualidade do produto.</p>
          </div>
          <div class="vp-card bg-[rgba(255,255,255,0.04)] border border-white/10 rounded-lg p-8 reveal shadow-sm backdrop-blur-sm" style="transition-delay:200ms">
            <div class="w-12 h-12 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M6 12h.01M6 16h.01M10 8h8M10 12h5M10 16h7"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-text-dark mb-3">Problemas com Bancos de Capacitores</h3>
            <p class="text-text-dark text-sm leading-relaxed">Bancos de capacitores tradicionais não acompanham cargas dinâmicas, causando sobre/subcompensação e risco de ressonância.</p>
          </div>
        </div>

        <!-- Fluxo de Compensação SVG -->
        <div class="relative reveal">
          <p class="text-center text-sm text-text-dark mb-8 tracking-widest uppercase font-barlow-condensed">Fluxo de Compensação SVG</p>
          <div class="relative flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
            <div class="hidden md:block absolute top-[28px] left-[12%] right-[12%] h-px bg-white/10"></div>
            <div class="md:hidden absolute left-[28px] top-[12%] bottom-[12%] w-px bg-white/10"></div>
            <div class="hidden md:block absolute -bottom-8 left-[12%] right-[12%]">
              <svg width="100%" height="30" viewBox="0 0 800 30" preserveAspectRatio="none"><path d="M 0 25 Q 400 5 800 25" fill="none" stroke="rgba(255,107,26,0.4)" stroke-width="1" stroke-dasharray="4 4"/><polygon points="790,22 800,28 790,28" fill="rgba(255,107,26,0.5)"/></svg>
              <p class="text-center text-xs text-brand-orange/70 mt-1 font-barlow-condensed">Resposta total &lt;10ms, malha fechada em tempo real</p>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Amostragem V/I trifásica&#10;128 pontos/ciclo">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">01</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Amostragem da Rede</p></div>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Cálculo de potência reativa&#10;Análise FP em tempo real">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">02</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Análise Q/FP</p></div>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Comutação IGBT >15kHz&#10;Design sem capacitor">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">03</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Inversão IGBT</p></div>
            </div>
            <div class="relative flex md:flex-col items-center md:text-center gap-4 md:gap-0 w-full md:w-auto z-10">
              <div class="w-14 h-14 rounded-full bg-white/[0.08] backdrop-blur-sm border border-brand-orange/30 flex items-center justify-center flex-shrink-0 tooltip-trigger" data-tip="Resposta &lt;10ms&#10;Saída contínua em tempo real">
                <span class="text-brand-orange font-bold text-sm font-barlow-condensed">04</span>
              </div>
              <div class="md:mt-4"><p class="text-text-dark text-sm font-medium">Injeção de Var</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tooltip (shared) -->
    <div id="roadmap-tooltip" class="fixed z-50 px-4 py-2 bg-text-dark border border-brand-orange/30 rounded text-xs text-brand-orange whitespace-pre-line pointer-events-none hidden font-barlow-condensed shadow-lg"></div>
  </section>

  <!-- Características Principais -->
  <section id="features" class="relative py-16 lg:py-20 overflow-hidden" style="background: linear-gradient(rgba(0,0,0,0.72), rgba(0,0,0,0.72)), url('/assets/images/products-key-features.jpg') center/cover no-repeat">
    <!-- Tab 0: AHF -->
    <div class="tab-panel" data-tab="0">
      <div class="max-w-page mx-auto px-4 lg:px-[180px]">
        <div class="text-left mb-16 reveal">
          <p class="text-brand-orange text-sm font-medium tracking-widest uppercase mb-3 font-barlow-condensed">Características Principais</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white/90 font-barlow-condensed">Vantagens da Tecnologia Central</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal">
          <div class="feat-card bg-[rgba(0,0,0,0.45)] border border-brand-orange/40 rounded-lg p-6">
            <div class="w-10 h-10 rounded-lg bg-brand-orange/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9zM9 15h6M15 9v6"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-white/90 mb-4">Tecnologia SiC</h3>
            <svg viewBox="0 0 200 120" class="w-full h-24 mb-4">
              <rect x="10" y="20" width="80" height="80" rx="4" fill="none" stroke="#ff4d00" stroke-width="1" opacity="0.5"/>
              <rect x="20" y="30" width="25" height="25" rx="2" fill="#ff4d00" opacity="0.6"/>
              <rect x="55" y="30" width="25" height="25" rx="2" fill="#ff4d00" opacity="0.4"/>
              <rect x="20" y="65" width="25" height="25" rx="2" fill="#ff4d00" opacity="0.3"/>
              <rect x="55" y="65" width="25" height="25" rx="2" fill="#ff4d00" opacity="0.5"/>
              <line x1="100" y1="60" x2="130" y2="60" stroke="#ff4d00" stroke-width="1" opacity="0.3"/>
              <rect x="130" y="20" width="60" height="80" rx="4" fill="none" stroke="#9ca3af" stroke-width="1" opacity="0.3"/>
              <rect x="140" y="35" width="40" height="15" rx="2" fill="#ff4d00" opacity="0.15"/>
              <rect x="140" y="60" width="40" height="15" rx="2" fill="#ff4d00" opacity="0.1"/>
              <text x="100" y="115" text-anchor="middle" fill="#ff4d00" font-size="10" font-family="Barlow, sans-serif">SiC vs IGBT</text>
            </svg>
            <p class="text-xs text-white/70 leading-relaxed">Frequência de comutação &gt;20kHz, redução de perdas 30%</p>
          </div>
          <div class="feat-card bg-[rgba(0,0,0,0.45)] border border-brand-orange/40 rounded-lg p-6" style="transition-delay:150ms">
            <div class="w-10 h-10 rounded-lg bg-brand-orange/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-white/90 mb-4">Anti-Ressonância</h3>
            <svg viewBox="0 0 200 120" class="w-full h-24 mb-4">
              <path d="M10 80 Q 55 20, 100 60 T 190 40" fill="none" stroke="#ff4d00" stroke-width="1.5" opacity="0.6"/>
              <path d="M10 90 Q 55 40, 100 75 T 190 55" fill="none" stroke="#ff4d00" stroke-width="1" opacity="0.3"/>
              <rect x="75" y="15" width="50" height="55" rx="4" fill="none" stroke="#ff4d00" stroke-width="1" opacity="0.4"/>
              <path d="M85 45 L95 55 L115 35" fill="none" stroke="#ff4d00" stroke-width="2"/>
              <text x="100" y="115" text-anchor="middle" fill="#ff4d00" font-size="10" font-family="Barlow, sans-serif">AMORTECIDO 5ª/7ª</text>
            </svg>
            <p class="text-xs text-white/70 leading-relaxed">Amortecimento adaptativo, evita amplificação de ressonância 5ª/7ª</p>
          </div>
          <div class="feat-card bg-[rgba(0,0,0,0.45)] border border-brand-orange/40 rounded-lg p-6" style="transition-delay:300ms">
            <div class="w-10 h-10 rounded-lg bg-brand-orange/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v18M16 3v18M4 8h16M4 16h16"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-white/90 mb-4">Ultracompactoo</h3>
            <svg viewBox="0 0 200 120" class="w-full h-24 mb-4">
              <rect x="30" y="30" width="60" height="70" rx="2" fill="none" stroke="#9ca3af" stroke-width="1" opacity="0.3"/>
              <text x="60" y="22" text-anchor="middle" fill="#9ca3af" font-size="8" font-family="Barlow, sans-serif">100mm+</text>
              <rect x="110" y="55" width="60" height="45" rx="2" fill="none" stroke="#ff4d00" stroke-width="1.5" opacity="0.7"/>
              <text x="140" y="48" text-anchor="middle" fill="#ff4d00" font-size="8" font-family="Barlow, sans-serif">U-Series 45mm</text>
              <line x1="110" y1="65" x2="170" y2="65" stroke="#ff4d00" stroke-width="0.5" opacity="0.3" stroke-dasharray="2 2"/>
              <text x="100" y="115" text-anchor="middle" fill="#ff4d00" font-size="10" font-family="Barlow, sans-serif">55% ECONOMIA DE ESPAÇO</text>
            </svg>
            <p class="text-xs text-white/70 leading-relaxed">Economia de espaço vs modelos de gabinete tradicionais 100mm+</p>
          </div>
          <div class="feat-card bg-[rgba(0,0,0,0.45)] border border-brand-orange/40 rounded-lg p-6" style="transition-delay:450ms">
            <div class="w-10 h-10 rounded-lg bg-brand-orange/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="16" height="10" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/><path d="M6 10v4M9 10v4M12 10v4M15 10v4"/></svg>
