<script>

    // ===== Hero Canvas Waveform =====
    const canvas = document.getElementById('hero-canvas');
    const ctx = canvas.getContext('2d');
    let mouse = { x: 0.5, y: 0.5 };
    let time = 0;
    let rafId;

    function resizeCanvas() {
      const hero = document.getElementById('hero');
      canvas.width = hero.offsetWidth;
      canvas.height = hero.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);
    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX / window.innerWidth;
      mouse.y = e.clientY / window.innerHeight;
    }, { passive: true });

    function drawWaveform() {
      time += 0.008;
      const w = canvas.width, h = canvas.height;
      const mx = mouse.x, my = mouse.y;
      ctx.clearRect(0, 0, w, h);

      // Grid
      ctx.strokeStyle = 'rgba(255, 77, 0, 0.04)';
      ctx.lineWidth = 1;
      const gs = 60;
      for (let x = 0; x < w; x += gs) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke(); }
      for (let y = 0; y < h; y += gs) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke(); }

      // Waves
      const waves = [
        { freq: 1.5, amp: 40, speed: 1, alpha: 0.3, yOff: 0 },
        { freq: 2.5, amp: 25, speed: 1.3, alpha: 0.2, yOff: 80 },
        { freq: 0.8, amp: 55, speed: 0.7, alpha: 0.25, yOff: -60 },
        { freq: 3.2, amp: 15, speed: 1.8, alpha: 0.15, yOff: 120 },
      ];
      const cy = h * 0.55;
      waves.forEach(wave => {
        ctx.beginPath();
        ctx.strokeStyle = 'rgba(255, 77, 0, ' + wave.alpha + ')';
        ctx.lineWidth = 2;
        for (let x = 0; x < w; x += 2) {
          const nx = x / w;
          const md = Math.sqrt((nx - mx) * (nx - mx) + ((cy + wave.yOff) / h - my) * ((cy + wave.yOff) / h - my));
          const mf = Math.max(0, 1 - md * 3) * 30;
          const y = cy + wave.yOff + Math.sin(x * wave.freq * 0.003 + time * wave.speed) * wave.amp + Math.sin(x * 0.008 + time * 0.5) * 10 + mf * Math.sin(x * 0.01 + time);
          if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        ctx.stroke();
      });

      // Pulse dots
      for (let i = 0; i < 8; i++) {
        const px = ((i / 8 + time * 0.05) % 1) * w;
        const py = cy + Math.sin(px * 0.005 + time) * 40;
        const ps = 2 + Math.sin(time * 3 + i) * 1;
        ctx.beginPath(); ctx.arc(px, py, ps, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255, 77, 0, ' + (0.4 + Math.sin(time * 2 + i) * 0.3) + ')';
        ctx.fill();
        const g = ctx.createRadialGradient(px, py, 0, px, py, 15);
        g.addColorStop(0, 'rgba(255, 77, 0, 0.15)'); g.addColorStop(1, 'transparent');
        ctx.beginPath(); ctx.arc(px, py, 15, 0, Math.PI * 2); ctx.fillStyle = g; ctx.fill();
      }

      rafId = requestAnimationFrame(drawWaveform);
    }
    rafId = requestAnimationFrame(drawWaveform);

    // ===== Proposta de Valor Canvas Waveform =====
    const vpCanvas = document.getElementById('vp-canvas');
    if (vpCanvas) {
      const vpCtx = vpCanvas.getContext('2d');
      let vpTime = 0;
      let vpRaf;

      function resizeVpCanvas() {
        const vp = document.getElementById('value-prop');
        vpCanvas.width = vp.offsetWidth;
        vpCanvas.height = vp.offsetHeight;
      }
      resizeVpCanvas();
      window.addEventListener('resize', resizeVpCanvas);

      function drawVpWaveform() {
        vpTime += 0.006;
        const w = vpCanvas.width, h = vpCanvas.height;
        vpCtx.clearRect(0, 0, w, h);

        // Grid
        vpCtx.strokeStyle = 'rgba(255, 77, 0, 0.03)';
        vpCtx.lineWidth = 1;
        const gs = 80;
        for (let x = 0; x < w; x += gs) { vpCtx.beginPath(); vpCtx.moveTo(x, 0); vpCtx.lineTo(x, h); vpCtx.stroke(); }
        for (let y = 0; y < h; y += gs) { vpCtx.beginPath(); vpCtx.moveTo(0, y); vpCtx.lineTo(w, y); vpCtx.stroke(); }

        // Waves
        const waves = [
          { freq: 1.2, amp: 30, speed: 0.8, alpha: 0.15, yOff: 0 },
          { freq: 2.0, amp: 18, speed: 1.1, alpha: 0.1, yOff: 60 },
          { freq: 0.6, amp: 40, speed: 0.5, alpha: 0.12, yOff: -50 },
        ];
        const cy = h * 0.5;
        waves.forEach(wave => {
          vpCtx.beginPath();
          vpCtx.strokeStyle = 'rgba(255, 77, 0, ' + wave.alpha + ')';
          vpCtx.lineWidth = 1.5;
          for (let x = 0; x < w; x += 2) {
            const y = cy + wave.yOff + Math.sin(x * wave.freq * 0.003 + vpTime * wave.speed) * wave.amp + Math.sin(x * 0.008 + vpTime * 0.5) * 8;
            if (x === 0) vpCtx.moveTo(x, y); else vpCtx.lineTo(x, y);
          }
          vpCtx.stroke();
        });

        vpRaf = requestAnimationFrame(drawVpWaveform);
      }
      vpRaf = requestAnimationFrame(drawVpWaveform);
    }

    // ===== Sticky Tab Bar =====
    const stickyBar = document.getElementById('sticky-tab-bar');
    window.addEventListener('scroll', () => {
      const heroBottom = window.innerHeight * 0.55;
      if (window.scrollY > heroBottom) {
        stickyBar.style.opacity = '1';
        stickyBar.style.transform = 'translateY(0)';
        stickyBar.style.pointerEvents = 'auto';
        stickyBar.style.height = 'auto';
        stickyBar.style.overflow = 'visible';
      } else {
        stickyBar.style.opacity = '0';
        stickyBar.style.transform = 'translateY(-8px)';
        stickyBar.style.pointerEvents = 'none';
        stickyBar.style.height = '0';
        stickyBar.style.overflow = 'hidden';
      }
    }, { passive: true });

    // ===== Tab Switching =====
    document.querySelectorAll('.sticky-hero-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;

        // Update button styles
        document.querySelectorAll('.sticky-hero-tab').forEach(b => {
          if (b.dataset.tab === tab) {
            b.classList.remove('text-[#374151]', 'hover:text-brand-orange', 'hover:bg-orange-50');
            b.classList.add('text-white', 'bg-brand-orange', 'shadow-sm');
          } else {
            b.classList.remove('text-white', 'bg-brand-orange', 'shadow-sm');
            b.classList.add('text-[#374151]', 'hover:text-brand-orange', 'hover:bg-orange-50');
          }
        });

        // Toggle all tab-panels
        document.querySelectorAll('.tab-panel').forEach(panel => {
          if (panel.dataset.tab === tab) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    // ===== Scroll Reveal =====
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          // Also reveal nested feat-cards
          entry.target.querySelectorAll('.feat-card').forEach((card, i) => {
            setTimeout(() => card.classList.add('visible'), i * 150);
          });
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ===== Roadmap Tooltip =====
    const tooltip = document.getElementById('roadmap-tooltip');
    document.querySelectorAll('.tooltip-trigger').forEach(el => {
      el.addEventListener('mouseenter', (e) => {
        const rect = e.currentTarget.getBoundingClientRect();
        tooltip.textContent = e.currentTarget.dataset.tip;
        tooltip.style.left = (rect.left + rect.width / 2) + 'px';
        tooltip.style.top = (rect.top - 10) + 'px';
        tooltip.style.transform = 'translate(-50%, -100%)';
        tooltip.classList.remove('hidden');
      });
      el.addEventListener('mouseleave', () => { tooltip.classList.add('hidden'); });
    });

    // ===== Product Matrix =====
    const seriesList = [
      { key: 'U', name: 'Ultrafino',      label: 'U-Series' },
      { key: 'D', name: 'Distribuído',     label: 'D-Series' },
      { key: 'A', name: 'Antipoluição',  label: 'A-Series' },
      { key: 'C', name: 'SiC',             label: 'C-Series' },
      { key: 'L', name: 'Padrão',        label: 'L-Series' },
    ];

    const voltColorMap = { '400V': '#3b82f6', '208V': '#eab308', '480V': '#f97316', '690V': '#ef4444' };
    const capacities = ['15A','30A','50A','75A','85A','100A','150A','200A'];

    const matrixData = {
      '400V': {
        U: ['15A'],
        D: ['30A','50A'],
        A: ['50A','75A','100A','150A','200A'],
        C: ['50A','75A','100A','150A'],
        L: ['50A','75A','100A','150A','200A'],
      },
      '208V': {
        U: [],
        D: [],
        A: ['50A','75A','100A','150A','200A'],
        C: ['50A','75A','100A','150A'],
        L: ['50A','75A','100A','150A','200A'],
      },
      '480V': {
        U: [],
        D: [],
        A: ['50A','75A','100A','150A','200A'],
        C: ['50A','75A','100A','150A'],
        L: ['50A','75A','100A','150A','200A'],
      },
      '690V': {
        U: [],
        D: [],
        A: ['85A','100A'],
        C: [],
        L: ['85A','100A'],
      },
    };

    const svgBySeries = {
      U: '10Kvar', D: '30~35Kvar', A: '35~150Kvar', C: '35~100Kvar', L: '35~150Kvar',
    };

    const specData = {
      'A-50A-400V':  { model:'AHF-A-050A-400',  current:'50A',  voltage:'380~415V', svg:'35Kvar',  weight:'25kg', harmonic:'2nd~50th', dimension:'440x176x380mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
      'A-75A-400V':  { model:'AHF-A-075A-400',  current:'75A',  voltage:'380~415V', svg:'50Kvar',  weight:'32kg', harmonic:'2nd~50th', dimension:'440x221x380mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
      'A-100A-400V': { model:'AHF-A-100A-400',  current:'100A', voltage:'380~415V', svg:'75Kvar',  weight:'40kg', harmonic:'2nd~50th', dimension:'440x266x380mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
      'A-150A-400V': { model:'AHF-A-150A-400',  current:'150A', voltage:'380~415V', svg:'100Kvar', weight:'58kg', harmonic:'2nd~50th', dimension:'600x310x450mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
      'A-200A-400V': { model:'AHF-A-200A-400',  current:'200A', voltage:'380~415V', svg:'150Kvar', weight:'75kg', harmonic:'2nd~50th', dimension:'600x400x450mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
      'C-50A-400V':  { model:'AHF-C-050A-400',  current:'50A',  voltage:'380~415V', svg:'35Kvar',  weight:'16kg', harmonic:'2nd~50th', dimension:'440x88x380mm',  monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'30kHz', ratedFreq:'50/60Hz' },
      'C-75A-400V':  { model:'AHF-C-075A-400',  current:'75A',  voltage:'380~415V', svg:'50Kvar',  weight:'24kg', harmonic:'2nd~50th', dimension:'440x132x380mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'30kHz', ratedFreq:'50/60Hz' },
      'C-100A-400V': { model:'AHF-C-100A-400',  current:'100A', voltage:'380~415V', svg:'75Kvar',  weight:'30kg', harmonic:'2nd~50th', dimension:'440x176x380mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'30kHz', ratedFreq:'50/60Hz' },
      'C-150A-400V': { model:'AHF-C-150A-400',  current:'150A', voltage:'380~415V', svg:'100Kvar', weight:'48kg', harmonic:'2nd~50th', dimension:'600x221x450mm', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'30kHz', ratedFreq:'50/60Hz' },
      'L-85A-690V':  { model:'AHF-L-085A-690',  current:'85A',  voltage:'690~800V', svg:'120Kvar', weight:'Contate-nos', harmonic:'2nd~50th', dimension:'Contate-nos', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
      'L-100A-690V': { model:'AHF-L-100A-690',  current:'100A', voltage:'690~800V', svg:'120Kvar', weight:'Contate-nos', harmonic:'2nd~50th', dimension:'Contate-nos', monitoring:'7" HMI Touchscreen', wiring:'3P3W / 3P4W', freq:'20kHz', ratedFreq:'50/60Hz' },
    };

    function getSpec(series, cap, volt) {
      const key = series + '-' + cap + '-' + volt;
      if (specData[key]) return specData[key];
      const vLabel = volt === '400V' ? '380~415V' : volt === '208V' ? '200~240V' : volt === '480V' ? '460~500V' : '690~800V';
      return {
        model: 'AHF-' + series + '-' + cap.replace('A','').padStart(3,'0') + 'A-' + volt.replace('V',''),
        current: cap,
        voltage: vLabel,
        svg: svgBySeries[series] || 'Contate-nos',
        weight: 'Contate-nos',
        harmonic: '2nd~50th',
        dimension: 'Contate-nos',
        monitoring: '7" HMI Touchscreen',
        wiring: '3P3W / 3P4W',
        freq: (series === 'C' ? '30kHz' : '20kHz'),
        ratedFreq: '50/60Hz'
      };
    }

    let selectedVoltage = '400V';
    let selectedCell = null;

    function renderMatrix() {
      const tbody = document.getElementById('matrix-tbody');
      const table = tbody.closest('table');
      const data = matrixData[selectedVoltage];
      const vColor = voltColorMap[selectedVoltage];
      tbody.innerHTML = '';
      const lastCap = capacities[capacities.length - 1];
      capacities.forEach(cap => {
        const tr = document.createElement('tr');
        tr.className = 'border-t border-[#d1d5db] hover:bg-[#fafbfc]';
        if (cap === lastCap) tr.style.borderBottom = '1px solid #d1d5db';
        let html = '<td class="p-2 text-text-dark font-medium text-sm font-barlow-condensed">' + cap + '</td>';
        seriesList.forEach(s => {
          const avail = data[s.key] || [];
          const isAvail = avail.includes(cap);
          const isSel = selectedCell && selectedCell.series === s.key && selectedCell.capacity === cap;
          html += '<td class="p-2 text-center"><button class="matrix-cell w-8 h-8 rounded-full flex items-center justify-center mx-auto transition-all duration-200 ' + (isAvail ? (isSel ? 'bg-brand-orange text-white scale-110 shadow-[0_0_12px_rgba(255,107,26,0.3)]' : 'border-2 hover:border-brand-orange hover:scale-105') : 'opacity-15 pointer-events-none') + '" data-series="' + s.key + '" data-cap="' + cap + '" ' + (!isAvail ? 'disabled' : '') + ' style="' + (isAvail && !isSel ? 'border-color:' + vColor + '60' : '') + '"><span class="w-3 h-3 rounded-full ' + (isSel ? 'bg-white' : '') + '" style="' + (!isSel && isAvail ? 'background-color:' + vColor : '') + '"></span></button></td>';
        });
        tr.innerHTML = html;
        tbody.appendChild(tr);
      });
      table.style.borderBottom = '1px solid #d1d5db';
      document.querySelectorAll('.matrix-cell').forEach(btn => {
        btn.addEventListener('click', () => {
          const series = btn.dataset.series;
          const cap = btn.dataset.cap;
          if (selectedCell && selectedCell.series === series && selectedCell.capacity === cap) {
            selectedCell = null;
            document.getElementById('spec-panel').classList.add('hidden');
          } else {
            selectedCell = { series, capacity: cap };
            showSpecPanel();
          }
          renderMatrix();
        });
      });
    }

    function showSpecPanel() {
      const panel = document.getElementById('spec-panel');
      const content = document.getElementById('spec-panel-content');
      const spec = getSpec(selectedCell.series, selectedCell.capacity, selectedVoltage);
      const sInfo = seriesList.find(s => s.key === selectedCell.series);
      const seriesDesc = sInfo ? sInfo.name : selectedCell.series;
      const modelParts = spec.model.split('-');
