    }

    initFaq('faqNavList', 'faqPanel');
    initFaq('faqNavListSvg', 'faqPanelSvg');
    // Ensure first items are properly set up after DOM
    // ===== Hash-Based Navigation =====
    const productHashMap = { 'ahf': '0', 'svg': '1', 'avr': '2', 'sic': '0', 'high-protection': '0' };

    function navigateToProduct() {
      const hash = window.location.hash.replace('#', '');
      if (hash && productHashMap[hash]) {
        const tab = productHashMap[hash];
        // Click the matching tab button
        const btn = document.querySelector(`.sticky-hero-tab[data-tab="${tab}"]`);
        if (btn) btn.click();
        // Scroll to product-series section for specific product anchors
        if (hash === 'sic' || hash === 'high-protection') {
          setTimeout(() => {
            document.getElementById('product-series')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 150);
        }
      }
    }

    window.addEventListener('hashchange', navigateToProduct);
    // Check initial hash
    navigateToProduct();

    setTimeout(setupFaqTab0, 100);
    setTimeout(setupFaqTab1, 100);
</script>
