---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Sobre a CHITEK – Perfil da Empresa e Certificações de Qualidade de Energia',
  description: 'A CHITEK é uma empresa de alta tecnologia fundada em 2019, especializada em I&D, fabrico e serviço de eletrónica de potência. Certificada ISO 9001 com mais de 20 patentes.',
};
---

<BaseLayout lang="pt" title={meta.title} description={meta.description}>
  <!-- ABOUT -->
  <section class="about relative overflow-hidden bg-bg-mid text-white mt-[72px] min-h-[calc(100vh-72px)] flex flex-col justify-center py-10 scroll-mt-[72px]" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>

    <!-- 顶部标题区域 -->
    <div class="relative z-10 text-center px-5 pt-6 pb-4 max-w-[900px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h1 class="font-barlow-condensed text-[clamp(36px,5vw,72px)] font-bold uppercase tracking-[0.02em] mb-[clamp(8px,2vw,32px)] text-white leading-[1.1]">APRESENTAÇÃO DA EMPRESA</h1>
    </div>

    <!-- 主体大框 (包含左右内容) -->
    <div class="relative z-10 flex flex-col md:flex-row w-[clamp(320px,90vw,1800px)] mx-auto max-md:mx-3 mb-[clamp(8px,1.5vw,32px)] bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <!-- 左侧 About CHITEK 区域 -->
      <div class="flex-1 px-[clamp(12px,2vw,56px)] py-[clamp(16px,3vw,72px)] flex flex-col justify-center border-b md:border-b-0 md:border-r border-white/10">
        <h2 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-[clamp(12px,2vw,32px)] uppercase tracking-[0.02em] text-white">SOBRE A <span class="text-brand-orange">CHITEK</span></h2>
        <div class="w-10 h-[3px] bg-brand-orange mb-[clamp(12px,2vw,32px)]"></div>
        <p class="text-[clamp(13px,0.9vw,16px)] leading-[1.8] text-white/75 mb-[clamp(16px,2.5vw,40px)]">
          A Shenzhen CHITEK New Energy Technology Co., Ltd., fundada em 2019 e
          com sede em Shenzhen, é uma empresa de alta tecnologia especializada em
          investigação, desenvolvimento, fabrico e serviço de produtos de
          eletrónica de potência. Comprometida em construir um futuro energeticamente
          eficiente e verde.
        </p>
        <a href="#" class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          Ver Vídeo
        </a>
      </div>

      <!-- 右侧四大优势区域 -->
      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <!-- 优势 1 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Equipa de I&amp;D Experiente</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Capacidade Sólida Apoiada por uma Equipa Altamente Qualificada e Experiente</p>
        </div>

        <!-- 优势 2 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Design Exclusivo</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Mais de 20 Patentes que Abrangem o Desenvolvimento e Fabrico de Produtos</p>
        </div>

        <!-- 优势 3 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Produtos Diversificados</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Gama Completa de Produtos para Diferentes Aplicações de Clientes</p>
        </div>

        <!-- 优势 4 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">Qualidade Garantida</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">Fabrico Certificado ISO que Garante os Mais Elevados Padrões de Qualidade</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRY CASES -->
  <section class="relative w-full min-h-[70vh] flex items-center justify-center py-16 px-[clamp(24px,8vw,160px)] overflow-hidden" id="industry">
    <div class="absolute inset-0 bg-[url('/assets/images/about-industry.webp')] bg-cover bg-center z-0"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(10,20,40,0.55)] to-[rgba(10,20,40,0.75)] z-[1]"></div>

    <div class="relative z-10 w-full text-center">
      <div class="fade-up">
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,52px)] font-bold text-white uppercase tracking-wide mb-3">CASOS DA INDÚSTRIA</h2>
        <div class="w-[60px] h-[3px] bg-brand-orange mx-auto mb-[50px]"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[clamp(12px,3vw,48px)] w-full fade-up">
        <!-- Card 1 -->
        <a href="/solutions#industry" class="block no-underline">
        <div class="bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] text-left backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-11 h-11 mb-5 text-brand-orange">
            <svg viewBox="0 0 48 48" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <rect x="8" y="6" width="32" height="36" rx="2"/>
              <rect x="14" y="12" width="20" height="6" rx="1"/>
              <line x1="18" y1="24" x2="30" y2="24"/>
              <line x1="18" y1="30" x2="30" y2="30"/>
              <line x1="18" y1="36" x2="24" y2="36"/>
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide">Fabrico Industrial</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70">Filtragem ativa de harmónicos e correção do fator de potência para maquinaria pesada, equipamentos de soldadura e sistemas acionados por motores em fábricas.</p>
        </div></a>

        <!-- Card 2 -->
        <a href="/solutions#commercial" class="block no-underline">
        <div class="bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] text-left backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-11 h-11 mb-5 text-brand-orange">
            <svg viewBox="0 0 48 48" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <path d="M6 44 L6 28 L14 28 L14 44"/>
              <path d="M18 44 L18 18 L26 18 L26 44"/>
              <path d="M30 44 L30 24 L38 24 L38 44"/>
              <path d="M4 28 L24 8 L44 28"/>
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide">Edifícios Comerciais e Médicos</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70">Proteção de equipamentos médicos sensíveis de imagem e sistemas de gestão de edifícios contra perturbações elétricas e quedas de tensão.</p>
        </div></a>

        <!-- Card 3 -->
        <a href="/solutions#datacenter" class="block no-underline">
        <div class="bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] text-left backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-11 h-11 mb-5 text-brand-orange">
            <svg viewBox="0 0 48 48" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <rect x="8" y="14" width="32" height="24" rx="2"/>
              <rect x="14" y="20" width="8" height="6" rx="1"/>
              <rect x="26" y="20" width="8" height="6" rx="1"/>
              <circle cx="24" cy="38" r="2"/>
              <line x1="24" y1="38" x2="24" y2="44"/>
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide">Data Centers e Telecomunicações</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70">Garantir qualidade de energia com zero tempo de inatividade para infraestrutura de TI crítica, sistemas UPS e centrais de comutação de telecomunicações.</p>
        </div></a>

        <!-- Card 4 -->
        <a href="/solutions#renewable" class="block no-underline">
        <div class="bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] text-left backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-11 h-11 mb-5 text-brand-orange">
            <svg viewBox="0 0 48 48" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <circle cx="24" cy="24" r="10"/>
              <path d="M24 4 L24 10"/>
              <path d="M24 38 L24 44"/>
              <path d="M4 24 L10 24"/>
              <path d="M38 24 L44 24"/>
              <path d="M9.86 9.86 L14.1 14.1"/>
              <path d="M33.9 33.9 L38.14 38.14"/>
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide">Energia Renovável</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70">Soluções de integração na rede para parques solares e eólicos, gerindo potência reativa e distorção harmónica de inversores.</p>
        </div></a>

        <!-- Card 5 -->
        <a href="/solutions#rail" class="block no-underline">
        <div class="bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] text-left backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-11 h-11 mb-5 text-brand-orange">
            <svg viewBox="0 0 48 48" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <rect x="10" y="18" width="28" height="20" rx="3"/>
              <circle cx="18" cy="38" r="4"/>
              <circle cx="30" cy="38" r="4"/>
              <line x1="14" y1="18" x2="14" y2="10"/>
              <line x1="34" y1="18" x2="34" y2="10"/>
              <line x1="10" y1="10" x2="38" y2="10"/>
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide">Transportes</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70">Soluções de qualidade de energia para estações de carregamento de VE, sistemas de tração ferroviária e infraestrutura para veículos elétricos.</p>
        </div></a>

        <!-- Card 6 -->
        <a href="/solutions#grid" class="block no-underline">
        <div class="bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] text-left backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-11 h-11 mb-5 text-brand-orange">
            <svg viewBox="0 0 48 48" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <path d="M4 24 L12 24 L16 12 L24 36 L32 16 L36 24 L44 24"/>
              <circle cx="24" cy="24" r="18"/>
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide">Rede Elétrica e Serviços Públicos</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70">Suporte à estabilidade da rede com compensação dinâmica de potência reativa e mitigação de harmónicos a nível de subestação.</p>
        </div></a>
      </div>
    </div>
  </section>

  <!-- CORE ADVANTAGES -->
  <section class="core-advantages relative w-full min-h-[calc(100vh-72px)] flex items-center justify-center py-16 px-[clamp(24px,8vw,160px)] overflow-hidden" id="core-advantages">
    <div class="absolute inset-0 bg-[url('/assets/images/about-key-features.webp')] bg-cover bg-center z-0"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(10,20,40,0.65)] to-[rgba(10,20,40,0.82)] z-[1]"></div>

    <div class="relative z-10 w-full text-center">
      <div class="fade-up">
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,52px)] font-bold text-white uppercase tracking-wide mb-3">VANTAGENS PRINCIPAIS</h2>
        <div class="w-[60px] h-[3px] bg-brand-orange mx-auto mb-[50px]"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[clamp(12px,3vw,48px)] w-full fade-up">
        <!-- Advantage 1: Expert R&D Team -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="text-[42px] font-bold leading-none text-brand-orange mb-4 text-left">60<sup class="text-[clamp(13px,1.1vw,17px)] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Equipa de I&amp;D Especializada</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Os membros da equipa provêm de empresas líderes mundiais, com mais de 60% a possuírem mestrado ou superior, garantindo uma profunda experiência técnica na inovação em eletrónica de potência.</p>
        </div>

        <!-- Advantage 2: Core Patent Technologies -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Tecnologias de Patente Principais</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Direitos de propriedade intelectual independentes que abrangem I&amp;D, design e fabrico, com mais de 20 patentes a proteger as nossas inovações.</p>
        </div>

        <!-- Advantage 3: Product Quality Control -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
              <polyline points="26,28 28,30 32,26" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Controlo de Qualidade do Produto</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Todos os produtos certificados segundo as normas internacionais CQC, CE e ISO 9001, garantindo desempenho fiável e conformidade nos mercados globais.</p>
        </div>

        <!-- Advantage 4: Full-Process Service -->
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <circle cx="32" cy="20" r="8" />
              <polygon points="16,52 24,32 40,32 48,52" stroke-linejoin="round" />
              <line x1="32" y1="40" x2="32" y2="50" />
              <line x1="24" y1="44" x2="40" y2="44" />
              <circle cx="28" cy="36" r="1.5" fill="currentColor" stroke="none" />
              <circle cx="36" cy="36" r="1.5" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">Serviço de Processo Completo</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">Serviço abrangente e soluções personalizadas que cobrem as fases de design, fabrico, operação e manutenção ao longo do ciclo de vida do produto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS & HONORS -->
  <section class="relative overflow-hidden py-12 px-[clamp(24px,8vw,160px)] bg-[#0c1628]" id="certifications">
    <div>
      <!-- Section Header -->
      <div class="text-center mb-14 fade-up">
        <div class="inline-flex items-center gap-3 mb-4 justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-brand-orange"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          <span class="text-[clamp(10px,0.8vw,14px)] text-brand-orange tracking-[0.15em] uppercase">Certificações e Honrarias</span>
        </div>
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,56px)] font-bold text-white uppercase tracking-[0.02em]">Garantia de Qualidade Global</h2>
