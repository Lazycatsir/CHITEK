---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
---
<BaseLayout title="Notícias e Insights | CHITEK INNOPOWER" description="Mantenha-se atualizado com as últimas notícias, artigos técnicos e insights do setor da CHITEK INNOPOWER em soluções de qualidade de energia." lang="pt">
  <Sidebar lang="pt" />

  <!-- Hero Section -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-20 md:py-28">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight mb-6">
        Notícias e <span class="text-brand-orange">Insights</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
        Mantenha-se informado sobre os últimos desenvolvimentos em tecnologia de qualidade de energia, tendências do setor e soluções CHITEK.
      </p>
    </div>
  </section>

  <!-- Latest Articles -->
  <section id="articles" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <h2 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mb-4">
        Artigos Mais Recentes
      </h2>
      <p class="text-text-mid text-lg mb-12 max-w-2xl">
        Explore nossas últimas notícias, atualizações de produtos e comunicados da empresa.
      </p>

      <div class="space-y-6">
        <!-- Article 1 - Jun 15, 2026 -->
        <a href="/pt/news/blog-active-harmonic-filter-for-vfd-systems" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-brand-orange/10 to-brand-orange/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-brand-orange/40">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div class="p-6 md:p-8 flex flex-col justify-center flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-semibold text-brand-orange bg-brand-orange/10 px-3 py-1 rounded-full">Tecnologia</span>
              <span class="text-xs text-text-muted">Jun 15, 2026</span>
            </div>
            <h3 class="text-xl font-bold text-text-dark mb-3 group-hover:text-brand-orange transition-colors">
              Filtros Ativos de Harmônicos para Sistemas VFD: Por Que São Essenciais
            </h3>
            <p class="text-text-mid text-sm leading-relaxed mb-4">
              Filtros Ativos de Harmônicos são indispensáveis para instalações com muitos VFDs. Descubra por que AHFs são a escolha inteligente para estabilizar a qualidade de energia.
            </p>
            <span class="inline-flex items-center text-brand-orange text-sm font-semibold">
              Leia Mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 ml-1">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Article 2 - Jun 8, 2026 -->
        <a href="/pt/news/blog-ahf-vs-line-reactors" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-purple-500/10 to-purple-500/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-purple-500/40">
              <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="p-6 md:p-8 flex flex-col justify-center flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-semibold text-purple-600 bg-purple-50 px-3 py-1 rounded-full">Tecnologia</span>
              <span class="text-xs text-text-muted">Jun 8, 2026</span>
            </div>
            <h3 class="text-xl font-bold text-text-dark mb-3 group-hover:text-brand-orange transition-colors">
              Filtros Ativos de Harmônicos vs Reatores de Linha: Uma Comparação Técnica
            </h3>
            <p class="text-text-mid text-sm leading-relaxed mb-4">
              Uma comparação técnica abrangente entre Filtros Ativos de Harmônicos e Reatores de Linha para mitigação da qualidade de energia industrial.
            </p>
            <span class="inline-flex items-center text-brand-orange text-sm font-semibold">
              Leia Mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 ml-1">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Article 3 - Jun 1, 2026 -->
        <a href="/pt/news/blog-svg-power-electronics-daily-life" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-green-500/10 to-green-500/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-green-500/40">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div class="p-6 md:p-8 flex flex-col justify-center flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full">Tecnologia</span>
              <span class="text-xs text-text-muted">Jun 1, 2026</span>
            </div>
            <h3 class="text-xl font-bold text-text-dark mb-3 group-hover:text-brand-orange transition-colors">
              Por Que SVG É o Guardião Invisível da Infraestrutura Moderna
            </h3>
            <p class="text-text-mid text-sm leading-relaxed mb-4">
              SVG é o silencioso guardião da qualidade de energia para redes modernas, parques industriais e infraestrutura urbana. Descubra como alimenta o cotidiano.
            </p>
            <span class="inline-flex items-center text-brand-orange text-sm font-semibold">
              Leia Mais
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 ml-1">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Article 4 - Dec 15, 2024 -->
        <a href="/pt/news/sic-ahf-launch" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-brand-orange/10 to-brand-orange/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-brand-orange/40">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
