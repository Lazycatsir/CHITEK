              </svg>
            </span>
          </div>
        </a>

        <!-- Article 8 - Oct 05, 2024 -->
        <a href="/pt/news/carbon-neutral-factories" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-cyan-500/10 to-cyan-500/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-cyan-500/40">
              <path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
