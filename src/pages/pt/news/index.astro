        <a href="#" class="w-10 h-10 flex items-center justify-center rounded border border-border-light text-text-muted hover:border-brand-orange hover:text-brand-orange transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
