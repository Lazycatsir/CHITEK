---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK INNOPOWER 鈥?manufacturer of power quality solutions',
  description: 'CHITEK is a leading manufacturer of low-voltage power quality solutions 鈥?Active Harmonic Filter (AHF), Static Var Generator (SVG) for industrial and commercial applications.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="ar">
  <!-- HERO -->
  <section id="hero-section" class="hero relative overflow-hidden mt-[72px] min-h-[calc(100vh-72px)] max-lg:min-h-[550px] max-md:min-h-[480px] flex items-center">
    <img src="/assets/images/index-hero-bg.webp" alt="Hero Background" class="absolute inset-0 w-full h-full object-cover object-[center_35%] max-lg:object-[center_25%] max-md:object-[center_15%] z-0 pointer-events-none" />

    <div class="flex flex-col justify-center px-[clamp(24px,8vw,160px)] py-20 max-md:py-16 relative z-10 w-full mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up text-right">
      <h1 class="font-barlow-condensed text-[clamp(38px,4.5vw,72px)] font-bold leading-[1.1] text-white mb-5">
        <span class="text-brand-orange">賲夭賵丿 乇丕卅丿 OEM</span> 賱丨賱賵賱 AHF<br />賵 SVG 賲賳禺賮囟丞 丕賱噩賴丿
      </h1>
      <p class="text-[clamp(13px,1.2vw,19px)] font-normal text-white/85 leading-[1.75] max-w-[560px] mb-9">
        丨爻賾賳 噩賵丿丞 丕賱胤丕賯丞 賱夭賷丕丿丞 丕賱廿賳鬲丕噩賷丞. 賳禺丿賲 兀賰孬乇 賲賳 30 丿賵賱丞 丨賵賱 丕賱毓丕賱賲.
      </p>
      <div class="flex gap-3.5 items-center">
        <a href="#products" class="bg-brand-orange text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-brand-orange hover:bg-brand-orange-dark hover:border-brand-orange-dark transition-[background,border-color] duration-200">丕爻鬲賰卮賮 丕賱賲賳鬲噩丕鬲</a>
        <a href="#about" class="text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-white/60 hover:bg-white/10 hover:border-white transition-all duration-200">丕毓乇賮 丕賱賲夭賷丿</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="relative overflow-hidden bg-bg-mid text-white min-h-[calc(100vh-72px)] flex flex-col justify-center py-10" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center bg-no-repeat opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>

    <div class="relative z-10 text-center px-5 pt-6 pb-4 max-w-[900px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h2 class="font-barlow-condensed text-[clamp(36px,4vw,72px)] font-bold uppercase tracking-[0.02em] mb-[clamp(8px,2vw,32px)] text-white leading-[1.1]">賳亘匕丞 毓賳 丕賱卮乇賰丞</h2>
    </div>

    <div class="relative z-10 flex flex-col md:flex-row w-[clamp(320px,90vw,1800px)] mx-auto max-md:mx-3 mb-[clamp(8px,1.5vw,32px)] bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <div class="flex-1 px-[clamp(12px,2vw,56px)] py-[clamp(16px,3vw,72px)] flex flex-col justify-center border-b md:border-b-0 md:border-l border-white/10">
        <h2 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-[clamp(12px,2vw,32px)] uppercase tracking-[0.02em] text-white">毓賳 <span class="text-brand-orange">鬲卮賷鬲賰鬲賰</span></h2>
        <div class="w-10 h-[3px] bg-brand-orange mb-[clamp(12px,2vw,32px)]"></div>
        <p class="text-[clamp(13px,0.9vw,16px)] leading-[1.8] text-white/75 mb-[clamp(16px,2.5vw,40px)]">
          卮乇賰丞 卮賳噩賳 鬲卮賷鬲賰鬲賰 賱鬲賰賳賵賱賵噩賷丕 丕賱胤丕賯丞 丕賱噩丿賷丿丞 丕賱賲丨丿賵丿丞貙 鬲兀爻爻鬲 賮賷 毓丕賲 2019 賵賲賯乇賴丕 賮賷 卮賳噩賳貙 賵賴賷 賲丐爻爻丞 毓丕賱賷丞 丕賱鬲賰賳賵賱賵噩賷丕 賲鬲禺氐氐丞 賮賷 丕賱亘丨孬 賵丕賱鬲胤賵賷乇 賵丕賱鬲氐賳賷毓 賵禺丿賲丞 賲賳鬲噩丕鬲 廿賱賰鬲乇賵賳賷丕鬲 丕賱胤丕賯丞. 賲賱鬲夭賲丞 亘亘賳丕亍 賲爻鬲賯亘賱 賲賵賮乇 賱賱胤丕賯丞 賵氐丿賷賯 賱賱亘賷卅丞.
        </p>
        <a href="#" class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          卮丕賴丿 丕賱賮賷丿賷賵
        </a>
      </div>

      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-l border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">賮乇賷賯 亘丨孬 賵鬲胤賵賷乇 匕賵 禺亘乇丞</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">賯丿乇丕鬲 賯賵賷丞 賲丿毓賵賲丞 亘賮乇賷賯 賲丐賴賱 鬲毓賱賷賲賷丕賸 賵匕丕鬲 禺亘乇丞 毓丕賱賷丞</p>
        </div>

        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">鬲氐賲賷賲 匕丕鬲賷</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">兀賰孬乇 賲賳 20 亘乇丕亍丞 丕禺鬲乇丕毓 鬲睾胤賷 鬲胤賵賷乇 丕賱賲賳鬲噩丕鬲 賵丕賱鬲氐賳賷毓</p>
        </div>

        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-l border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">賲賳鬲噩丕鬲 賲鬲賳賵毓丞</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">賲噩賲賵毓丞 賰丕賲賱丞 賲賳 丕賱賲賳鬲噩丕鬲 鬲睾胤賷 鬲胤亘賷賯丕鬲 丕賱毓賲賱丕亍 丕賱賲禺鬲賱賮丞</p>
        </div>

        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">噩賵丿丞 賲囟賲賵賳丞</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">鬲氐賳賷毓 賲毓鬲賲丿 賲賳 ISO 賷囟賲賳 兀毓賱賶 賲毓丕賷賷乇 丕賱噩賵丿丞</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="min-h-[calc(100vh-72px)] px-[clamp(24px,8vw,160px)] bg-[url('/assets/images/index-products-bg.webp')] bg-cover bg-center bg-no-repeat relative flex flex-col justify-center py-12" id="products">
    <div class="relative z-10">
      <div class="text-center mb-[clamp(16px,3vw,48px)] opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <h2 class="font-barlow-condensed text-[clamp(36px,4vw,72px)] font-bold uppercase tracking-[0.01em] leading-[1.1] mb-[clamp(4px,2vw,32px)]">爻賱爻賱丞 丕賱賲賳鬲噩丕鬲</h2>
        <div class="flex justify-center gap-1 mt-[clamp(8px,2vw,32px)] relative border-b border-border-light max-w-[740px] mx-auto overflow-x-auto max-md:justify-start">
          <div class="tab active text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap shrink-0" data-product="ahf">賮賱鬲乇 丕賱鬲賵丕賮賯 丕賱賳卮胤</div>
          <div class="tab text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap shrink-0" data-product="svg">賲賵賱丿 丕賱賮賵賱鬲 兀賲亘賷乇 丕賱爻丕賰賳</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr_1fr] gap-[clamp(12px,3vw,48px)] items-start opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <div class="min-h-[240px] relative">
          <div class="product-info-item active block" id="info-ahf">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">AHF</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">
              賮賱丕鬲乇 丕賱胤丕賯丞 丕賱賳卮胤丞 丕賱鬲賷 鬲睾胤賷 賲賳 208 賮賵賱鬲 廿賱賶 800 賮賵賱鬲貙 亘賰賮丕亍丞 鬲氐賱 廿賱賶 99%. 鬲睾胤賷丞 賰丕賲賱丞 賱賱鬲胤亘賷賯丕鬲 丕賱氐賳丕毓賷丞 賵丕賱鬲噩丕乇賷丞 賵賲乇丕賮賯 丕賱禺丿賲丞.
            </p>
            <a href="#" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">&larr; 賲乇賰夭 丕賱賲賳鬲噩丕鬲</a>
          </div>
          <div class="product-info-item hidden" id="info-svg">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">SVG</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">賷爻鬲禺丿賲 賲賵賱丿 丕賱賮賵賱鬲 兀賲亘賷乇 丕賱爻丕賰賳 賲賳 鬲卮賷鬲賰鬲賰 鬲賯賳賷丞 IGBT 丕賱賲鬲賯丿賲丞 亘賲毓丿賱 鬲亘丿賷賱 賷氐賱 廿賱賶 25.6 賰賷賱賵賴乇鬲夭 賱鬲賳馗賷賲 丿賯賷賯 賱丨噩賲 賵噩賴丿 丕賱毓丕賰爻. 賷賯丿賲 鬲毓賵賷囟丕賸 丿賷賳丕賲賷賰賷丕賸 賱賱賯丿乇丞reactive power 賵鬲賵丕夭賳 丕賱兀丨賲丕賱 丕賱孬賱丕孬賷丞 亘丿賯丞 丕爻鬲孬賳丕卅賷丞.</p>
            <a href="#" class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">&larr; 賲乇賰夭 丕賱賲賳鬲噩丕鬲</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-px bg-border-light h-full">
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">匕賰賷 賵賲乇賷丨</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">鬲丨乇賷賰 丕賱丨賲賱 丕賱匕乇賵賷貙 賯氐 丕賱匕乇賵丞 賵鬲毓丿賷賱 丕賱鬲乇丿丿貙 夭賷丕丿丞 丕賱賯丿乇丞 丕賱丕賮鬲乇丕囟賷丞 賵賵囟毓 睾賷乇 賲鬲氐賱 亘丕賱卮亘賰丞.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">賰賮丕亍丞 毓丕賱賷丞</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">賯賷賲丞 丨乇丕乇賷丞 賲賳禺賮囟丞 賱賱睾丕賷丞貙 胤丕賯丞 賮賷 賵囟毓 丕賱丕賳鬲馗丕乇 賲賳禺賮囟丞貙 賰賮丕亍丞 鬲氐賱 廿賱賶 98.5-99.2%. 鬲賯賳賷丞 SiC.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">鬲賵丕賮賯 賲鬲毓丿丿</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">賲鬲賵丕賮賯 賲毓 賲毓丕賷賷乇 丕賱噩賴丿 丕賱毓丕賱賲賷丞 孬賱丕孬賷丞 丕賱兀胤乇 3 兀爻賱丕賰 / 4 兀爻賱丕賰. 賷丿毓賲 丕賱賮賱鬲乇丞 丕賱賳卮胤丞 賱賱鬲賵丕賮賯賷丕鬲.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">氐丿賷賯 賱賱亘胤丕乇賷丞</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">賲噩賲賵毓丕鬲 丕賱亘胤丕乇賷丞 丕賱賲禺鬲賱賮丞 鬲毓賲賱 亘卮賰賱 賲爻鬲賯賱貙 賲賲丕 賷鬲噩賳亘 鬲賷丕乇 丕賱丿賵乇丕賳 丕賱賲鬲賵丕夭賷.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">氐賷丕賳丞 爻賴賱丞</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">毓賳丿 毓胤賱 丕賱賵丨丿丞貙 賱丕 賷鬲兀孬乇 亘丕賱丿賵丕卅乇 丕賱兀禺乇賶. 氐賷丕賳丞 爻乇賷毓丞 禺賱丕賱 5 丿賯丕卅賯.</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">丌賲賳 賵賲賵孬賵賯</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">賵馗丕卅賮 丨賲丕賷丞 毓胤賱 賰丕賲賱丞貙 亘丿賵賳 鬲賷丕乇 丿賵乇丕賳 賮賷 丕賱亘胤丕乇賷丞貙 鬲氐賳賷賮 賲爻鬲賵賶 丕賱鬲賱賵孬 III.</div>
