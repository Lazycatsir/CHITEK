---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "لماذا SVG هو الحارس الخفي للبنية التحتية الحديثة",
  category: "التكنولوجيا",
  date: "2026-02-22",
  dateDisplay: "22 فبراير 2026",
  author: "FNI CHITEK الفني",
  readTime: "5 دقائق للقراءة",
  description: "SVG هو الحارس الصامت لجودة الطاقة للشبكات الحديثة والمناطق الصناعية والبنية التحتية الحضرية. تعرف على كيفية تشغيله للحياة اليومية.",
  keywords: ["SVG", "مولد التيار المتغير الثابت", "جودة الطاقة", "تعويض القدرة التفاعلية", "الشبكة الذكية", "الطاقة المتجددة", "إلكترونيات القدرة", "FACTS"]
};

const otherArticles = [
  { title: "إطلاق سلسلة جديدة من المرشحات النشطة للتوافقيات المبنية على SiC", category: "تحديث المنتجات", href: "/ar/news/sic-ahf-launch", color: "orange" },
  { title: "المرشحات النشطة للتوافقيات لأنظمة VFD", category: "التكنولوجيا", href: "/ar/news/blog-active-harmonic-filter-for-vfd-systems", color: "blue" },
  { title: "AHF مقابل مفاعلات الخط: مقارنة فنية", category: "التكنولوجيا", href: "/ar/news/blog-ahf-vs-line-reactors", color: "purple" },
];

const relatedProducts = [
  { name: "المرشح النشط للتوافقيات AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "مولد التيار المتغير الثابت SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG الكفاءة العالية", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "مزرعة دبي الشمسية 50 ميجاوات", industry: "الطاقة المتجددة" },
  { name: "المنشأة الصناعية السعودية", industry: "التصنيع" },
  { name: "مركز البيانات البرازيلي", industry: "مراكز البيانات" },
];
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="ar"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/blog/sic-ahf-launch.webp"
>
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "لماذا SVG هو الحارس الخفي للبنية التحتية الحديثة",
    "description": "SVG هو الحارس الصامت لجودة الطاقة للشبكات الحديثة والمناطق الصناعية والبنية التحتية الحضرية. تعرف على كيفية تشغيله للحياة اليومية.",
    "image": "https://chitek-inno.com/assets/images/blog/sic-ahf-launch.webp",
    "author": { "@type": "Organization", "name": "FNI CHITEK الفني" },
    "publisher": { "@type": "Organization", "name": "CHITEK INNOPOWER", "logo": { "@type": "ImageObject", "url": "https://chitek-inno.com/assets/images/logo.webp" } },
    "datePublished": "2026-02-22",
    "dateModified": "2026-02-22",
    "keywords": "SVG, مولد التيار المتغير الثابت, جودة الطاقة, تعويض القدرة التفاعلية, الشبكة الذكية, الطاقة المتجددة, إلكترونيات القدرة, FACTS"
  }
  </script>

  <Sidebar lang="ar" />

  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href="/ar/news" class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        العودة إلى الأخبار
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <article class="flex-1 max-w-4xl">
                <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/news/news-img-7.webp" alt="لماذا SVG هو الحارس الخفي للبنية التحتية الحديثة" class="w-full h-full object-cover" loading="eager" />
        </div>

        <div class="prose prose-lg max-w-none">
          <p class="text-text-mid text-lg leading-relaxed mb-6">
            عندما تضاء الضوء، أو تشحن هاتفك، أو تركب المترو، أو تشاهد فيديو، فأنت تستخدم الكهرباء. لكن هل توقفت يومًا للتساؤل لماذا تظل هذه الطاقة مستقرة تمامًا ونظيفة وموثوقة؟
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            وراء إمدادات الطاقة غير المنقطعة ورحلات النقل السلسة ومزارع الرياح الفعالة تقع قطعة حاسمة من إلكترونيات القدرة تعمل على مدار الساعة طوال أيام الأسبوع، لكنها تظل غير معروفة خارج دوائر الهندسة: مولد التيار المتغير الثابت (SVG).
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            لا يظهر SVG أبدًا في إعلانات التكنولوجيا الاستهلاكية. ومع ذلك، فإنه يعمل كـ"حارس جودة الطاقة" الخفي للشبكات الحديثة والمناطق الصناعية والبنية التحتية الحضرية حول العالم.
          </p>

          <h2 id="what-is-svg" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            ما هو SVG؟
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            في أنظمة الطاقة، يُعد SVG عضوًا أساسيًا في عائلة FACTS (أنظمة النقل الكهربائية التكييفية). إنه جهاز تعويض كامل للقدرة التفاعلية يتميز بهندسة محوّل مصدر الجهد (VSC). على عكس أجهزة القدرة التفاعلية التقليدية التي تعتمد على مكونات ميكانيكية ضخمة أو مجموعات مكثفات ثابتة، يستخدم SVG التحكم بعرض النبضة (PWM) في الوقت الفعلي.
          </p>

          <h2 id="comparison" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            SVG مقابل معدات التعويض التقليدية
          </h2>
          <div class="overflow-x-auto mb-6">
            <table class="w-full border-collapse">
              <thead>
                <tr class="bg-gray-50">
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">المؤشرات الفنية</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">SVG</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">SVC</th>
                  <th class="text-left p-4 font-semibold text-text-dark border-b border-border-light">مجموعات المكثفات الثابتة</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="p-4 border-b border-border-light text-text-mid">سرعة الاستجابة</td><td class="p-4 border-b border-border-light text-text-mid font-semibold">5–10 مللي ثانية</td><td class="p-4 border-b border-border-light text-text-mid">20–30 مللي ثانية</td><td class="p-4 border-b border-border-light text-text-mid">100 مللي ثانية – ثوانٍ</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">تنظيم القدرة التفاعلية</td><td class="p-4 border-b border-border-light text-text-mid font-semibold">ثنائي الاتجاه، مستمر</td><td class="p-4 border-b border-border-light text-text-mid">سعة غير متدرجة</td><td class="p-4 border-b border-border-light text-text-mid">أحادي الاتجاه، متدرجة</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">قمع التوافقيات</td><td class="p-4 border-b border-border-light text-text-mid font-semibold">قوي</td><td class="p-4 border-b border-border-light text-text-mid">محدود</td><td class="p-4 border-b border-border-light text-text-mid">شبه معدوم</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">المساحة الفعلية</td><td class="p-4 border-b border-border-light text-text-mid font-semibold">صغيرة (معيارية)</td><td class="p-4 border-b border-border-light text-text-mid">كبيرة</td><td class="p-4 border-b border-border-light text-text-mid">كبيرة جدًا</td></tr>
                <tr><td class="p-4 border-b border-border-light text-text-mid">خطر رنين الشبكة</td><td class="p-4 border-b border-border-light text-text-mid font-semibold">منخفض للغاية</td><td class="p-4 border-b border-border-light text-text-mid">مرتفع</td><td class="p-4 border-b border-border-light text-text-mid">مرتفع للغاية</td></tr>
              </tbody>
            </table>
          </div>

          <h2 id="daily-life" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            أين يدعم SVG حياتك اليومية
          </h2>

          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">الشبكات السكنية والتجارية الحضرية</h3>
              <p class="text-text-mid text-sm">الأحمال الحضرية الحديثة - المصاعد ومكيفات الهواء ذات السرعة المتغيرة والإضاءة LED وشحناء السيارات الكهربائية - تُحدث خسائر كبيرة في القدرة التفاعلية. تقوم SVGs بتعديل القدرة التفاعلية باستمرار للحفاظ على جهد المدينة ضمن حدود ±5% ضيقة.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">تكامل الطاقة المتجددة</h3>
              <p class="text-text-mid text-sm">طاقة الرياح والطاقة الشمسية متقطعة بطبيعتها. تُعد SVGs ضرورية لمحطات الطاقة المتجددة على مستوى المرافق، حيث تستقر الشبكة أثناء الاندفاعات المفاجئة في التوليد وتضمن دمج الطاقة النظيفة بسلاسة.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">النقل السككي وقطارات عالية السرعة</h3>
              <p class="text-text-mid text-sm">تستهلك المترو وقطارات عالية السرعة طاقة هائلة بشكل مفاجئ عند التسريع. تستجيب SVGs في غضون مللي ثوانٍ لاستقرار جهد السكة، مما يمنع انخفاضات الجهد التي قد تُربك إشارات القطارات.</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="font-semibold text-text-dark mb-2">التصنيع المتقدم ومراكز البيانات</h3>
              <p class="text-text-mid text-sm">للمصانع الأشباه الموصولة ومراكز البيانات، يمكن أن يتسبب انخفاض في الجهد يستمر لبضع مللي ثوانٍ في تلف البيانات. ترفع SVGs عامل القدرة للنظام إلى أكثر من 0.99، مما يحمي البنية التحتية الرقمية عالية الحساسية.</p>
            </div>
          </div>

          <h2 id="conclusion" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            الخلاصة
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            أكثر التقنيات أهمية في المجتمع الحديث هي تلك التي لا نراها أبدًا. لا يتمتع SVG بالاعتراف بالعلامة التجارية الاستهلاكية، لكنه يعمل كركيزة أساسية للتحول العالمي في مجال الطاقة والأتمتة الصناعية. بالنسبة للمهندسين، يُعد SVG الأداة المثلى لاستقرار الشبكة. بالنسبة للجمهور العام، فهو الضامن الصامت للكهرباء الآمنة والفعالة والموثوقة.
          </p>

          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <div class="w-12 h-12 bg-brand-orange/10 rounded-full flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-brand-orange">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-text-dark">FNI CHITEK الفني</div>
              <div class="text-sm text-text-muted">نُشر {article.dateDisplay}</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">مشاركة:</span>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </article>

      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              مقالات أخرى
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={item.href} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              منتجات ذات صلة
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={product.href} class="flex items-center gap-2.5 p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="w-8 h-8 bg-brand-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-brand-orange">
                      <path d={product.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-text-dark truncate">{product.name}</div>
                  </div>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-text-muted shrink-0">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              حالات العملاء
            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href="/ar/news/solar-farm-dubai" class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
                  <div class="text-xs text-text-muted mt-1">{caseItem.industry}</div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
