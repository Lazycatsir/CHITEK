---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const article = {
  title: "المرشحات التوافقية النشطة مقابل السلبية: أين ينتمي كل منها حقًا",
  category: "التكنولوجيا",
  date: "2025-12-15",
  dateDisplay: "15 ديسمبر 2025",
  author: "FNI CHITEK الفني",
  readTime: "6 دقائق للقراءة",
  description: "مقارنة عملية بين المرشحات السلبية (LC المضبوطة) والمرشحات النشطة للتوافقيات (AHF) لتخفيف التوافقيات في قضبان الجهد المنخفض، بما في ذلك الأسباب الجذرية والقيود وتطور IGBT إلى SiC.",
  keywords: ["مرشح توافقي نشط", "AHF", "مرشح سلبي", "توافقيات", "جودة الطاقة", "IGBT", "SiC", "IEEE 519", "جهد منخفض", "CHITEK"]
};

const otherArticles = [
  { title: "الدليل الموسوعي لتعويض القدرة التفاعلية SVG", category: "التكنولوجيا", href: "/ar/news/svg-reactive-power-compensation-factory-guide", color: "orange" },
  { title: "الدليل الموسوعي لـ APF الموزع صغير السعة", category: "التكنولوجيا", href: "/ar/news/distributed-small-capacity-apf-guide", color: "orange" },
  { title: "تصحيح معامل القدرة النشط والتعويض الديناميكي للقدرة التفاعلية", category: "التكنولوجيا", href: "/ar/news/active-pfc-dynamic-reactive-compensation", color: "purple" },
];

const relatedProducts = [
  { name: "المرشح النشط للتوافقيات AHF", href: "/products#ahf", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "مولد التيار المتغير الثابت SVG", href: "/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "SiC-AHF/SVG الكفاءة العالية", href: "/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const relatedCases = [
  { name: "مزرعة دبي الشمسية 50 ميجاوات", industry: "الطاقة المتجددة" },
  { name: "المنشأة الصناعية السعودية", industry: "التصنيع" },
  { name: "مركز البيانات البرازيلي", industry: "مراكز البيانات" },
];
---
<BaseLayout 
  title={`${article.title} | CHITEK INNOPOWER`} 
  description={article.description} 
  lang="ar"
  ogType="article"
  ogTitle={article.title}
  ogDescription={article.description}
  ogImage="https://chitek-inno.com/assets/images/index-product-ahf.webp"
>
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "المرشحات التوافقية النشطة مقابل السلبية: أين ينتمي كل منها حقًا",
    "description": "مقارنة عملية بين المرشحات السلبية (LC المضبوطة) والمرشحات النشطة للتوافقيات (AHF) لتخفيف التوافقيات في قضبان الجهد المنخفض، بما في ذلك الأسباب الجذرية والقيود وتطور IGBT إلى SiC.",
    "image": "https://chitek-inno.com/assets/images/index-product-ahf.webp",
    "author": { "@type": "Organization", "name": "FNI CHITEK الفني" },
    "publisher": { "@type": "Organization", "name": "CHITEK INNOPOWER", "logo": { "@type": "ImageObject", "url": "https://chitek-inno.com/assets/images/logo.webp" } },
    "datePublished": "2025-12-15",
    "dateModified": "2025-12-15",
    "keywords": "active harmonic filter, AHF, passive filter, harmonics, power quality, IGBT, SiC, IEEE 519, low voltage, CHITEK"
  }
  </script>

  <Sidebar lang="ar" />

  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-16 md:py-20">
      <a href="/ar/news" class="inline-flex items-center text-brand-orange text-sm font-semibold mb-6 hover:underline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 mr-2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        العودة إلى الأخبار
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-brand-orange bg-brand-orange/20 px-3 py-1 rounded-full">{article.category}</span>
        <span class="text-xs text-gray-400">{article.dateDisplay}</span>
        <span class="text-xs text-gray-400">·</span>
        <span class="text-xs text-gray-400">{article.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight max-w-4xl">
        {article.title}
      </h1>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 flex flex-col lg:flex-row gap-10">

      <article class="flex-1 max-w-4xl">
        <!-- Featured Image -->
        <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-10 bg-gray-50">
          <img src="/assets/images/index-product-ahf.webp" alt="المرشحات التوافقية النشطة مقابل السلبية: أين ينتمي كل منها حقًا" class="w-full h-full object-cover" loading="eager" />
        </div>

        <div class="prose prose-lg max-w-none">
          <p class="text-text-mid text-lg leading-relaxed mb-6">
            الأحمال غير الخطية — محركات التردد المتغير، المقومات، أجهزة UPS، ماكينات اللحام، مزودات الطاقة ذات التبديل السريع — تسحب التيار بنبضات وتحقق ترددات توافقية في القضيب. إذا لم يتم التحكم بها، يؤدي هذا التشوه إلى ارتفاع حرارة المحولات والكابلات، ويشكل ضغطًا على المفاتيح الكهربائية ويقصر عمر المعدات. يوجد عائلتان رئيسيتان من الحلول: المرشحات السلبية (LC المضبوطة) والمرشحات النشطة للتوافقيات (AHF). لا يمكن استبدال أحدهما بالآخر، ويعتمد الاختيار الصحيح مباشرة على خصائص الحمل.
          </p>

          <h2 id="root-cause" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            السبب الجذري: لماذا تظهر التوافقيات
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            في شبكة الجهد المنخفض السليمة (≤ 1 كيلوفولت تقريبًا)، يكون تيار الحمل موجة جيبية نقية عند التردد الأساسي. الأحمال غير الخطية تقوم بالتبديل على مراحل وتنتج توافقيات مميزة. على سبيل المثال، الواجهة الأمامية ذات 6 نبضات تنتج توافقيات <code class="text-brand-orange bg-brand-orange/10 px-1 rounded">n = 6k ± 1</code> (الخامس، السابع، الحادي عشر، الثالث عشر…). بدون تخفيف، يتراوح THDi عادة بين 8% و30%، وهو أعلى بكثير من حد IEEE 519 البالغ &lt; 5% للجهد المنخفض (&lt; 3% لكل توافقي فردي). مع مشاركة المزيد من المحركات وإلكترونيات الطاقة لنفس القضيب، يستمر هذا الطيف في التغير طوال اليوم.
          </p>

          <h2 id="passive-filter" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            المرشحات التوافقية السلبية: ثابتة ومضبوطة
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            يستخدم المرشح السلبي مكثفات ومفاعلات ومقاومات لتشكيل شبكة LC مضبوطة على رتب توافقية محددة. يعمل من خلال توفير مسار منخفض المعاوقة للترددات المستهدفة. عندما يكون الحمل مستقرًا والطيف قابلًا للتنبؤ، تكون ميزته هي البساطة والتكلفة المنخفضة.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            لكن حدوده هيكلية:
          </p>
          <ul class="list-disc list-inside text-text-mid leading-relaxed mb-6 space-y-2">
            <li><span class="font-semibold text-text-dark">ضبط ثابت</span> — يعالج فقط الرتب التوافقية المصمم من أجلها</li>
            <li><span class="font-semibold text-text-dark">خطر الرنين</span> — يمكن لرنين LC أن يضخم التشوه</li>
            <li><span class="font-semibold text-text-dark">لا يتتبع الحمل</span> — لا يمكنه متابعة قضيب يتقلب محتواه التوافقي</li>
          </ul>

          <h2 id="active-filter" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            المرشحات النشطة للتوافقيات: ديناميكية وعريضة النطاق
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            AHF للجهد المنخفض يقيس تيار الحمل عبر محولات التيار، ويعزل المكونات التوافقية، ويحقن تيارًا مساويًا في السعة ومعاكسًا في الطور: <code class="text-brand-orange bg-brand-orange/10 px-1 rounded">i<sub>c</sub><sup>*</sup> = i<sub>L</sub> − i<sub>s</sub> (الأساسي)</code>. يلغي أي رتبة توافقية تظهر، ويغطي نطاقًا عريضًا (عادة من الثاني إلى الخمسين) في الوقت الفعلي بزمن استجابة &lt; 1 مللي ثانية. يتتبع القضيب بينما تسارع المحركات وتبطئ، ويدير المصادر المختلطة، ويتجنب تمامًا مصائد الرنين.
          </p>

          <h2 id="decision" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            الاختيار يعتمد على الحمل
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            اختر السلبي عندما يكون الحمل مستقرًا، والرتب التوافقية محددة جيدًا، ولا يتطلب الأمر تتبعًا ديناميكيًا. اختر AHF عندما يكون الحمل متغيرًا (عدة محركات، مصادر غير خطية مختلطة)، أو عندما يجب تجنب الرنين، أو عندما يحتاج جهاز واحد لتغطية رتب توافقية متعددة.
          </p>
          <p class="text-text-mid leading-relaxed mb-6">
            في معظم قضبان الجهد المنخفض الحديثة — المصانع، محطات معالجة المياه، مراكز البيانات، المباني التجارية — لم تعد الأحمال بسيطة بما يكفي لحلها بحلول ثابتة فقط. عندما يتعايش حمل أساسي كبير مع مصادر توافقية متقلبة، غالبًا ما يُعتمد نهج هجين (سلبي كأساس + AHF للضبط الدقيق).
          </p>

          <h2 id="converter-core" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            قلب المحول: IGBT مقابل SiC
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            أداء AHF محدود بمفاتيح الطاقة الخاصة به. درجة حرارة الوصلة المقدرة لـ IGBT القياسي حوالي 150 درجة مئوية، وترددات التبديل عادة أقل من 20 كيلوهرتز؛ تزداد خسائر التبديل مع التردد، مما يحد من سرعة التتبع. MOSFET SiC يرفع هذا السقف: كربيد السيليكون هو جهاز عريض فجوة النطاق (3.26 eV فجوة نطاق، مقابل 1.12 eV للسيليكون)، يتحمل حوالي 200 درجة مئوية، ويحقق ترددات تبديل تبلغ 2–3 أضعاف IGBT، ويقلل خسائر التبديل بنحو 50%. هذا يترجم إلى تحسن في الكفاءة بنسبة 1%–3% وقمع أكثر دقة للتوافقيات. منصة AHF للجهد المنخفض من CHITEK مبنية على هذا التطور من IGBT إلى SiC.
          </p>

          <h2 id="conclusion" class="text-2xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mt-10 mb-4">
            الخلاصة
          </h2>
          <p class="text-text-mid leading-relaxed mb-6">
            للمرشحات السلبية مكانها في الأحمال المستقرة والقابلة للتنبؤ؛ المرشحات النشطة تتألق في الأحمال الديناميكية وغير الخطية. الاختيار الخاطئ — مرشح ثابت على قضيب محركات متقلب — يخاطر بالرنين وفشل التتبع. قس القضيب الحقيقي أولاً، ثم طابق المعدات مع الحمل.
          </p>

          <!-- CTA Question -->
          <p class="text-text-mid text-lg font-semibold leading-relaxed mb-8">
            ما هي تقنية الترشيح المناسبة لقضيبك؟ اتصل بـ CHITEK لإجراء تقييم توافقي واحصل على توصية اختيار مبنية على البيانات.
          </p>

          <div class="mt-10 pt-6 border-t border-border-light">
            <div class="flex flex-wrap gap-2">
              {article.keywords.map((keyword) => (
                <span class="text-xs text-text-muted bg-gray-100 px-3 py-1 rounded-full">#{keyword}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border-light">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <div class="w-12 h-12 bg-brand-orange/10 rounded-full flex items-center justify-center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-brand-orange">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-text-dark">FNI CHITEK الفني</div>
              <div class="text-sm text-text-muted">نُشر {article.dateDisplay}</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">مشاركة:</span>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="#" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.05c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579260405315" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded border border-border-light flex items-center justify-center hover:border-brand-orange hover:text-brand-orange transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </article>

      <aside class="lg:w-[320px] shrink-0">
        <div class="lg:sticky lg:top-[88px] space-y-4">

          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
              مقالات أخرى
            </h3>
            <div class="space-y-2">
              {otherArticles.map((item) => (
                <a href={item.href} class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark leading-snug">{item.title}</div>
                </a>
              ))}
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              منتجات ذات صلة
            </h3>
            <div class="space-y-2">
              {relatedProducts.map((product) => (
                <a href={product.href} class="flex items-center gap-2.5 p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="w-8 h-8 bg-brand-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-brand-orange">
                      <path d={product.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-text-dark truncate">{product.name}</div>
                  </div>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-text-muted shrink-0">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="font-bold text-text-dark mb-3 flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-brand-orange">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              حالات العملاء
            </h3>
            <div class="space-y-2">
              {relatedCases.map((caseItem) => (
                <a href="/ar/news/solar-farm-dubai" class="block p-2.5 bg-white rounded-lg border border-border-light hover:border-brand-orange hover:shadow-sm transition-all no-underline">
                  <div class="text-sm font-semibold text-text-dark">{caseItem.name}</div>
                  <div class="text-xs text-text-muted mt-1">{caseItem.industry}</div>
                </a>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
