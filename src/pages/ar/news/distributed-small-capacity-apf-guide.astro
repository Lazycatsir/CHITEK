  { name: "مولد الفار الثابت SVG", href: "/ar/products#svg", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "السلسلة عالية الكفاءة SiC-AHF/SVG", href: "/ar/products#sic", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

