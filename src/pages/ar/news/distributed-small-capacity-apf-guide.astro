  category: "تكنولوجيا",
  date: "2026-05-16",
  dateDisplay: "16 مايو 2026",
  author: "الفريق الفني لـ CHITEK",
  readTime: "8 دقائق قراءة",
  description: "دليل شامل لحلول تخفيف التوافقيات باستخدام APF الموزع صغير السعة في المباني التجارية ومراكز البيانات ومشاريع التحديث — يغطي المبادئ التقنية وتكييف السيناريوهات ومعايير الاختيار وبراءات الاختراع وشهادات الامتثال.",
  keywords: ["APF", "مرشح القدرة النشط", "موزع", "سعة صغيرة", "تخفيف التوافقيات", "مرشح نشط", "IGBT", "كربيد السيليكون", "SiC", "CHITEK"]
};

const otherArticles = [
  { title: "مسح ممارسي صناعة مرشحات القدرة النشطة 2026", category: "اتجاهات الصناعة", href: "/ar/news/apf-industry-practitioner-2026", color: "orange" },
