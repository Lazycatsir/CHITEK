    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <h2 class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-barlow-condensed)] text-text-dark mb-4">
        أحدث المقالات
      </h2>
      <p class="text-text-mid text-lg mb-12 max-w-2xl">
        استكشف آخر أخبارنا وتحديثات المنتجات وإعلانات الشركة.
      </p>

      <div class="space-y-6">
        <!-- Article 1 - Jul 9, 2026 -->
        <a href="/ar/news/blog-chitek-ahf-advantages" class="group bg-white rounded-xl overflow-hidden border border-border-light hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row no-underline">
          <div class="relative w-full md:w-[320px] lg:w-[380px] h-48 md:h-auto bg-gradient-to-br from-brand-orange/10 to-brand-orange/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-brand-orange/40">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
