---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
---
<BaseLayout title="الأخبار والرؤى | CHITEK INNOPOWER" description="تابع آخر الأخبار والورقات التقنية ورؤى الصناعة من CHITEK INNOPOWER في حلول جودة الطاقة." lang="ar">
  <Sidebar lang="ar" />

  <!-- Hero Section -->
  <section class="pt-[72px] bg-bg-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-20 md:py-28">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-[family-name:var(--font-barlow-condensed)] tracking-tight mb-6">
        الأخبار والـ<span class="text-brand-orange">رؤى</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
        تابع أحدث التطورات في تكنولوجيا جودة الطاقة واتجاهات الصناعة وحلول CHITEK.
      </p>
    </div>
  </section>

  <!-- Latest Articles -->
