---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'عن تشيتكتك – ملف الشركة وشهادات جودة الطاقة',
  description: 'تشيتكتك مؤسسة عالية التكنولوجيا تأسست عام 2019، متخصصة في البحث والتطوير وتصنيع وخدمة إلكترونيات الطاقة. معتمدة من ISO 9001 مع أكثر من 20 براءة اختراع.',
};
---

<BaseLayout title={meta.title} description={meta.description} lang="ar">
  <!-- ABOUT -->
  <section class="about relative overflow-hidden bg-bg-mid text-white mt-[72px] min-h-[calc(100vh-72px)] flex flex-col justify-center py-10 scroll-mt-[72px]" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>

    <div class="relative z-10 text-center px-5 pt-6 pb-4 max-w-[900px] mx-auto opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <h1 class="font-barlow-condensed text-[clamp(36px,5vw,72px)] font-bold uppercase tracking-[0.02em] mb-[clamp(8px,2vw,32px)] text-white leading-[1.1]">نبذة عن الشركة</h1>
    </div>

    <div class="relative z-10 flex flex-col md:flex-row w-[clamp(320px,90vw,1800px)] mx-auto max-md:mx-3 mb-[clamp(8px,1.5vw,32px)] bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <div class="flex-1 px-[clamp(12px,2vw,56px)] py-[clamp(16px,3vw,72px)] flex flex-col justify-center border-b md:border-b-0 md:border-l border-white/10">
        <h2 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-[clamp(12px,2vw,32px)] uppercase tracking-[0.02em] text-white">عن <span class="text-brand-orange">تشيتكتك</span></h2>
        <div class="w-10 h-[3px] bg-brand-orange mb-[clamp(12px,2vw,32px)]"></div>
        <p class="text-[clamp(13px,0.9vw,16px)] leading-[1.8] text-white/75 mb-[clamp(16px,2.5vw,40px)]">
          شركة شنجن تشيتكتك لتكنولوجيا الطاقة الجديدة المحدودة، تأسست في عام 2019 ومقرها في شنجن، وهي مؤسسة عالية التكنولوجيا متخصصة في البحث والتطوير والتصنيع وخدمة منتجات إلكترونيات الطاقة. ملتزمة ببناء مستقبل موفر للطاقة وصديق للبيئة.
        </p>
        <a href="#" class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          شاهد الفيديو
        </a>
      </div>

      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-l border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">فريق بحث وتطوير ذو خبرة</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">قدرات قوية مدعومة بفريق مؤهل تعليمياً وذات خبرة عالية</p>
        </div>

        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">تصميم ذاتي</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">أكثر من 20 براءة اختراع تغطي تطوير المنتجات والتصنيع</p>
        </div>

        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-l border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">منتجات متنوعة</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">مجموعة كاملة من المنتجات تغطي تطبيقات العملاء المختلفة</p>
        </div>

        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">جودة مضمونة</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">تصنيع معتمد من ISO يضمن أعلى معايير الجودة</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRY CASES -->
  <section class="relative w-full overflow-hidden bg-white" id="industry">
    <div class="relative z-10 w-full pt-12 max-md:pt-8">
      <div class="text-center mb-8 max-md:mb-5 fade-up">
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,52px)] font-bold text-text-dark uppercase tracking-wide">دراسات الحالة الصناعية</h2>
        <div class="w-[60px] h-[3px] bg-brand-orange mx-auto mt-3"></div>
      </div>

      <div class="grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 fade-up">
        <a href="/solutions#industry" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-manufacturing.webp" alt="التصنيع الصناعي" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">التصنيع الصناعي</span>
          </div>
        </a>
        <a href="/solutions#commercial" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-commercial-medical.webp" alt="المباني التجارية والطبية" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">المباني التجارية والطبية</span>
          </div>
        </a>
        <a href="/solutions#datacenter" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-datacenter.webp" alt="مراكز البيانات والاتصالات" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">مراكز البيانات والاتصالات</span>
          </div>
        </a>
        <a href="/solutions#renewable" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-renewable.webp" alt="الطاقة المتجددة" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">الطاقة المتجددة</span>
          </div>
        </a>
        <a href="/solutions#rail" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-transportation.webp" alt="النقل" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">النقل</span>
          </div>
        </a>
        <a href="/solutions#grid" class="relative group block overflow-hidden aspect-[4/3]">
          <img src="/assets/images/about-industry-power-grid.webp" alt="شبكة الكهرباء والمرافق" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-300 flex items-center justify-center max-md:bg-black/40 max-md:opacity-100">
            <span class="text-white text-[clamp(16px,1.5vw,24px)] max-md:text-[14px] font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide max-md:opacity-100">شبكة الكهرباء والمرافق</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CORE ADVANTAGES -->
  <section class="core-advantages relative w-full min-h-[calc(100vh-72px)] flex items-center justify-center py-16 px-[clamp(24px,8vw,160px)] overflow-hidden" id="core-advantages">
    <div class="absolute inset-0 bg-[url('/assets/images/about-key-features.webp')] bg-cover bg-center z-0"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(10,20,40,0.65)] to-[rgba(10,20,40,0.82)] z-[1]"></div>

    <div class="relative z-10 w-full text-center">
      <div class="fade-up">
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,52px)] font-bold text-white uppercase tracking-wide mb-3">المزايا الجوهرية</h2>
        <div class="w-[60px] h-[3px] bg-brand-orange mx-auto mb-[50px]"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[clamp(12px,3vw,48px)] w-full fade-up">
        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="text-[42px] font-bold leading-none text-brand-orange mb-4 text-left">60<sup class="text-[clamp(13px,1.1vw,17px)] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">فريق بحث وتطوير متخصص</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">يأتي أعضاء الفريق من مؤسسات رائدة عالمياً، مع أكثر من 60% يحملون درجات الماجستير أو أعلى، مما يضمن خبرة تقنية عميقة في ابتكار إلكترونيات الطاقة.</p>
        </div>

        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">تقنيات براءات اختراع أساسية</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">حقوق ملكية فكرية مستقلة تغطي البحث والتطوير والتصميم والتصنيع مع أكثر من 20 براءة اختراع تحمي ابتكاراتنا.</p>
        </div>

        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
              <polyline points="26,28 28,30 32,26" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">رقابة جودة المنتجات</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">جميع المنتجات معتمدة وفقاً لمعايير CQC و CE و ISO 9001 الدولية، مما يضمن أداءً موثوقاً والامتثال في جميع الأسواق العالمية.</p>
        </div>

        <div class="ca-card bg-white/[0.06] border border-white/10 rounded p-[clamp(16px,3vw,48px)] backdrop-blur transition-all duration-[350ms] hover:bg-brand-orange/[0.1] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 mb-4 text-brand-orange text-left">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none stroke-linecap-round stroke-linejoin-round">
              <circle cx="32" cy="20" r="8" />
              <polygon points="16,52 24,32 40,32 48,52" stroke-linejoin="round" />
              <line x1="32" y1="40" x2="32" y2="50" />
              <line x1="24" y1="44" x2="40" y2="44" />
              <circle cx="28" cy="36" r="1.5" fill="currentColor" stroke="none" />
              <circle cx="36" cy="36" r="1.5" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-white mb-2.5 tracking-wide text-left">خدمة شاملة</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-relaxed text-white/70 text-left">خدمة شاملة وحلول مخصصة تغطي مراحل التصميم والتصنيع والتشغيل والصيانة طوال دورة حياة المنتج.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS & HONORS -->
  <section class="relative overflow-hidden py-12 px-[clamp(24px,8vw,160px)] bg-white" id="certifications">
    <div>
      <div class="text-center mb-14 fade-up">
        <div class="inline-flex items-center gap-3 mb-4 justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-brand-orange"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          <span class="text-[clamp(10px,0.8vw,14px)] text-brand-orange tracking-[0.15em] uppercase">الشهادات والجوائز</span>
        </div>
        <h2 class="font-barlow-condensed text-[clamp(28px,3vw,56px)] font-bold text-text-dark uppercase tracking-[0.02em]">ضمان الجودة العالمية</h2>
        <div class="w-[60px] h-[3px] bg-gradient-to-r from-transparent via-brand-orange to-transparent mx-auto mb-4"></div>
        <p class="text-[15px] text-text-secondary max-w-[600px] mx-auto leading-relaxed">معايير إدارة الجودة وسلامة المنتجات المعتمدة دولياً تضمن أداءً موثوقاً في جميع الأسواق.</p>
      </div>

      <div class="relative fade-up" id="certCarousel">
        <div id="certTrack" class="flex transition-transform duration-500 ease-out">
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(18px,1.4vw,24px)] font-bold text-brand-orange font-barlow-condensed">CE</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">علامة CE</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">معتمدة من TÜV Rheinland، متوافقة مع الاتحاد الأوروبي</p>
            </div>
          </div>
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(18px,1.4vw,24px)] font-bold text-brand-orange font-barlow-condensed">UL</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">UL 508 مدرج</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">معتمد لسلامة أمريكا الشمالية</p>
            </div>
          </div>
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
            <div class="bg-bg-card border border-border-card rounded p-4 h-full transition-all duration-[350ms] hover:border-brand-orange hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)] flex flex-col items-center">
              <div class="w-full h-[72px] mb-2.5 bg-brand-orange/10 rounded flex items-center justify-center overflow-hidden">
                <span class="text-[clamp(16px,1.2vw,20px)] font-bold text-brand-orange font-barlow-condensed text-center leading-tight">ISO<br>9001</span>
              </div>
              <h3 class="text-[clamp(13px,1.1vw,17px)] font-bold text-text-dark text-center font-barlow-condensed tracking-wide">ISO 9001:2015</h3>
              <p class="text-[clamp(10px,0.8vw,14px)] text-text-secondary text-center mt-1 leading-relaxed">إدارة جودة معتمدة من SGS</p>
            </div>
          </div>
          <div class="cert-card min-w-[33.333%] max-md:min-w-full px-2">
