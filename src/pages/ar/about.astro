        <button id="certPrev" class="absolute left-0 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-bg-card border border-border-card rounded-full text-text-dark hover:bg-brand-orange hover:text-white hover:border-brand-orange transition-all duration-200 cursor-pointer z-10 max-md:hidden">
