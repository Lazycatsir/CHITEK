---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found – CHITEK INNOPOWER" description="The page you are looking for does not exist. Return to CHITEK homepage.">
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 mt-[72px]">
    <h1 class="font-barlow-condensed text-[clamp(72px,12vw,160px)] font-bold text-brand-orange leading-[1] mb-4">404</h1>
    <p class="text-[clamp(16px,1.5vw,24px)] text-text-dark font-medium mb-8">Page not found</p>
    <p class="text-text-muted max-w-md mb-10">The page you are looking for might have been moved or deleted. Let's get you back on track.</p>
    <a href="/" class="bg-brand-orange text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline hover:bg-brand-orange-dark transition-colors duration-200">Back to Homepage</a>
  </section>
</BaseLayout>
