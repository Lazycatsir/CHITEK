---
import BaseLayout from '../layouts/BaseLayout.astro';

const meta = {
  title: 'CHITEK INNOPOWER – 低压电能质量解决方案制造商',
  description: 'CHITEK是低压电能质量解决方案领先制造商——有源电力滤波器(AHF)、静止无功发生器(SVG)和自动电压调节器(AVR)，广泛应用于工业和商业领域。',
};

// 本地开发/预览用语言前缀；线上（子域名承载语言）保持根相对
const isLocal = /localhost|127\.0\.0\.1|0\.0\.0\.0/.test(Astro.url.host);
const lp = (p: string) => isLocal ? '' + p : p;

---

<BaseLayout title={meta.title} description={meta.description} lang="zh">
  <!-- HERO -->
  <section id="hero-section" class="hero relative overflow-hidden mt-[72px] min-h-[calc(100vh-72px)] max-lg:min-h-[550px] max-md:min-h-[480px] flex items-center">
    <div class="hero-carousel absolute inset-0 z-0 pointer-events-none">
      <img src="/assets/images/index-hero-bg1.webp" alt="促进能源与生态的和谐共生" class="hero-slide hero-slide-active absolute inset-0 w-full h-full object-cover object-[center_35%] max-lg:object-[center_25%] max-md:object-[center_15%]" />
      <img src="/assets/images/index-hero-bg.webp" alt="CHITEK 首页背景" class="hero-slide absolute inset-0 w-full h-full object-cover object-[center_35%] max-lg:object-[center_25%] max-md:object-[center_15%]" />
    </div>

    <!-- 文字面板 0：新图专属主题（第一页，仅此一句） -->
    <div class="hero-text hero-text-active absolute inset-0 z-10 flex flex-col justify-center px-[clamp(24px,8vw,160px)]">
      <h1 class="font-barlow-condensed text-[clamp(40px,5vw,76px)] font-bold leading-[1.1] max-w-[1200px] [word-break:keep-all]">
        <span class="text-white">促进能源与生态的</span><br /><span class="text-brand-orange">和谐共生</span>
      </h1>
    </div>

    <!-- 文字面板 1：原首图内容（第二页，保持不变） -->
    <div class="hero-text absolute inset-0 z-10 flex flex-col justify-center px-[clamp(24px,8vw,160px)]">
      <h1 class="font-barlow-condensed text-[clamp(38px,4.5vw,72px)] font-bold leading-[1.1] text-white mb-5">
        <span class="text-brand-orange">低压AHF与SVG解决方案</span> 领先OEM供应商
      </h1>
      <p class="text-[clamp(13px,1.2vw,19px)] font-normal text-white/85 leading-[1.75] max-w-[560px] mb-9">
        优化电能质量，提升生产效率。服务全球30+国家与地区。
      </p>
      <div class="flex gap-3.5 items-center">
        <a href="#products" class="bg-brand-orange text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-brand-orange hover:bg-brand-orange-dark hover:border-brand-orange-dark transition-[background,border-color] duration-200">探索产品</a>
        <a href="#about" class="text-white text-[13px] font-semibold tracking-[0.06em] uppercase px-7 py-3.5 rounded-sm no-underline border-2 border-white/60 hover:bg-white/10 hover:border-white transition-all duration-200">了解更多</a>
      </div>
    </div>

    <!-- HERO 轮播指示点 -->
    <div class="hero-dots absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2.5">
      <button type="button" class="hero-dot hero-dot-active" data-slide="0" aria-label="切换到第 1 张"></button>
      <button type="button" class="hero-dot" data-slide="1" aria-label="切换到第 2 张"></button>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="relative overflow-hidden bg-bg-mid text-white min-h-[calc(100vh-72px)] flex flex-col justify-center py-10" id="about">
    <div class="absolute inset-0 bg-[url('/assets/images/about-bg.webp')] bg-cover bg-center bg-no-repeat opacity-30 z-0"></div>
    <div class="absolute inset-0 bg-[rgba(7,16,30,0.7)] z-[1]"></div>


    <!-- 主体大框 -->
    <div class="relative z-10 flex flex-col md:flex-row w-[clamp(320px,90vw,1800px)] mx-auto max-md:mx-3 mb-[clamp(8px,1.5vw,32px)] bg-white/[0.03] border border-white/15 shadow-2xl opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
      <!-- 左侧 About CHITEK 区域 -->
      <div class="flex-1 px-[clamp(12px,2vw,56px)] py-[clamp(16px,3vw,72px)] flex flex-col justify-center border-b md:border-b-0 md:border-r border-white/10">
        <h3 class="font-barlow-condensed text-[32px] font-bold leading-[1.2] mb-[clamp(12px,2vw,32px)] uppercase tracking-[0.02em] text-white">关于 <span class="text-brand-orange">CHITEK</span></h3>
        <div class="w-10 h-[3px] bg-brand-orange mb-[clamp(12px,2vw,32px)]"></div>
        <p class="text-[clamp(13px,0.9vw,16px)] leading-[1.8] text-white/75 mb-[clamp(16px,2.5vw,40px)]">
          深圳市启点新能源科技有限公司成立于2019年，总部位于深圳，是一家专注于电力电子产品研发、制造和销售服务的高新技术企业。致力于打造节能、绿色的未来。
        </p>
        <a href={lp('/about')} class="inline-flex items-center gap-2.5 bg-brand-orange-light text-[#0f2040] text-[13px] font-bold tracking-[0.05em] uppercase px-7 py-3.5 rounded-sm no-underline transition-all duration-300 w-fit border-none hover:bg-white hover:-translate-y-0.5 hover:shadow-md">
          <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current stroke-none">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          播放视频
        </a>
      </div>

      <!-- 右侧四大优势区域 -->
      <div class="flex-[1.2] grid grid-cols-1 md:grid-cols-2">
        <!-- 优势 1 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="font-barlow-condensed text-[42px] font-bold leading-[1] text-brand-orange mb-3">60<sup class="text-[16px] align-super text-brand-orange">%</sup></div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">经验丰富的研发团队</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">60%成员拥有硕士及以上学历，来自世界领先企业</p>
        </div>

        <!-- 优势 2 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center border-b border-white/10 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="32" r="8" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(0 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(60 32 32)" />
              <ellipse cx="32" cy="32" rx="24" ry="10" transform="rotate(120 32 32)" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">自主研发设计</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">20余项专利覆盖产品研发与制造</p>
        </div>

        <!-- 优势 3 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center md:border-r border-b border-white/10 md:border-b-0 hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <path d="M20 20 L44 20 L44 44 L20 44 Z" stroke-linecap="round" />
              <circle cx="38" cy="38" r="10" stroke-linecap="round" />
              <line x1="42" y1="42" x2="48" y2="48" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">多元化产品</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">全系列产品覆盖不同客户应用场景</p>
        </div>

        <!-- 优势 4 -->
        <div class="px-[clamp(12px,2vw,40px)] py-[clamp(16px,3vw,56px)] flex flex-col items-center justify-center text-center hover:bg-[rgba(255,107,26,0.05)] transition-colors duration-300 relative">
          <div class="w-12 h-12 mb-4 text-brand-orange">
            <svg viewBox="0 0 64 64" class="w-full h-full stroke-current stroke-[1.5] fill-none">
              <circle cx="32" cy="16" r="8" />
              <path d="M16 32 L48 32 L56 48 L8 48 Z" stroke-linecap="round" stroke-linejoin="round" />
              <polygon points="24,36 26,42 32,42 34,48 38,42 44,42 40,36" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3 class="text-[clamp(12px,1.1vw,17px)] font-bold text-white mb-2 leading-[1.4] uppercase tracking-[0.02em]">品质保障</h3>
          <p class="text-[clamp(10px,0.8vw,14px)] leading-[1.6] text-white max-w-[180px]">ISO认证制造，确保最高质量标准</p>
        </div>
      </div>
    </div>
  
    <!-- 统计数字：整合进 Company Intro 区域，不再单独成区 -->
    <div class="relative z-10 w-[clamp(320px,90vw,1800px)] mx-auto grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-4 text-center pt-[clamp(20px,3vw,48px)]">
      <div class="flex flex-col items-center">
        <div class="font-barlow-condensed text-[clamp(40px,5vw,64px)] font-bold leading-[1] text-brand-orange"><span class="stat-number" data-target="2019" data-duration="1600">0</span></div>
        <div class="mt-3 text-[clamp(12px,1vw,15px)] font-semibold uppercase tracking-[0.08em] text-white/85">成立于</div>
      </div>
      <div class="flex flex-col items-center">
        <div class="font-barlow-condensed text-[clamp(40px,5vw,64px)] font-bold leading-[1] text-brand-orange"><span class="stat-number" data-target="2700" data-duration="1800">0</span><span class="text-[clamp(28px,3vw,40px)]">+</span></div>
        <div class="mt-3 text-[clamp(12px,1vw,15px)] font-semibold uppercase tracking-[0.08em] text-white/85">公司面积</div>
      </div>
      <div class="flex flex-col items-center">
        <div class="font-barlow-condensed text-[clamp(40px,5vw,64px)] font-bold leading-[1] text-brand-orange"><span class="stat-number" data-target="30" data-duration="2600">0</span><span class="text-[clamp(28px,3vw,40px)]">+</span></div>
        <div class="mt-3 text-[clamp(12px,1vw,15px)] font-semibold uppercase tracking-[0.08em] text-white/85">知识产权</div>
      </div>
      <div class="flex flex-col items-center">
        <div class="font-barlow-condensed text-[clamp(40px,5vw,64px)] font-bold leading-[1] text-brand-orange"><span class="stat-number" data-target="20" data-duration="2600">0</span><span class="text-[clamp(28px,3vw,40px)]">+</span></div>
        <div class="mt-3 text-[clamp(12px,1vw,15px)] font-semibold uppercase tracking-[0.08em] text-white/85">出口国家</div>
      </div>
    </div>
</section>

  <!-- PRODUCTS -->
  <section class="min-h-[calc(100vh-72px)] px-[clamp(24px,8vw,160px)] bg-[url('/assets/images/index-products-bg.webp')] bg-cover bg-center bg-no-repeat relative flex flex-col justify-center py-12" id="products">
    <div class="relative z-10">
      <div class="text-center mb-[clamp(16px,3vw,48px)] opacity-0 translate-y-6 transition-all duration-[600ms] ease fade-up">
        <h2 class="font-barlow-condensed text-[clamp(36px,4vw,72px)] font-bold uppercase tracking-[0.01em] leading-[1.1] mb-[clamp(4px,2vw,32px)]">产品系列</h2>
        <div class="flex justify-center gap-1 mt-[clamp(8px,2vw,32px)] relative border-b border-border-light max-w-[740px] mx-auto overflow-x-auto max-md:justify-start">
          <div class="tab active text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap shrink-0" data-product="ahf">有源电力滤波器</div>
          <div class="tab text-[14px] font-medium text-text-muted px-5 py-2 cursor-pointer relative border-b-2 border-transparent mb-[-1px] transition-colors duration-200 hover:text-brand-orange whitespace-nowrap shrink-0" data-product="svg">静止无功发生器</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr_1fr] gap-[clamp(12px,3vw,48px)] items-start">
        <!-- 左侧：文字介绍 -->
        <div class="min-h-[240px] relative fade-up conv-left">
          <div class="product-info-item active" id="info-ahf">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">AHF</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">
              有源谐波滤波器（AHF）覆盖 208V 至 800V，效率最高可达 99%。AHF 是一种实时、基于 IGBT 或 SiC 的有源滤波器，能够检测非线性负载所汲取的谐波电流，并注入大小相等、方向相反的电流在源头将其抵消——从而恢复纯净的正弦波形并校正功率因数。广泛应用于工业厂房、商业楼宇、数据中心、医院、电动汽车充电站及可再生能源场站等存在谐波畸变、功率因数罚款或电网不稳定问题的场所。
            </p>
            <a href={lp('/products')} class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">产品中心 &rarr;</a>
          </div>
          <div class="product-info-item" id="info-svg">
            <h3 class="font-barlow-condensed text-[clamp(20px,2vw,32px)] font-bold uppercase mb-2">SVG</h3>
            <div class="w-8 h-[3px] bg-brand-orange mb-4"></div>
            <p class="text-[13px] text-text-muted leading-[1.7] mb-6">
              CHITEK 静止无功发生器（SVG）采用先进的 IGBT 或 SiC 开关技术，频率高达 25.6kHz，可精确调节逆变器电压幅值与相位。SVG 是一种实时无功补偿装置，通过注入或吸收无功电流来动态校正功率因数、稳定电压——消除罚款、电压跌落与闪变。广泛应用于工业厂房、商业楼宇、数据中心、新能源电站、电动汽车充电枢纽及电网等存在无功功率、电压波动或负载不平衡问题的场所。
            </p>
            <a href={lp('/products')} class="text-[11px] font-semibold tracking-[0.1em] uppercase text-text-muted no-underline flex items-center gap-1.5 hover:text-brand-orange transition-colors duration-200">产品中心 &rarr;</a>
          </div>
        </div>

        <!-- 中间：功能特征网格 -->
        <div class="grid grid-cols-2 gap-px bg-border-light h-full">
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200 ps-card">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">补偿效果好</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">具有谐波补偿THDi &lt;5%、功率因数补偿PF&gt;0.99和三相不平衡等多种补偿功能</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200 ps-card">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">模块化设计</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">采用模块化设计，全系列机型可直接替换，方便集成和扩容，易用灵活</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200 ps-card">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">高密度低损耗</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">相同功率体积更小，节约占地空间，损耗满载时&lt;2.5%</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200 ps-card">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">保护功能</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">具备过压、过流、过温等多种保护功能，确保运行异常时保护系统及设备</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200 ps-card">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">友好UI界面</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">LCD显示，友好人机界面，实时监控，操作便捷</div>
          </div>
          <div class="bg-white p-[clamp(8px,1.5vw,32px)] cursor-pointer flex flex-col justify-start hover:bg-[#fff9f6] transition-colors duration-200 ps-card">
            <div class="text-[clamp(11px,1vw,15px)] font-semibold text-brand-orange mb-2">扩展功能强</div>
            <div class="w-6 h-0.5 bg-brand-orange mb-3"></div>
            <div class="text-[clamp(10px,0.9vw,14px)] text-text-muted leading-[1.6]">支持485通信、Wifi扩展功能，标准配置2路输入2路输出干接点</div>
          </div>
        </div>

        <!-- 右侧：图片介绍 -->
        <div class="flex items-center justify-end fade-up conv-right">
          <div class="w-[clamp(160px,25vw,340px)] h-[clamp(300px,34vw,460px)] rounded-sm relative overflow-hidden bg-contain bg-center bg-no-repeat bg-[url('/assets/images/index-product-ahf.webp')]" id="product-visual"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const productData = {
      ahf: { visual: '/assets/images/index-product-ahf.webp', infoId: 'info-ahf' },
      svg: { visual: '/assets/images/index-product-svg.webp', infoId: 'info-svg' }
    };

    const tabs = document.querySelectorAll('.tab');
    const infoItems = document.querySelectorAll('.product-info-item');
    const productVisual = document.getElementById('product-visual');

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const key = this.getAttribute('data-product');
        const data = productData[key];

        // 1. 切换 Tab 样式
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');

        // 2. 切换左侧文字
        infoItems.forEach(item => {
          item.classList.remove('active');
        });
        const target = document.getElementById(data.infoId);
        target.classList.add('active');

        // 3. 切换右侧图片
        productVisual.style.backgroundImage = `url('${data.visual}')`;
      });
    });

    // STATS 数字滚动动画（可重复播放）
    const statNumbers = document.querySelectorAll('.stat-number');
    if (statNumbers.length) {
      const animateCount = (el) => {
        const target = parseInt(el.getAttribute('data-target'), 10) || 0;
        const duration = parseInt(el.getAttribute('data-duration'), 10) || 1500;
        if (el._rafId) cancelAnimationFrame(el._rafId);
        const start = performance.now();
        const step = (now) => {
          const p = Math.min((now - start) / duration, 1);
          const eased = target <= 50 ? p : 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(eased * target).toString();
          if (p < 1) {
            el._rafId = requestAnimationFrame(step);
          } else {
            el.textContent = target.toString();
            el._rafId = null;
          }
        };
        el._rafId = requestAnimationFrame(step);
      };
      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCount(entry.target);
          } else {
            // 离开视口时重置，便于下次重新播放
            if (entry.target._rafId) cancelAnimationFrame(entry.target._rafId);
            entry.target._rafId = null;
            entry.target.textContent = '0';
          }
        });
      }, { threshold: 0.4 });
      statNumbers.forEach((el) => statsObserver.observe(el));
    }

    // HERO 轮播
    const heroSlides = Array.from(document.querySelectorAll('.hero-slide'));
    const heroTexts = Array.from(document.querySelectorAll('.hero-text'));
    const heroDots = Array.from(document.querySelectorAll('.hero-dot'));
    if (heroSlides.length > 1) {
      let heroIdx = 0;
      let heroTimer = null;
      const heroShow = (i) => {
        heroSlides[heroIdx].classList.remove('hero-slide-active');
        if (heroTexts[heroIdx]) heroTexts[heroIdx].classList.remove('hero-text-active');
        if (heroDots[heroIdx]) heroDots[heroIdx].classList.remove('hero-dot-active');
        heroIdx = (i + heroSlides.length) % heroSlides.length;
        heroSlides[heroIdx].classList.add('hero-slide-active');
        if (heroTexts[heroIdx]) heroTexts[heroIdx].classList.add('hero-text-active');
        if (heroDots[heroIdx]) heroDots[heroIdx].classList.add('hero-dot-active');
      };
      const heroStart = () => { heroTimer = setInterval(() => heroShow(heroIdx + 1), 5000); };
      const heroStop = () => { if (heroTimer) { clearInterval(heroTimer); heroTimer = null; } };
      heroDots.forEach((dot, i) => {
        dot.addEventListener('click', () => { heroStop(); heroShow(i); heroStart(); });
      });
      heroStart();
    }

    // 可反复触发入场：进视口加 .visible，出视口移除；滚动回来重新播放
    // 作用对象：Product Series 左右两栏 + Solution Insights 标题与三张卡片
    const revealEls = document.querySelectorAll('.conv-left, .conv-right, .insight-title, .insight-card, .ps-card');
    if (revealEls.length) {
      const insightCards = Array.from(document.querySelectorAll('.insight-card'));
      const psCards = Array.from(document.querySelectorAll('.ps-card'));
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const el = entry.target;
          if (entry.isIntersecting) {
            if (el.classList.contains('insight-card')) {
              const i = insightCards.indexOf(el);
              setTimeout(() => el.classList.add('visible'), i * 120);
            } else if (el.classList.contains('ps-card')) {
              const i = psCards.indexOf(el);
              setTimeout(() => el.classList.add('visible'), i * 90);
            } else {
              el.classList.add('visible');
            }
          } else {
            el.classList.remove('visible');
          }
        });
      }, { threshold: 0.12 });
      revealEls.forEach((el) => revealObserver.observe(el));
    }
  </script>

